---
name: checkout_billing_address
resource: modules/insites_core/crm_address
resource_owner: anyone
redirect_to: checkout/payment
flash_alert: "Error-UserAddressBilling"
flash_notice: "Success-UserAddressBilling"
fields:
  properties:
    uuid:
    related_uuid:
    related_type: 
      property_options:
        default: "contact"
    #Do not edit any address properties for logged in user.
    #use virtual property instead of original; sample: used address_1_ instead of address_1
    #The Add address modal form is responsible for adding new address.
    address_1_:
      property_options:
        virtual: true
    address_2_:
      property_options:
        virtual: true
    suburb_:
      property_options:
        virtual: true
    state_:
      property_options:
        virtual: true
    postcode_:
      property_options:
        virtual: true
    country_:     
      property_options:
        virtual: true
    billing_same_with_shipping:
      property_options:
        virtual: true   
    billing_company_name:
      property_options:
        virtual: true
    billing_contact_first_name:
      property_options:
        virtual: true
    billing_contact_last_name:
      property_options:
        virtual: true
    billing_contact_email:
      property_options:
        virtual: true
    billing_contact_phone_number:
      property_options:
        virtual: true
    billing_contact_phone_country_code:
      property_options:
        virtual: true
    billing_address_id:
      property_options:
        virtual: true        
    
callback_actions: |-    

  {%- session billing_address_id = form.properties.billing_address_id -%}
  {%- session latest_step = 4 -%}

---

{% assign prop = form.fields.properties %}

{%- form 
  html-id: "billing-address-form"
  html-novalidate: true
  html-enctype="multipart/form-data"
  html-onsubmit:"return Checkout.events.billingSubmit(event);" -%}  


    {% include 'modules/ecommerce/checkout/checkout_billing_contacts', prop %}

    <div class="spacer large"></div>

    <div class="grid-x">        
      <h4>Billing address</h4>
      <div class="cell show-for-small-only spacer"></div>
      {% comment %} Add new address {% endcomment %}
      <div class="text-right flex-child-grow"
        id="address-toggle">
        <ins-button 
          type="button" 
          id="add-address-btn"
          name="billing-address-fields" 
          icon="icon-plus" 
          label="Add new address">
        </ins-button>
      </div> 
    </div>      

    <div class="spacer xx-small"></div>
      
    {% comment %} Selected address {% endcomment %}
    <ins-input validate
      id="billing_address_id" 
      class="hidden-input"
      value="{{ context.session.billing_address_id }}"
      name="{{ prop.billing_address_id.name }}"
      error-message="Billing address is required. Please select from the list below or add new address.">
    </ins-input> 
                
    {%- comment -%} Address cards {%- endcomment -%}
    {%- include 'modules/ecommerce/layout/address_cards', 
      addresses: addresses,
      selected_card: context.session.billing_address_id | default: "",
      type: 'billing' -%}
        

    {% comment %} Buttons {% endcomment %}
    {% include 'modules/ecommerce/checkout/checkout_billing_buttons' %}
     
    {% comment %} There is an error when removing this '</div>'. Cant find the opening <div> yet {% endcomment %}
    </div>
{%- endform -%}

{% comment %} Add new address modal {% endcomment %}
{% comment %} Do not put this modal inside <form>, it has it's own validation. {% endcomment %}
{% include 'modules/ecommerce/checkout/add_address_modal', page: 'billing' %}
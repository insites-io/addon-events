---
name: checkout_create_user
resource: User
resource_owner: anyone
redirect_to: checkout/shipping
flash_alert: Sorry-AddUser
flash_notice: Success-AddUser
fields:
  email:
    validation: 
      presence:
        message: Please use a valid email address
      email: 
        message: Please use a valid email address
  password:
    validation: 
      presence: 
        message: Invalid Password
  first_name:
    validation: 
      presence: 
        message: First name is required
  last_name:
    validation: 
      presence: 
        message: Last name is required
  account_company_name:
    property_options:
      virtual: true
  profiles:
    modules/insites_core/insites_contact_number:
      properties:
        mobile_phone_number:
        mobile_phone_country_code:
    modules/insites_core/insites_customer:
      properties:
        is_enabled:
          property_options:
            default: true
            readonly: true
    modules/ecommerce/customer:
      properties:
        is_enabled:
          property_options:
            default: true
            readonly: true
        is_activated:
          property_options:
            default: false
            readonly: true
default_payload: |-
  {
    "fields": {
      "profiles":{
        "modules/ecommerce/customer":{
          "properties_attributes": {
            "is_enabled" : true,
            "is_activated" : true
          }
        }
      }
    }
  }
callback_actions: |-    
  {% graphql g = 'modules/ecommerce/account/generate_user_temporary_token', email: form.email %}
  {% if g.items.results[0] %}
    {% graphql res = 'modules/ecommerce/account/set_email_verification_token', id: g.items.results[0].id, token: g.items.results[0].temporary_token %}
  {% endif %}  

  {% graphql user_login = 'modules/ecommerce/account/create_user_session', 
    email: form.email, 
    password: form.password %}

  {%- log "==== Triggered: context User ====" -%}

  {%- assign phone_info = form.profiles['modules/insites_core/insites_contact_number'].properties.mobile_phone_number | default: "" -%}
  {%- assign company_name = form.account_company_name | default: "" -%}
  {%- background priority: 'default', 
    max_attempts: 3, 
    source_name: "CRM Jobs", 
    form_email: form.email, 
    phone_info: phone_info,
    company_name: company_name -%}

  {%- graphql user_info = 'modules/ecommerce/user/get_user_by_email', 
    email: form_email 
    | dig: 'items' | dig: 'results' | first -%}
  
  {%- log "==== Triggered: Get User By Email ====" -%}

  {%- include 'modules/insites_core/insites_admin/insites_create_crm_on_submit',
    email: user_info.email,
    first_name: user_info.first_name,
    last_name: user_info.last_name,
    mobile_phone_number: phone_info,
    model_id: user_info.id -%} 

  {%- log "==== Triggered: Checkout Create CRM on Submit ====" -%}

  {%- if company_name and company_name != blank -%}
  {%- include 'modules/ecommerce/checkout/create_crm_company_on_submit',
    user_id: user_info.id,
    company_name: company_name -%}
  {%- endif -%}

  {%- endbackground -%}

  {%- log "==== Triggered: Checkout Create Company on Submit ====" -%}

  {%- session account_company_name = form.account_company_name | default: "" -%}
  {%- session account_mobile_number = form.profiles['modules/insites_core/insites_contact_number'].properties.mobile_phone_number | default: "" -%}
  {%- session account_mobile_country_code = form.profiles['modules/insites_core/insites_contact_number'].properties.mobile_phone_country_code | default: "" -%}

  {%- session latest_step = 2 -%}
    
---

{%- form 
  html-id: "checkout-account-detail" 
  html-novalidate: true 
  html-enctype="multipart/form-data" 
  html-onsubmit:"return Checkout.events.accountSubmit(event);" -%}


  <div id="account-details">
    <h2 class="heading-1 font-color-head">Account Details</h2>
    <div class="spacer xxx-large"></div>
    <h2 class="heading-2">Account Information</h2>
    <div class="spacer x-large"></div>

    <div class="grid-x grid-padding-x account-details">

      <input type="hidden" 
        id="hidden-account-phone"
        name="{{ form.fields.profiles['modules/insites_core/insites_contact_number'].properties.mobile_phone_number.name }}"
        value="{{ form.fields.profiles['modules/insites_core/insites_contact_number'].properties.mobile_phone_number.value }}" />
      <input type="hidden" 
        id="hidden-account-phone-country-code"
        name="{{ form.fields.profiles['modules/insites_core/insites_contact_number'].properties.mobile_phone_country_code.name }}"
        value="{{ form.fields.profiles['modules/insites_core/insites_contact_number'].properties.mobile_phone_country_code.value }}" />

      <div class="large-12 medium-12 small-12 cell">
        <ins-input   
          class="label-input" 
          label="Company Name"
          placeholder="Company Name" 
          field="text" 
          id="account-company-name" 
          value="{{ input_company_name | default: '' }}"
          name="{{ form.fields.account_company_name.name }}">
        </ins-input>
      </div>
      <div class="large-6 medium-6 small-12 cell">
        <ins-input required validate  class="label-input"
          {% if context.current_user and context.current_user.first_name %} readonly {% endif %} 
          label="First Name*"
          placeholder="First Name" 
          id="account-first-name" 
          value="{{ context.current_user.first_name }}"
          name="{{ form.fields.first_name.name }}" 
          {% if form.errors['first_name'] %} has-error {% endif %}
          error-message="{{ form.fields.first_name.validation.rules.presence.message }}">
        </ins-input>
      </div>
      <div class="large-6 medium-6 small-12 cell">
        <ins-input required validate  
          class="label-input"
          {% if context.current_user and context.current_user.last_name %} readonly {% endif %} label="Last Name*"
          placeholder="Last Name" id="account-last-name" value="{{ context.current_user.last_name }}"
          name="{{ form.fields.last_name.name }}" 
          {% if form.errors['last_name'] %} has-error {% endif %}
          error-message="{{ form.fields.last_name.validation.rules.presence.message }}">
        </ins-input>
      </div>
      <div class="large-6 medium-6 small-12 cell">
        <ins-input required validate  
          class="label-input new-user-email"
          {% if context.current_user and context.current_user.email %} readonly {% endif %} 
          label="Email*"
          placeholder="Email" 
          field="email" 
          id="account-email" 
          value="{{ context.current_user.email }}"
          name="{{ form.fields.email.name }}" 
          {% if form.errors['email'] %} has-error {% endif %}
          error-message="{{ form.fields.email.validation.rules.presence.message }}">
        </ins-input>
      </div>
      <div class="large-6 medium-6 small-12 cell">
        <ins-input-tel  
          class="label-input" 
          id="account-phone" 
          label="Mobile Phone"
          areacode-value="{{ data.current_user.insites_contact_number[0].mobile_phone_country_code | default: '61'}}"  
          phonenum-value="{{ data.current_user.insites_contact_number[0].mobile_phone_number }}"
          phonenum-placeholder="Mobile Phone" 
          no-areacode>
        </ins-input-tel>
      </div>
      <div class="large-6 medium-6 small-12 cell">
        <ins-input class="label-input" required validate 
          {% if context.current_user and context.current_user.email %} readonly {% endif %}
          label="Password*"
          placeholder="Password" 
          field="password" 
          id="account-password" 
          value="" 
          name="{{ form.fields.password.name }}"
          {% if form.errors['password'] %} has-error {% endif %}
          error-message="{{ form.fields.password.validation.rules.presence.message }}">
        </ins-input>
      </div>
    </div>

    <input type="hidden" name="page_id" value="{{ context.page.id }}"  />
    <input type="hidden" name="{{ form.fields.profiles['modules/insites_core/insites_customer'].properties.is_enabled.name }}" value="{{ form.fields.profiles['modules/insites_core/insites_customer'].properties.is_enabled.value }}">
    <input type="hidden" name="{{ form.fields.profiles['modules/ecommerce/customer'].properties.is_enabled.name }}" value="{{ form.fields.profiles['modules/ecommerce/customer'].properties.is_enabled.value }}">
    <input type="hidden" name="{{ form.fields.profiles['modules/ecommerce/customer'].properties.is_activated.name }}" value="{{ form.fields.profiles['modules/ecommerce/customer'].properties.is_activated.value }}">

    <div class="grid-x grid-padding-x">
      <div class="large-12 medium-12 small-12 cell text-right">
        <div class="spacer small"></div>
        <ins-button solid type="submit" id="account-submit" label="Create Account">
        </ins-button>
      </div>
    </div>
  </div>
        
{%- endform -%}




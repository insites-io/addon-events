---
name: checkout_shipping_address
resource: modules/insites_core/crm_address
resource_owner: anyone
redirect_to: checkout/billing
flash_alert: "Error-UserAddressShipping"
flash_notice: "Success-UserAddressShipping"
fields:
  properties:
    uuid:
    related_uuid:
    related_type: 
      property_options:
        default: "contact"
    #Do not edit any address properties for logged in user.
    #use virtual property instead of original; sample: used address_1_ instead of address_1
    #The Add address modal form is responsible for adding new address.
    address_1_:
      property_options:
        virtual: true
    address_2_:
      property_options:
        virtual: true
    suburb_:
      property_options:
        virtual: true
    state_:
      property_options:
        virtual: true
    postcode_:
      property_options:
        virtual: true
    country_:     
      property_options:
        virtual: true
    shipping_same_with_account:
      property_options:
        virtual: true 
    shipping_instructions:
      property_options:
        virtual: true    
    shipping_company_name:
      property_options:
        virtual: true
    shipping_contact_first_name:
      property_options:
        virtual: true
    shipping_contact_last_name:
      property_options:
        virtual: true
    shipping_contact_email:
      property_options:
        virtual: true
    shipping_contact_phone_number:
      property_options:
        virtual: true
    shipping_contact_phone_country_code:
      property_options:
        virtual: true
    shipping_address_id:
      property_options:
        virtual: true        
    
callback_actions: |-    

  {%- session shipping_address_id = form.properties.shipping_address_id -%}
  {%- session latest_step = 3 -%}

---

{% assign prop = form.fields.properties %}

{%- form 
  html-id: "shipping-address-form"
  html-novalidate: true
  html-enctype="multipart/form-data"
  html-onsubmit:"return Checkout.events.shippingSubmit(event);" -%}  


    {% include 'modules/ecommerce/checkout/checkout_shipping_contacts', prop %}

    <div class="spacer large"></div>

    <div class="grid-x">        
      <h4>Shipping address</h4>
      <div class="cell show-for-small-only spacer"></div>
      {% comment %} Add new address {% endcomment %}
      <div class="text-right flex-child-grow"
        id="address-toggle">
        <ins-button 
          type="button" 
          id="add-address-btn"
          name="shipping-address-fields" 
          icon="icon-plus" 
          label="Add new address">
        </ins-button>
      </div> 
    </div>      

    <div class="spacer xx-small"></div>
      
    {% comment %} Selected address {% endcomment %}
    <ins-input validate
    id="shipping_address_id" 
    class="hidden-input"
    value="{{ context.session.shipping_address_id }}"
    name="{{ prop.shipping_address_id.name }}"
    error-message="Shipping address is required. Please select from the list below or add new address.">
    </ins-input> 
                
    {%- comment -%} Address cards {%- endcomment -%}
    {%- include 'modules/ecommerce/layout/address_cards', 
      addresses: addresses,
      selected_card: context.session.shipping_address_id | default: "",
      type: 'shipping' -%}
        

    {% comment %} Shipping Instructions; Buttons {% endcomment %}
    {% include 'modules/ecommerce/checkout/checkout_shipping_bottom_blocks' %}
         
{%- endform -%}

{% comment %} Add new address modal {% endcomment %}
{% comment %} Do not put this modal inside <form>, it has it's own validation. {% endcomment %}
{% include 'modules/ecommerce/checkout/add_address_modal', page: 'shipping' %}
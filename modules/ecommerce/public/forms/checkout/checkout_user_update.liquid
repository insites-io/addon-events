---
name: checkout_user_update
resource: User
resource_owner: anyone
redirect_to: checkout/shipping
flash_alert: Sorry-AddUser
flash_notice: Success-AddUser
fields:
  email:
    validation: 
      presence:
        message: Please use a valid email address
      email: 
        message: Please use a valid email address
  first_name:
    validation: 
      presence: 
        message: First name is required
  last_name:
    validation: 
      presence: 
        message: Last name is required
  
  company_name:
    property_options:
      virtual: true

  profiles:
    modules/insites_core/crm_contact:
      properties:
        mobile_phone_number:
        mobile_phone_country_code:

callback_actions: |- 
  {%- session contact_first_name = form.first_name -%}  
  {%- session contact_last_name = form.last_name -%}  
  {%- session contact_email = form.email -%}  
  {%- session contact_company_name = form.company_name -%}  
  {%- session contact_phone_number = form.profiles['modules/insites_core/crm_contact'].properties.mobile_phone_number | default: "" -%}
  {%- session contact_phone_country_code = form.profiles['modules/insites_core/crm_contact'].properties.mobile_phone_country_code | default: "" -%}

  {% unless context.current_user %}
    {%- parse_json guest_user -%}
    {
        "id": "{{ form.id }}",
        "uuid": "{{ context.session.guest_user.uuid }}",
        "email": "{{ form.email }}",
        "first_name": "{{ form.first_name }}",
        "last_name" : "{{ form.last_name }}"
    }
    {%- endparse_json -%}
    {%- session guest_user = guest_user -%}
  {% endunless %}

  {%- session latest_step = 2 -%}
---

{%- form 
  html-id: "checkout-account-detail" 
  html-novalidate: true 
  html-enctype="multipart/form-data" 
  html-onsubmit:"return Checkout.events.contactSubmit(event);" -%}

  {% include 'modules/ecommerce/checkout/checkout_contact_form' %}

{%- endform -%}
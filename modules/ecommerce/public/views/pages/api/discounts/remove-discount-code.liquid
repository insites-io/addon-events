
---
slug: api/remove-discount-code
format: json
method: post
searchable: false
metadata: {
    "status": "published",
    "page_type": "endpoint", 
    "page_name": "Remove Discount Code API",
    "page_title": "Remove Discount Code API",
    "meta_title": "Remove Discount Code API"      
}
---
{%- assign status = 200 -%}
{%- assign discount_uuid = context.params.uuid -%}
{%- assign user_uuid = context.current_user.external_id -%}


{%- if user_uuid and discount_uuid -%}
    {%- comment -%} Logged in user: Check if the code being removed belongs to the customer {%- endcomment -%}

    {%- graphql user_cart_discount = 'modules/ecommerce/carts/get_cart_discount',
            contact_uuid: user_uuid, discount_code_uuids: discount_uuid | dig: 'items' -%}

    {%- comment -%} Step 2: If it is valid, update user cart, remove the discount_code_uuid {%- endcomment -%}
    {%- if user_cart_discount.results.size > 0 -%}
        {%- include 'modules/ecommerce/discounts/update_discount', 
            user_uuid: user_uuid,
            type: 'remove',
            discount_uuid: discount_uuid -%}
    {%- endif -%}

    {%- parse_json data -%}
    {
        {{ context.exports.update_cart_discount }}
    }
    {%- endparse_json -%}

{%- elsif discount_uuid -%}
    {%- comment -%} Guest user {%- endcomment -%}
    

    {% comment %} Update session discount_uuids {% endcomment %}
    {%- assign local_discount_uuids = context.session.discount_uuids | default: '[]' | parse_json -%}
    {% log local_discount_uuids, type: "==TEST api-remove local_discount_uuids" %}

    {%- assign filtered_uuids = local_discount_uuids | array_delete: discount_uuid -%}
    {% log filtered_uuids, type: "==TEST api-remove filtered_uuids" %}

    {% session discount_uuids = filtered_uuids %}
    {% log context.session.discount_uuids, type: "==TEST api-remove session.discount_uuids" %}

    {%- parse_json data -%}
    {
        "type": "localStorage",
        "discount_uuid": "{{ discount_uuid }}"        
    }
    {%- endparse_json -%}
{%- endif -%}


{%- comment -%}Status code 400: API or GraphQL error{%- endcomment -%}
{%- if data == blank -%}
  {%- assign status = 400 -%}
{%- endif -%}

{{- data -}}
{%- response_status status -%}
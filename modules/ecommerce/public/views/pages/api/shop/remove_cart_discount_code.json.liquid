
---
slug: api/remove-discount-code
format: json
method: post
searchable: false
metadata: {
    "status": "published",
    "page_type": "endpoint", 
    "page_name": "Remove Discount Code API",
    "page_title": "Remove Discount Code API",
    "meta_title": "Remove Discount Code API"      
}
---
{%- assign discount_uuid = context.params.uuid -%}
{%- assign status = 200 -%}


{% comment %} Get the user uuid {% endcomment %}
{%  liquid
    if context.session.user_uuid and context.session.user_uuid != ''
        assign user_uuid = context.session.user_uuid
    else
        graphql user = 'modules/client/account/get_current_user'
        session user_uuid = user.current_user.external_id
        assign user_uuid = user.current_user.external_id
    endif
%}

{% comment %} Step 1: Check if code is being removed belongs to the customer {% endcomment %}
{%- if user_uuid != '' and discount_uuid != '' -%}
    {% graphql user_cart_discount = 'modules/ecommerce/carts/get_cart_discount',
            contact_uuid: user_uuid, discount_code_uuids: discount_uuid | dig: 'items' %}
{% else %}
    {% comment %} check cart local storage {% endcomment %}
{% endif %}


{% comment %} Step 2: If it is valid, update user cart, remove the discount_code_uuid {% endcomment %}
{%- if user_cart_discount.results.size > 0 -%}
    {% include 'modules/ecommerce/discounts/update_discount', 
        user_uuid: user_uuid,
        type: 'remove',
        discount_uuid: discount_uuid %}
{%- endif -%}

{% parse_json data %}
    {{ context.exports.update_cart_discount | fetch: "items" }}
{% endparse_json %}

{%- comment -%}Status code 400: API or GraphQL error{%- endcomment -%}
{%- if data == blank %}
  {%- assign status = 400 -%}
{%- endif -%}

{%- response_status status -%}
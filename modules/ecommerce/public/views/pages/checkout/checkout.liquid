---
slug: checkout
layout: modules/ecommerce/checkout-layout
searchable: "true"
max_deep_level: 3
metadata: {
    "status": "published",
    "page_type": "content", 
    "page_name": "Checkout",
    "page_title": "Checkout",
    "meta_title": "Checkout"       
}
---
{%- include "modules/insites_cms/globals" -%}
{%- assign global = context.exports.global -%}
{% function has_profile = "modules/website/layout/check_if_user_has_profile" %}

{%- if has_profile -%}
    {%- include 'modules/ecommerce/checkout/checkout_account_info_page' -%}
{%- elsif context.params.guest -%}
    {%- session latest_step = 2 -%}
    {% redirect_to '/checkout/shipping' %}
{%- else -%}
    {%- include 'modules/ecommerce/checkout/landing_page' -%}
{%- endif -%}

{%- if context.environment == "staging" -%}
    <script src="{{ 'modules/portal/scripts/login-scripts.js' | asset_url }}"></script>
{%- else -%}
    <script src="{{ 'modules/portal/scripts/login-scripts.min.js' | asset_url }}"></script>
{%- endif -%}
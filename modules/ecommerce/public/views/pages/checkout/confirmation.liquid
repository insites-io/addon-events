---
slug: confirmation
layout: modules/ecommerce/checkout-layout
searchable: false
max_deep_level: 2
metadata: {
    "status": "published",
    "page_type": "content", 
    "page_name": "Checkout - Order Successful",
    "page_title": "Checkout - Order Successful",
    "meta_title": "Checkout - Order Successful"       
}
authorization_policies:
    - modules/ecommerce/order_created_date_valid
---
{% assign order_uuid = context.params.id %}
{% if order_uuid != blank %}
    {% graphql order = "modules/ecommerce/orders/get_order_details", 
        uuid: order_uuid, is_shipping_info_needed: true | dig: 'items' | dig: 'results' | first %}
{% endif %}

{% liquid


    # Fetch current user data
    function has_profile = "modules/website/layout/check_if_user_has_profile"

    include 'modules/ecommerce/checkout/clear_session'
    include 'modules/ecommerce/checkout/clear_local_storage'


%}


{%- if order -%}

    <div class="grid-x grid-padding-x">
        <div class="large-12 medium-12 small-12 cell text-center">
            <h1 class="heading-1">We've received your order</h1>
            <div class="spacer small"></div> 
            <p class="body-large">Your order has been received with order number <strong>{{ order.id }}-{{ order.order_reference }}</strong></p>
        </div>
    </div>
    <div class="spacer xxxx-large"></div>

    <div class="grid-x grid-padding-x confirmation__wrapper">
        <div class="large-7 medium-6 small-12 cell">
            <h4>Order details</h4>
            <div class="spacer x-large"></div>
       
            <div class="grid-x grid-padding-x">
                
                
                <div class="large-5 medium-12 small-12 cell">
                    <div class="grid-y">
                        {% comment %} Contact details {% endcomment %}
                        <div class="wrap">
                            <h5 class="heading-5-small">Contact details</h5>
                            <div class="spacer small"></div>
                            <p class="font-cabin">{{ order.order_company_name }}</p>
                            <p class="font-cabin">{{ order.order_contact_first_name }} {{ order.order_contact_last_name }}</p>
                            <p class="font-cabin">{{ order.order_contact_email  }}</p>
                            <p class="font-cabin">
                                {% if order.order_contact_phone_country_code %}({{ order.order_contact_phone_country_code }}){% endif %} 
                                {{ order.order_contact_phone_number }}
                            </p>                            
                        </div>

                        <div class="spacer x-large"></div>

                        {% comment %} Shipping details {% endcomment %}
                        <div class="wrap">
                            <h5 class="heading-5-small">Shipping details</h5>
                            <div class="spacer small"></div>
                            <p class="font-cabin">{{ order.shipping_company_name }}</p>
                            <p class="font-cabin">{{ order.shipping_contact_first_name }} {{ order.shipping_contact_last_name }}</p>
                            <p class="font-cabin">{{ order.shipping_contact_email  }}</p>
                            <p class="font-cabin">
                                {% if order.shipping_contact_phone_country_code %}({{ order.shipping_contact_phone_country_code }}){% endif %} 
                                {{ order.shipping_contact_phone_number }}
                            </p>
                            {%   liquid
                                assign shipping_address = '' | split: ','
                                assign shipping_address = shipping_address | array_add: order.shipping_address_1
                                assign shipping_address = shipping_address | array_add: order.shipping_address_2
                                assign shipping_address = shipping_address | array_add: order.shipping_address_3
                                assign shipping_address = shipping_address | array_add: order.billing_suburb
                                assign shipping_address = shipping_address | array_add: order.billing_state
                                assign shipping_address = shipping_address | array_add: order.billing_postcode 
                                assign shipping_address = shipping_address | array_add: order.billing_country | array_compact
                                assign shipping_address = shipping_address | join: ', ' | replace: ' ,', ','
                            %}  
                            <p>{{ shipping_address }}</p>
                        </div>

                        <div class="spacer x-large"></div>

                        {% comment %} Shipping instructions {% endcomment %}
                        <div class="wrap">
                            <h5 class="heading-5-small">Shipping instructions</h5>
                            <div class="spacer small"></div>
                            <p class="font-cabin">{{ order.shipping_instructions }}</p>
                        </div>
                        
                    </div>
                </div>                                    
                               
                <div class="large-offset-1 large-5 medium-12 small-12 cell">
                    <div class="grid-y">

                        {% comment %} Billing Details {% endcomment %} 
                        <div class="wrap">
                            <h5 class="heading-5-small">Billing details</h5>                    
                            <div class="spacer small"></div>
                            <p class="font-cabin">{{ order.billing_company_name }}</p>
                            <p class="font-cabin">{{ order.billing_contact_first_name }} {{ order.billing_contact_last_name }}</p>
                            <p class="font-cabin">{{ order.billing_contact_email  }}</p>
                            <p class="font-cabin">
                                {% if order.billing_contact_phone_country_code %}({{ order.billing_contact_phone_country_code }}){% endif %} 
                                {{ order.billing_contact_phone_number }}
                            </p>
                            {%   liquid
                                assign billing_address = '' | split: ','
                                assign billing_address = billing_address | array_add: order.billing_address_1
                                assign billing_address = billing_address | array_add: order.billing_address_2
                                assign billing_address = billing_address | array_add: order.billing_address_3
                                assign billing_address = billing_address | array_add: order.billing_suburb
                                assign billing_address = billing_address | array_add: order.billing_state
                                assign billing_address = billing_address | array_add: order.billing_postcode 
                                assign billing_address = billing_address | array_add: order.billing_country | array_compact
                                assign billing_address = billing_address | join: ', ' | replace: ' ,', ','
                            %}
                            <p>{{ billing_address }}</p>
                        </div>

                        <div class="spacer x-large"></div>

                        {% comment %} Payment details {% endcomment %} 
                        <div class="wrap">
                            <h5 class="heading-5-small">Payment details</h5>                    
                            <div class="spacer small"></div>
                            <p class="font-cabin">{{ order.payment.card_brand | upcase }} **** **** **** {{ order.payment.card_last_four_digits }}</p>
                            {%- assign month = order.payment.card_expiry_month -%}
                            {%- if order.payment.card_expiry_month.size < 2 -%}
                                {%- assign month = "0" | append: order.payment.card_expiry_month -%}
                            {%- endif -%}
                            <p class="font-cabin">{{ month }} / {{ order.payment.card_expiry_year }}</p>
                        </div>

                    </div>
                </div>

                


                                              

            </div>
        </div>
        <div class="large-4 large-offset-1 medium-6 small-12 cell">        
            {% include 'modules/ecommerce/layout/order_summary', 
                show_product: true, is_ordered_items: true,
                order_uuid: context.params.id %}
        </div>
    </div>

    {% include 'modules/ecommerce/checkout/clear_session' %}
    
{%- else -%}
    {% include 'modules/ecommerce/checkout/clear_session' %}
    {%- redirect_to '/shopping-cart' -%}
{%- endif -%}
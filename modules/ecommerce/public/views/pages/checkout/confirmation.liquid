---
slug: confirmation
layout: modules/ecommerce/checkout
# enable_profiler: true
searchable: "true"
max_deep_level: 3
metadata: {
    "status": "published",
    "page_type": "content", ## content, system or endpoint
    "page_name": "Checkout - Order Successful",
    "og:url": "{{ context.exports.global.company_url | strip }}",
    "og:type": "",
    "og:image": "",
    "og:title": "Checkout - Order Successful",
    "og:description": "Checkout - Order Successful",
    "og:site_name": "{{ context.exports.global.company_name | strip }}",
    "meta_title": "Checkout - Order Successful",
    "page_title": "Checkout - Order Successful | {{ context.exports.global.company_name | strip }}",
    "description": "Checkout - Order Successful",
    "canonical_url": "",
    "search_engine_visibility": false,
    "sitemap_enabled": false,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "0", ## secondary order (ASC)
    "sitemap_changefreq": "never"
}
authorization_policies:
    - modules/ecommerce/order_created_date_valid 
#    - modules/ecommerce/customer_logged_in  ## commented out to allow 'guest customer' to view order confirmation
---

{% graphql order = "modules/ecommerce/orders/get_order_details", uuid: context.params.order_uuid, is_more: true | dig: 'items' | dig: 'results' | first %}

{%- if context.current_user.id == order.user_id -%}

    <div class="grid-x grid-padding-x">
        <div class="large-offset-2 medium-offset-1 small-offset-0 large-8 medium-10 small-12 cell">
            {% include 'modules/ecommerce/layout/checkout_steps' %}
        </div>
    </div>

    <div class="spacer xxx-large"></div>
    <div class="grid-x grid-padding-x">
        <div class="large-12 medium-12 small-12 cell text-center">
            <h1 class="heading-1">We've received your order</h1>
            <div class="spacer small"></div> 
            <p>Your order has been received with order number <strong>{{ order.id }}-{{ order.order_reference }}</strong></p>
        </div>
    </div>
    <div class="spacer xxxx-large"></div>

    <div class="grid-x grid-padding-x confirmation__wrapper">
        <div class="large-7 medium-6 small-12 cell">
            <h2 class="heading-2">Order Details</h2>
            <div class="spacer xx-large"></div>

            {%- comment -%} Contact & Payment Details {%- endcomment -%}
            <div class="grid-x grid-padding-x">
                <div class="large-5 medium-5 small-12 cell">
                    <h3 class="heading-3">Order Contact</h3>
                    <div class="spacer small"></div>
                    {%- if order.billing_company_name -%}
                    <p class="font-cabin">{{ order.billing_company_name }}</p>
                    {%- endif -%}
                    <p class="font-cabin">{{ order.billing_contact_first_name | append: ' ' | append: order.billing_contact_last_name }}</p>
                    <p class="font-cabin">{{ order.billing_contact_email }}</p>
                    <p class="font-cabin">{{ order.billing_contact_phone_country_code }} {{ order.billing_contact_phone_number }}</p>
                    <div class="spacer xx-large"></div>
                </div>

                {%- if context.current_user.id -%}
                <div class="large-5 large-offset-1 medium-5 medium-offset-1 small-12 cell">
                    <h3 class="heading-3">Payment Details</h3>
                    <div class="spacer small"></div>
                    <p class="font-cabin">{{ order.payment.card_brand | upcase }} **** **** **** {{ order.payment.card_last_four_digits }}</p>
                    {%- assign month = order.payment.card_expiry_month -%}
                    {%- if order.payment.card_expiry_month.size < 2 -%}
                        {%- assign month = "0" | append: order.payment.card_expiry_month -%}
                    {%- endif -%}
                    <p class="font-cabin">{{ month }} / {{ order.payment.card_expiry_year }}</p>
                    <div class="spacer xx-large"></div>

                </div>
                {%- endif -%}

                {%- comment -%} Addresses Details {%- endcomment -%}
                <div class="large-5 medium-5 {% unless context.current_user.id %} large-offset-1 medium-offset-1 {% endunless %} small-12 cell">
                    <h3 class="heading-3">Shipping Details</h3>
                    <div class="spacer small"></div>
                        {%- assign shipping_address = "" -%}
                        {%- if order.shipping_address_1 and order.shipping_address_1 != '' -%}
                            {%- assign shipping_address = shipping_address | append: order.shipping_address_1 | append : ", " -%}
                        {%- endif -%}
                        {%- if order.shipping_address_2 and order.shipping_address_2 != '' -%}
                            {%- assign shipping_address = shipping_address | append: order.shipping_address_2 | append : ", " -%}
                        {%- endif -%}
                        {%- if order.shipping_address_3 and order.shipping_address_3 != '' -%}
                            {%- assign shipping_address = shipping_address | append: order.shipping_address_3 | append : ", " -%}
                        {%- endif -%}
                        {%- if order.shipping_city and order.shipping_city != '' -%}
                            {%- assign shipping_address = shipping_address | append: order.shipping_city | append : ", " -%}
                        {%- endif -%}
                        {%- if order.shipping_state and order.shipping_state != '' -%}
                            {%- assign shipping_address = shipping_address | append: order.shipping_state | append : " " -%}
                        {%- endif -%}
                        {%- if order.shipping_postcode and order.shipping_postcode != '' -%}
                            {%- assign shipping_address = shipping_address | append: order.shipping_postcode | append : ", " -%}
                        {%- endif -%}
                        {%- if order.shipping_country and order.shipping_country != '' -%}
                            {%- assign shipping_address = shipping_address | append: order.shipping_country | append : " " -%}
                        {%- endif -%}
                    {%- if order.shipping_company_name -%}
                    <p class="font-cabin">{{ order.shipping_company_name }}</p>
                    {%- endif -%}
                    <p class="font-cabin">{{ order.shipping_contact_first_name | append: ' ' | append: order.shipping_contact_last_name }}</p>
                    <p class="font-cabin">{{ order.shipping_contact_email }}</p>
                    <p class="font-cabin">{{ order.shipping_contact_phone_country_code }} {{ order.shipping_contact_phone_number }}</p>
                    <p class="font-cabin">{{ shipping_address }}</p>
                    <div class="spacer xx-large"></div>
                </div>
                <div class="large-5 medium-5 {% if context.current_user.id %} large-offset-1 medium-offset-1 {% endif %} small-12 cell">
                    <h3 class="heading-3">Billing Address</h3>
                    <div class="spacer small"></div>
                    {%- assign billing_address = "" -%}
                        {%- if order.billing_address_1 and order.billing_address_1 != '' -%}
                            {%- assign billing_address = billing_address | append: order.billing_address_1 | append : ", " -%}
                        {%- endif -%}
                        {%- if order.billing_address_2 and order.billing_address_2 != '' -%}
                            {%- assign billing_address = billing_address | append: order.billing_address_2 | append : ", " -%}
                        {%- endif -%}
                        {%- if order.billing_address_3 and order.billing_address_3 != '' -%}
                            {%- assign billing_address = billing_address | append: order.billing_address_3 | append : ", " -%}
                        {%- endif -%}
                        {%- if order.billing_city and order.billing_city != '' -%}
                            {%- assign billing_address = billing_address | append: order.billing_city | append : ", " -%}
                        {%- endif -%}
                        {%- if order.billing_state and order.billing_state != '' -%}
                            {%- assign billing_address = billing_address | append: order.billing_state | append : " " -%}
                        {%- endif -%}
                        {%- if order.billing_postcode and order.billing_postcode != '' -%}
                            {%- assign billing_address = billing_address | append: order.billing_postcode | append : ", " -%}
                        {%- endif -%}
                        {%- if order.billing_country and order.billing_country != '' -%}
                            {%- assign billing_address = billing_address | append: order.billing_country | append : " " -%}
                        {%- endif -%}
                    <p class="font-cabin">{{ billing_address }}</p>
                </div>
            </div>
        </div>
        <div class="large-4 large-offset-1 medium-6 small-12 cell">        
            {%- comment -%}Payment Details: Customer is logged in{%- endcomment -%}
            {%- if context.current_user.id -%}
                {% include 'modules/ecommerce/layout/order_summary', 
                    show_product: true,
                    order_uuid: context.params.order_uuid %}
            {%- endif -%}
        </div>
    </div>

    {% include 'modules/ecommerce/checkout/clear_session' %}

{%- else -%}
    {% include 'modules/ecommerce/checkout/clear_session' %}
    {%- redirect_to '/shopping-cart' -%}
{%- endif -%}
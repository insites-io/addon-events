---
slug: api/save-checkout-session
format: json
method: post
searchable: false
metadata:
  status: "published"
  page_type: "endpoint"
  og:url: ""
  og:type: ""
  og:image: ""
  og:title: "Save checkout session API"
  og:description: "Save checkout session API"
  og:site_name: ""
  meta_title: "Save checkout session API"
  page_title: "Save checkout session API"
  meta_description: "Save checkout session API"
  canonical_url: ""
  search_engine_visibility: false
  sitemap_enabled: false
  sitemap_priority: "1.0"
  sitemap_order: "9999"
  sitemap_changefreq: "never"
---

{% liquid
    assign response = "{}" | parse_json
    assign address_id = context.params.address_id | default: null
    assign user_uuid = context.current_user.external_id
    assign guest_user = context.params.guest_user

    if guest_user and guest_user == true
        # Assign address-related session variables for guest
        if context.params.billing_address_1
            session billing_address_1 = context.params.billing_address_1
        endif
        if context.params.billing_address_2
            session billing_address_2 = context.params.billing_address_2
        endif
        if context.params.billing_suburb
            session billing_suburb = context.params.billing_suburb
        endif
        if context.params.billing_state
            session billing_state = context.params.billing_state
        endif
        if context.params.billing_postcode
            session billing_postcode = context.params.billing_postcode
        endif
        if context.params.billing_country
            session billing_country = context.params.billing_country
        endif

        if context.params.shipping_address_1
            session shipping_address_1 = context.params.shipping_address_1
        endif
        if context.params.shipping_address_2
            session shipping_address_2 = context.params.shipping_address_2
        endif
        if context.params.shipping_suburb
            session shipping_suburb = context.params.shipping_suburb
        endif
        if context.params.shipping_state
            session shipping_state = context.params.shipping_state
        endif
        if context.params.shipping_postcode
            session shipping_postcode = context.params.shipping_postcode
        endif
        if context.params.shipping_country
            session shipping_country = context.params.shipping_country
        endif

        # Assign order-summary-related session variables for guest
        assign guest_order_summary = '{}' | parse_json 

        if context.params.sub_total_amount
            assign guest_order_summary = guest_order_summary | add_hash_key: "sub_total_amount", context.params.sub_total_amount
        endif
        if context.params.shipping_amount
            assign guest_order_summary = guest_order_summary | add_hash_key: "shipping_amount", context.params.shipping_amount
        endif
        if context.params.total_discount_amount
            assign guest_order_summary = guest_order_summary | add_hash_key: "total_discount_amount", context.params.total_discount_amount
        endif
        if context.params.processing_fee
            assign guest_order_summary = guest_order_summary | add_hash_key: "processing_fee", context.params.processing_fee
        endif
        if context.params.tax_label
            assign guest_order_summary = guest_order_summary | add_hash_key: "tax_label", context.params.tax_label
        endif
        if context.params.tax_amount
            assign guest_order_summary = guest_order_summary | add_hash_key: "tax_amount", context.params.tax_amount
        endif
        if context.params.tax_included_in_price
            assign guest_order_summary = guest_order_summary | add_hash_key: "tax_included_in_price", context.params.tax_included_in_price
        endif
        if context.params.total_amount
            assign guest_order_summary = guest_order_summary | add_hash_key: "total_amount", context.params.total_amount
        endif

        # Only store in session if guest_order_summary is not still the initial empty object
        if guest_order_summary != '{}' 
            session guest_order_summary = guest_order_summary
        endif

        # Assign order-cart-related session variables for guest
        if context.params.cart
            session guest_cart = context.params.cart
        endif
        if context.params.products
          session guest_products = context.params.products
        endif 
    else
        if address_id != null and user_uuid
            graphql addresses = 'modules/ecommerce/address/get_address', user_uuid: user_uuid id: address_id | dig: 'items', 'results'

            if addresses.size > 0
                assign address = addresses | first

                if context.params.billing_same_with_shipping
                    session billing_address_1 = address.address_1
                    session billing_address_2 = address.address_2
                    session billing_suburb = address.suburb
                    session billing_state = address.state
                    session billing_postcode = address.postcode
                    session billing_country = address.country
                    session billing_address_id = address_id
                else
                    session shipping_address_1 = address.address_1
                    session shipping_address_2 = address.address_2
                    session shipping_suburb = address.suburb
                    session shipping_state = address.state
                    session shipping_postcode = address.postcode
                    session shipping_country = address.country
                    session shipping_address_id = address_id
                endif
            endif
        endif
    endif

    # Assign shipping-related session variables if provided
    if context.params.same_shipping
        session same_shipping = context.params.same_shipping
    endif
    if context.params.shipping_instructions
        session shipping_instructions = context.params.shipping_instructions
    endif
    if context.params.shipping_company_name
        session shipping_company_name = context.params.shipping_company_name
    endif
    if context.params.shipping_contact_first_name
        session shipping_contact_first_name = context.params.shipping_contact_first_name
    endif
    if context.params.shipping_contact_last_name
        session shipping_contact_last_name = context.params.shipping_contact_last_name
    endif
    if context.params.shipping_contact_email
        session shipping_contact_email = context.params.shipping_contact_email
    endif
    if context.params.shipping_contact_phone_number
        session shipping_contact_phone_number = context.params.shipping_contact_phone_number
    endif
    if context.params.shipping_contact_phone_country_code
        session shipping_contact_phone_country_code = context.params.shipping_contact_phone_country_code
    endif

    # Assign billing-related session variables if provided
    if context.params.billing_same_with_shipping
        session billing_same_with_shipping = context.params.billing_same_with_shipping
    endif
    if context.params.billing_company_name
        session billing_company_name = context.params.billing_company_name
    endif
    if context.params.billing_contact_first_name
        session billing_contact_first_name = context.params.billing_contact_first_name
    endif
    if context.params.billing_contact_last_name
        session billing_contact_last_name = context.params.billing_contact_last_name
    endif
    if context.params.billing_contact_email
        session billing_contact_email = context.params.billing_contact_email
    endif
    if context.params.billing_contact_phone_number
        session billing_contact_phone_number = context.params.billing_contact_phone_number
    endif
    if context.params.billing_contact_phone_country_code
        session billing_contact_phone_country_code = context.params.billing_contact_phone_country_code
    endif

    # Assign the latest step if present
    if context.params.latest_step
        session latest_step = context.params.latest_step
    endif

    # Add response status
    assign response = response | add_hash_key: 'status', 200
    assign response = response | add_hash_key: 'data', context.session

%}

{{ response }}

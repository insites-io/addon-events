<section class="bg-color-ui-01">
    <div class="spacer xxxx-large"></div>
    <div class="product-carousel">

        {% graphql products = "modules/ecommerce/products/get_products", not_uuid: not_uuid | dig: 'items','results' %}        

        <!-- desktop carousel -->
        <ins-carousel 
            class="show-for-large"
            layout="1"
            per-page="4"
            no-pagination=true
            no-carousel-button=true
            bind-to="newArrivalCardsDesktop">

            <h3>You may also like</h3>     
            <div class="spacer xx-large"></div>
            <div id="newArrivalCardsDesktop" class="product-cards">
                {% for product in products %}
                    {% include "modules/ecommerce/products/product_card", product: product %}
                {% endfor %}
            </div>
        </ins-carousel>
        <!-- desktop carousel -->

        <!-- tablet carousel -->
        <ins-carousel 
            class="show-for-medium-only"
            layout="1"
            per-page="3"
            no-pagination=true
            no-carousel-button=true
            bind-to="newArrivalCardsTablet">

            <h3>You may also like</h3>
            <div class="spacer xx-large"></div>
            <div id="newArrivalCardsTablet" class="product-cards">
                {% for product in products %}
                    {% include "modules/ecommerce/products/product_card", product: product %}
                {% endfor %}
            </div>
        </ins-carousel>
        <!-- tablet carousel -->

        <!-- mobile carousel -->
        <ins-carousel 
            class="show-for-small-only"
            layout="1"
            per-page="1"
            no-pagination=true
            no-carousel-button=true
            bind-to="newArrivalCardsMobile">

            <h3>You may also like</h3>  
            <div class="spacer xx-large"></div>
            <div id="newArrivalCardsMobile" class="product-cards">
                {% for product in products %}
                    {% include "modules/ecommerce/products/product_card", product: product %}
                {% endfor %}
            </div>
        </ins-carousel>
        <!-- mobile carousel -->

    </div>
</section>
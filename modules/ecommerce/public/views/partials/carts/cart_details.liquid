{% liquid 
    assign product = products | array_detect: uuid: item.product_uuid 
    assign product_name = product.product_name    
    assign is_tax_included = product.is_tax_included       

    ## to fix issues in comparing '' versus null
    if product.product_sku == null 
        assign product = product | add_hash_key: 'product_sku', ''
    endif
    
    ## Check if the item is a product or a variant of the product
    assign selected_prop = ''
    if item.product_sku == product.product_sku
        ## item is NOT a variant
        assign selected_prop = product
        assign is_variant = false
    else 
        ## item is a variant                
        for variant in product.variants
            if item.product_sku == variant.product_sku
                assign selected_prop = variant
                assign is_variant = true
            endif
        endfor
    endif       
%}      

{% comment %} product_sku has changed, Remove this item in the cart {% endcomment %}
{% if selected_prop == '' %}            
    {% parse_json params %}
    {
        "product_uuid": "{{ item.product_uuid }}",
        "product_sku": "{{ item.product_sku }}",
        "contact_uuid": "{{ user_uuid }}"
    }
    {% endparse_json %}
    {% include 'modules/ecommerce/carts/remove_to_cart', params %} 

    {% comment %} Skip the current iteration of the loop {% endcomment %}
    {% continue %}
{% endif %}  

{% comment %} Prices {% endcomment %}
{%  liquid
    if selected_prop.is_on_sale == true 
        assign price = selected_prop.sale_price
        assign price_strikethrough = selected_prop.regular_price
    else 
        assign price = selected_prop.regular_price
        assign price_strikethrough = ''
    endif          

    
    assign item_total_price = price | times: item.quantity
%}      

{% parse_json cart %}
{
    "product_name": "{{ product_name }}",
    "is_variant": {{ is_variant | default: false }},
    "selected_prop": {{ selected_prop | default: '[]' }},
    "price": {{ price | default: 0 }},
    "price_strikethrough": "{{ price_strikethrough }}",
    "is_tax_included": {{ is_tax_included | default: false }},
    "item_total_price": {{ item_total_price | default: 0 }}
}
{% endparse_json %}

{% export cart %}
{% comment %} Get the user uuid {% endcomment %}
{%  liquid
    if context.session.user_uuid and context.session.user_uuid != ''
        assign user_uuid = context.session.user_uuid
    else
        graphql user = 'modules/client/account/get_current_user'
        session user_uuid = user.current_user.external_id
        assign user_uuid = user.current_user.external_id
    endif
%}


{% comment %} Get the user's cart(s) {% endcomment %}
{% if user_uuid != '' %}
    {% graphql user_cart = 'modules/ecommerce/carts/get_user_cart', 
        contact_uuid: user_uuid | dig: 'items','results' | first %}
{% endif %}


{% if user_cart.items.size > 0 %}

    {% comment %} Get the product info {% endcomment %}
    {%  liquid

        ## Convert an array of strings into an array of objects
        assign item_obj = '' | split: ',' 
        for item in user_cart.items
            assign item_json = item | parse_json
            assign item_obj = item_obj | array_add: item_json
        endfor

        assign product_uuids = item_obj | array_map: 'product_uuid' | array_flatten
        graphql products = 'modules/ecommerce/products/get_cart_products', uuid: product_uuids, size: user_cart.items.size | dig: 'items','results'
    %}

{% endif %}


<ins-drawer 
  label="Cart ({{ user_cart.items.size }})" 
  custom-width="390px" 
  position="right" 
  id="cartDrawer"
  class="cart-drawer">

    <div id="cart-items-wrap">

    {% if user_cart.items.size > 0 %}
    
        {% assign subtotal = 0 %}

        {% for item in item_obj %}

        {% liquid 
            assign product = products | array_detect: uuid: item.product_uuid
            assign product_name = product.product_name

            ## to fix issues in comparing '' versus null
            if product.product_sku == null 
                assign product = product | add_hash_key: 'product_sku', ''
            endif
            
            ## Check if the item is a product or a variant of the product
            if item.product_sku == product.product_sku
                ## item is NOT a variant
                assign selected_prop = product
            else 
                ## item is a variant                
                for variant in product.variants
                    if item.product_sku == variant.product_sku
                        assign selected_prop = variant
                    endif
                endfor
            endif             

            if selected_prop.is_on_sale == true 
                assign price = selected_prop.sale_price
                assign price_strikethrough = selected_prop.regular_price
            else 
                assign price = selected_prop.regular_price
                assign price_strikethrough = ''
            endif          

            assign product_id = selected_prop.id
            assign item_total = price | times: item.quantity
            assign subtotal = subtotal | plus: item_total
        %}

        <div id="cart-item-{{product_id}}" class="cart-item-wrap">
            <div class="grid-x" >
                <div class="cell grid-y large-7 medium-7 small-7">
                    <h6>{{ product_name }}</h6>
                    <p class="body-x-small">SKU {{ item.product_sku }}</p>
                    <div class="spacer x-small"></div>
                    {% comment %} Get variant info {% endcomment %}
                    {% if item.product_sku != product.product_sku %}
                        {%  liquid 
                            ## Convert an array of strings into an array of objects
                            assign options = '' | split: ',' 
                            for option in selected_prop.product_options
                                assign option_json = option | parse_json
                                assign options = options | array_add: option_json
                            endfor
                        %}
                        {% for option in options %}
                            <p>
                                <span class="body-x-small-bold">{{ option.product_option_label | titleize }}:</span>
                                <span class="body-x-small">{{ option.product_option_value | titleize }}</span>
                            </p>
                        {% endfor %}
                    {% endif %}
                    <p>
                        <span class="body-x-small-bold">Price:</span>
                        <span class="body-x-small item-price">{{ price | pricify }}</span>
                        {% if selected_prop.is_on_sale == true %}
                        <span class="body-x-small strikethrough">{{ price_strikethrough | pricify }}</span>
                        {% endif %}
                    </p>
                </div>
                <div class="cell grid-y large-5 medium-5 small-5 text-right">
                    <p class="cart-price compute-price">{{ item_total | pricify }}</p>
                    <div class="spacer x-small"></div>
                    <ins-input-stepper
                        class="cart-stepper" 
                        data-product_uuid="{{ item.product_uuid }}"
                        data-product_sku="{{ item.product_sku }}"
                        value="{{ item.quantity }}" 
                        step="1" min="1" 
                        max="{{ selected_prop.stock_level  }}" 
                        small>
                    </ins-input-stepper>
                    <div class="spacer small"></div>
                    <div class="text-right" >
                        {% parse_json remove_item %}
                        {
                            "product_uuid": "{{ item.product_uuid }}",
                            "product_sku": "{{ item.product_sku }}"
                        }
                        {% endparse_json %}
                        <ins-button label="Remove" icon="icon-trash-2" size="small" class="cart-remove-btn" data='{{ remove_item }}' ></ins-button>
                    </div> 
                </div>        
            </div>               
            <div class="spacer x-large"></div>
        </div>
        {% endfor %}    

    {% endif %}

    </div>

    <div id="empty-cart-wrap" class="hide">
        <h3 class="text-center">Your cart is empty!</h3>
        <div class="spacer x-small"></div>
        <p class="text-center">Don't miss out on the best deals!</p>
    </div>

    <div id="bottom-wrap">
        <div class="spacer"></div>
        <div class="grid-x align-justify" >
            <p class="heading-3-small font-color-head">Sub Total</p>
            <p id="cart-subtotal" class="heading-3-small font-color-head">{{ subtotal | pricify }}</p>
        </div>
        <div class="spacer"></div>
        <a href="/shopping-cart"><ins-button label="Go to Cart" icon="icon-shopping-cart" solid class="full"></ins-button></a>
        <div class="spacer x-small"></div>
        <ins-button label="Continue Shopping" icon="icon-arrow-back" id="continue-shopping-btn" class="full"></ins-button>
        <div class="spacer"></div>
        <p class="body-small text-center">Shipping calculated at checkout</p>
    </div>    

</ins-drawer>




<script>
    let page = "{{ context.params.slug }}";
    let user_uuid = "{{ user_uuid }}";
    let cartDrawer = document.getElementById('cartDrawer');
    let cartItemsWrap = document.getElementById('cart-items-wrap');
    let emptyCartWrap = document.getElementById('empty-cart-wrap');
    let bottomWrap = document.getElementById('bottom-wrap');
    let cartSubtotal = document.getElementById('cart-subtotal');
    let cartQuantity = 1;

    //product detailed page          
    let variantID = 0;
    let variantPrice = 0;
    let productSKU = document.getElementById("product-sku");
    let cartQuantityInput = document.getElementById('cart-quantity');  
    if(cartQuantityInput){  
        cartQuantityInput.addEventListener('insValueChange', event => {
            cartQuantity = event.detail; 
        });
    }
        

    /* Add to Cart */
    let addToCartBtn = document.querySelectorAll(".add-to-cart-btn");
    addToCartBtn.forEach(btn => {
        btn.addEventListener('insClick', event => {  
            //show cart drawer
            if(event.detail.label == "Add to Cart"){
                cartDrawer.setDrawerState(true); 
            } 

            let data = JSON.parse(event.detail.data);      
                data.quantity = cartQuantity; 
            
            //used for product with variants in product details page
            if(productSKU){
                data.id = variantID;
                data.price = variantPrice;
                data.product_sku = productSKU.textContent;
            }     

            let cartItem = document.getElementById(`cart-item-${data.id}`);

            if(cartItem == null){

                if(addToCart(data)){        

                    if (!emptyCartWrap.classList.contains('hide')) {
                        emptyCartWrap.classList.add('hide');
                        bottomWrap.classList.remove('hide');
                    }          
                                    
                    cartItemsWrap.insertAdjacentHTML('afterbegin', cartItemHtml(data));

                    let newItemAdded = document.getElementById(`cart-item-${data.id}`);
                    if (newItemAdded) {                   
                        let cartStepper = document.querySelector(`#cart-item-${data.id} .cart-stepper`);                        
                        cartStepperEventListener(cartStepper);

                        let removeCartBtn = document.querySelector(`#cart-item-${data.id} .cart-remove-btn`);
                        removeCartEventListener(removeCartBtn);
                    } 

                    computeSubTotal();
                }
            }

            if(event.detail.label != "Add to Cart"){
                window.location = "/shopping-cart";
            } 
        });
    });
    
    /* Increment / Decrement Cart in Drawer */
    let cartStepper = document.querySelectorAll(".cart-stepper");
    cartStepper.forEach(step => {
        cartStepperEventListener(step);
    }); 
    
    function cartStepperEventListener(step){
        step.addEventListener('insValueChange', event => {   
            let itemWrap = event.target.closest(".cart-item-wrap");            
            let stepperData = event.target.closest("ins-input-stepper").dataset;
            let data = {
                "product_uuid": stepperData.product_uuid,
                "product_sku": stepperData.product_sku,
                "quantity": event.detail
            };            
            computeItemTotal(itemWrap, event.detail);
            if(addToCart(data, 'stepper')){                
                computeSubTotal();
            }       
        });
    }    


    /* Remove from Cart */
    let removeCartBtn = document.querySelectorAll(".cart-remove-btn");
    removeCartBtn.forEach(btn => {
        removeCartEventListener(btn);
    });

    function removeCartEventListener(btn){
        btn.addEventListener('insClick', event => {
            if(removeToCart(JSON.parse(event.detail.data))){
                let cartItem = btn.closest('.cart-item-wrap');
                if (cartItem) {
                    cartItem.remove();
                    computeSubTotal();
                }
            }
        });
    }    

    /* Add cart to Database or to localStorage */
    async function addToCart(data, type){                  
        data["type"] = type;
        if(user_uuid != ""){
            data["contact_uuid"] = user_uuid;
            let response = await apiServices.processRequest("post", "/add-to-cart.json", data);
            console.log('add response', response);        
            if(response.state && response.data.items) {
                return true;          
            }
        } else {
            addCartToLocalStorage(data);            
        }
    }         

    /* Remove cart from Database or from localStorage */
    async function removeToCart(data){                                      
        if(user_uuid != ""){
            data["contact_uuid"] = user_uuid;
            let response = await apiServices.processRequest("post", "/remove-to-cart.json", data);             
            if(response.state && response.data.items) {
                if(page == 'shopping-cart') location.reload();
                return true;          
            }
        } else {
            removeCartFromLocalStorage(data);            
        }
    }       

    function cartItemHtml(data){
        return ` <div id="cart-item-${data.id}" class="cart-item-wrap">
                <div class="grid-x" >
                    <div class="cell grid-y large-7 medium-7 small-7">
                        <h6>${ data.product_name }</h6>
                        <p class="body-x-small">SKU ${ data.product_sku }</p>
                        <div class="spacer x-small"></div>
                        <p>
                            <span class="body-x-small-bold">Price:</span>
                            <span class="body-x-small item-price">$${ data.price }</span>
                        </p>
                    </div>
                    <div class="cell grid-y large-5 medium-5 small-5 text-right">
                        <p class="cart-price compute-price">$${ data.price }</p>
                        <div class="spacer x-small"></div>
                        <ins-input-stepper
                            class="cart-stepper" 
                            data-product_uuid="${ data.product_uuid }"
                            data-product_sku="${ data.product_sku }"
                            value="${ data.quantity }"
                            step="1" min="1" 
                            small>
                        </ins-input-stepper>
                    </div>        
                </div>
                <div class="text-right" >
                    <ins-button label="Remove" icon="icon-trash-2" size="small" class="cart-remove-btn" data='{"product_uuid":"${data.product_uuid}","product_sku":"${data.product_sku}"}' ></ins-button>
                </div>    
                <div class="spacer x-large"></div>
            </div>`;    
    }

    /* Guest user - Get cart from local storage */
    if(user_uuid == ""){
        let carts = getCartFromLocalStorage();

        if(carts.length > 0){
            carts.forEach(cart => {
                data = JSON.parse(cart);
                cartItemsWrap.insertAdjacentHTML('afterbegin', cartItemHtml(data));
                newItemAdded = document.getElementById(`cart-item-${data.id}`);
                if (newItemAdded) {                   
                    let cartStepper = document.querySelector(`#cart-item-${data.id} .cart-stepper`);                        
                    cartStepperEventListener(cartStepper);

                    let removeCartBtn = document.querySelector(`#cart-item-${data.id} .cart-remove-btn`);
                    removeCartEventListener(removeCartBtn);
                } 
            });

            computeSubTotal();                                        
        }
    }

    function getCartFromLocalStorage(){
        let carts = localStorage.getItem('carts');
        if (carts) {
            carts = JSON.parse(carts);
        }
        return carts;     
    }

    function addCartToLocalStorage(data){ 
        let carts = getCartFromLocalStorage();
        if(carts){
            /* Update Cart */
            let is_item_exist = false
            let item_exist_index = -1

            for (let i = 0; i < carts.length; i++) {    
                item = JSON.parse(carts[i]); //convert string to object
                if(item.product_uuid == data.product_uuid && item.product_sku == data.product_sku){
                    is_item_exist = true;
                    item_exist_index = i;                                        
                }
            }

            if(is_item_exist == true){                
                carts[item_exist_index] = JSON.stringify(data);
            } else {
                carts.push(JSON.stringify(data));
            }

        } else {
            /* Add Cart */
            carts = [(JSON.stringify(data))];
        }

        localStorage.setItem('carts', JSON.stringify(carts));        
    }

    function removeCartFromLocalStorage(data){
        let carts = getCartFromLocalStorage();
        if(carts){
            /* Find the item to be removed */
            for (let i = 0; i < carts.length; i++) {    
                item = JSON.parse(carts[i]); //convert string to object
                if(item.product_uuid == data.product_uuid && item.product_sku == data.product_sku){       
                    carts.splice(i, 1); //remove this item from array                       
                }
            }
        }
        localStorage.setItem('carts', JSON.stringify(carts));        
    }

    function computeItemTotal(itemWrap, qty){      
        let itemPrice = itemWrap.querySelector(".item-price");
        let computePrice = itemWrap.querySelector(".compute-price");
        let price = parseFloat(itemPrice.textContent.replace('$', '')) * qty;
        computePrice.textContent = `$${price}`;
    }

    function computeSubTotal(){    
        let subTotal = 0;
        let prices = document.querySelectorAll(".compute-price");

        prices.forEach(price => {
            subTotal += parseFloat(price.textContent.replace('$', ''));
        });

        cartSubtotal.textContent = `$${subTotal}`;
        cartDrawer.label = `Cart (${prices.length})`;

        if(prices.length == 0){
            bottomWrap.classList.add('hide');
            emptyCartWrap.classList.remove('hide');            
        }
    }        

    /* Close the cart drawer */
    let contShoppingBtn = document.getElementById("continue-shopping-btn");
    contShoppingBtn.addEventListener('insClick', event => {                 
        cartDrawer.setDrawerState(false); 
    });
</script>
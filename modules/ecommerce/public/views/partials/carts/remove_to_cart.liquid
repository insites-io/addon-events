{%- comment -%} Check if the user already has a cart {%- endcomment -%}
{%- graphql user_cart = 'modules/ecommerce/carts/get_user_cart', 
    contact_uuid: params.contact_uuid | dig: 'items','results' | first -%}


{%- if user_cart.id -%}
    {%- comment -%} The user already exists: Update Cart {%- endcomment -%}

    {%- comment -%} Convert array values from string to object {%- endcomment -%}
    {%-  liquid
        assign item_array = '' | split: ','         

        for item in user_cart.items
            assign item_json = item | parse_json
            assign item_array = item_array | array_add: item_json

            ## Check if the product to be added already exists
            if item_json.product_uuid == params.product_uuid and item_json.product_sku == params.product_sku
                assign is_item_exist = true
                assign item_exist_index = forloop.index0
            endif
        endfor
    -%}

    {%- comment -%} Check if the product to be added already exists. {%- endcomment -%}    
    {%- if is_item_exist == true -%}        

        {%- comment -%} Delete existing {%- endcomment -%}        
        {%- assign item_array = item_array | array_delete_at: item_exist_index  -%}                

        {%- if item_array.size == 0 -%}
            {%- assign item_array = '' | split: ',' -%}
        {%- endif -%}      

    {%- endif -%}

    {%- comment -%} Convert the object back to string {%- endcomment -%}
    {%-  liquid
        assign tmp_array = '' | split: ',' 
        for item in item_array
            assign tmp_item = item | json
            assign tmp_array = tmp_array | array_add: tmp_item
        endfor
        assign item_array = tmp_array
    -%}

    {%- parse_json args -%}
    {
        "id": {{ user_cart.id | default: 0 }},
        "items": {{ item_array | default: '[]' }}
    }
    {%- endparse_json -%}
    {%- graphql cart = 'modules/ecommerce/carts/edit_cart_items', args: args -%}

{%- endif -%}

{%- if print == true -%}
    {{cart}}
    {%- response_status 200 -%}
{%- endif -%}
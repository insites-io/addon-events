---
metadata: {
    partial_name: 'Ecommerce | Checkout | Callback Initialize'
}
---
{% log "================ START CALLBACK INIT: Processing checkout and payment ================" %}

{%- comment -%}GET Cart data{%- endcomment -%}
{% include 'modules/ecommerce/checkout/compute_order_summary' %}

{% comment %} Manually set gateway and currency value for now {% endcomment %}
{%- assign gateway = 'stripe' -%}
{%- assign currency = 'AUD' -%}

{%- if gateway == 'stripe' -%}
    
    {%- comment -%}Step 1-A: Stripe payment process{%- endcomment -%}
    {%- include 'modules/ecommerce/stripe/payment/checkout_payment', form, currency -%}

    {% assign payment_response = context.exports.payment_response %}

{%- else -%}
        {% comment %} If new / other payment gateways are supported, insert process here: {% endcomment %}
{%- endif -%}

    {%- comment -%}
    Capture gateway reposnse and set status
    {%- endcomment -%}
    {%- assign status = payment_response.status | downcase -%}
    {%- assign user_id = context.exports.user_id | downcase -%}
    {%- assign order_uuid = form.properties.uuid | downcase -%}
    {%- if status == 'succeeded' -%}
        {%- assign status = 'success' -%}
        {%- assign order_payment_status = "Paid" -%}
        {%- assign order_status = "Completed" -%}
    {%- else -%}
        {%- assign status = 'failed' -%}
        {%- assign order_payment_status = "Failed" -%}
        {%- assign order_status = "Open" -%}
    {%- endif -%}

{%- comment -%}
Step 2: (optional) Create address models
{%- endcomment -%}
{%- if context.current_user.id -%}
    {% include 'modules/ecommerce/checkout/callback_create_address', 
        user_id: user_id,
        form: form %}
    {% assign guest_user = false %}
    {% assign products = context.exports.cart_items.products  %}
    {% assign cart = context.exports.cart_items.carts  %}
{% else %}
    {% assign guest_user = true %}
    {% assign products = context.exports.guest_cart_items.products  %}
    {% assign cart = context.exports.guest_cart_items.carts  %}
{%- endif -%}


{%- comment -%}
Step 3: Update inventory, cart and order models.
{%- endcomment -%}
{% include 'modules/ecommerce/checkout/callback_update_records'
    payment_response: payment_response,
    status: status,
    order_status: order_status,
    order_payment_status: order_payment_status,
    user_id: user_id,
    order_uuid: order_uuid,
    form: form,
    gateway: gateway,
    currency: currency,
    guest_user: guest_user
    %}

{%- comment -%}
Step 4: Trigger autoresponder, workflow email & API 
{%- endcomment -%}
{% parse_json customer_info %}
{
    "email": "{{ form.properties.billing_contact_email }}",
    "first_name": "{{ form.properties.billing_contact_first_name }}",
    "last_name": "{{ form.properties.billing_contact_last_name }}"
}
{% endparse_json %}

{% parse_json data %}
{
    "payment_response": {{ payment_response | default: '[]' }},
    "customer_info": {{ context.current_user | default: customer_info }},
    "cart_ids": {{ context.exports.order.cart_ids | default: 0 }},
    "cart": {{ cart | default: '[]' }},
    "products": {{ products | default: '[]' }},
    "order_info": {{ context.exports.updated_order.items | default: '' }},
    "total_discounted_amount": {{ context.exports.order.total_discount_amount | default: 0 }}, 
    "form": {{ form | default: '' }},
    "guest_user": {{ guest_user | default: false }}

}
{% endparse_json %}
{% log status, type: "==== Email & API: status ====" %}

{%- comment -%}Step 4.1 Workflow & Email Notification{%- endcomment -%}
{% include 'modules/ecommerce/checkout/callback_email_notifications', 
    status: status,
    data: data %}

{%- comment -%}Step 4.2: Trigger API Call{%- endcomment -%}
{% include 'modules/ecommerce/checkout/callback_api_call', 
    status: status,
    data: data %}

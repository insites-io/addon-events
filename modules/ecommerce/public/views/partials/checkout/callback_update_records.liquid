---
metadata: {
    partial_name: 'Ecommerce | Checkout | Callback Update Records'
}
---

{%- assign date_time = "now" | date: "%Y-%m-%dT%H:%M:%SZ" -%}
{%- capture payment_gateway_details -%}{{ payment_response }}{%- endcapture -%}
{%- assign amount = payment_response.amount | divided_by: 100.00 -%}

{%- parse_json card -%}
{
    "last4": "{{ payment_response.source.last4 }}",
    "brand": "{{ payment_response.source.brand }}",
    "exp_month": "{{ payment_response.source.exp_month }}",
    "exp_year": "{{ payment_response.source.exp_year }}"
}
{%- endparse_json -%}

{% parse_json temp_computed %}
{
    "total_amount": {{ amount }}
}
{% endparse_json %}
{%- comment -%}Step 2.0: Create payment data{%- endcomment -%}
{% parse_json payment_data %}
{
    "order_uuid": "{{ order_uuid }}",
    "source": "Payment Gateway",
    "payment_status": "{{ order_payment_status }}",
    "payment_gateway_name": "{{ gateway | titleize }}",
    "date_time": "{{ date_time }}",
    "last_updated_by_id": "{{ context.current_user.id }}",
    "card_last_four_digits": "{{ card.last4 }}",
    "card_brand": "{{ card.brand }}",
    "card_expiry_month": "{{ card.exp_month }}",
    "card_expiry_year": "{{ card.exp_year }}",
    "currency": "{{ currency }}",
    "order_value": {{ amount }},
    "amount": {{ amount }},
    "amount_due": {{ amount }},
    "payment_method_name" : "Credit Card",
    "status": "{{ payment_response.status }}"
}
{% endparse_json %}
{% assign payment_data = payment_data | add_hash_key: "payment_gateway_details", payment_gateway_details %}
{% assign payment_data = payment_data | add_hash_key: "computed", temp_computed %}
{%- graphql add_payment = 'modules/ecommerce/system/trigger_api_call', name: "modules/portal/add_payment", data: payment_data | dig: 'items','response','body' | parse_json -%}   

{% comment %} Create Order Items {% endcomment %}
{%- include 'modules/ecommerce/order_items/create_order_items', order_uuid, guest_user -%}
{% assign cart = context.exports.cart %}


{%- comment -%} Delete the user cart if the status is not 'failed'. {%- endcomment -%}
{% assign tmp_order_payment_status = order_payment_status | downcase %}
{% unless tmp_order_payment_status contains 'failed' %}
    {% if cart.id %}
        {% comment %} Delete Cart and Cart Items {% endcomment %}
        {%- graphql delete_cart = 'modules/ecommerce/carts/delete_cart', id: cart.id -%}
        {%- graphql delete_cart_items = 'modules/ecommerce/cart_items/delete_cart_items', cart_uuid: cart.uuid | dig: 'records_delete_all' -%}
    {% endif %}
{% endunless %}


{%- if status == 'success' -%}    
        
{%- endif -%}

{%- comment -%}Step 2.3: Update order status fields{%- endcomment -%}
{%- parse_json order_update_data -%}
{
    "uuid": "{{ order_uuid }}",
    "date_time": "{{ date_time }}",
    "order_payment_status": "{{ order_payment_status }}",
    "order_status": "{{ order_status }}",
    "shipping_company_name": "{{ form.properties.shipping_company_name }}",
    "billing_company_name": "{{ form.properties.billing_company_name }}"
}
{%- endparse_json -%}
{%- graphql updated_order = 'modules/ecommerce/system/trigger_api_call', name: "modules/portal/update_order", data: order_update_data | dig: 'items','response','body' | parse_json -%}

{%- comment -%}Step 2.4: Update inventory{%- endcomment -%}
{%- if status == 'success' -%}
{%- assign model_name = "modules/insites_ecommerce/product" -%}    

    {% comment %} Product Inventory {% endcomment %}
    {%- if settings.inventory_tracking -%}
        {% log "==== Inventory tracking is enabled: updating inventory ==== " %}
        {%- for cart_id in context.exports.order.cart_ids -%}
            {%- comment -%}2.3.1 Check if cart item was variant or main product{%- endcomment -%}
            {%- graphql cart = 'modules/ecommerce/cart/get_cart_variant', 
                id: cart_id
                | dig: 'items' | dig: 'results' | first -%}

            {%- assign qty_purchased = cart.quantity | times: 1.0 -%}
            {%- comment -%}Check if cart item was variant or main product{%- endcomment -%}
            {%- if cart.product_variant_uuid and cart.product.variant_schema -%}
                {%- comment -%}IF variant id and variant schema, deduct purchase from variant inventory{%- endcomment -%}
                {%- assign model_name = cart.product.variant_schema -%}
                {%- assign cart_item_id = cart.product_variant_uuid -%}

            {%- else -%}
                {%- comment -%}ELSE inventory will be deducted on product model{%- endcomment -%}
                {%- assign cart_item_id = cart.product.id -%}
            {%- endif -%}
            
            {%- comment -%}2.3.2 Deduct purchase from model variant / product{%- endcomment -%}
            {%- if cart_item_id -%}
                {%- graphql stock = "modules/ecommerce/orders/update_stock_purchased"
                    id: cart_item_id
                    model_name: model_name
                    qty: qty_purchased -%}
                    
                {% log "==== Stock updated ==== " %}
            {%- endif -%}
        {%- endfor -%}
    {%- else -%}
        {% log "==== Inventory tracking is disabled: inventory was not updated ==== " %}
    {%- endif -%}
{%- endif -%}

{% export updated_order %}
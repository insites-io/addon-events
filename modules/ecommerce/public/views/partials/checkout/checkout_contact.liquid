---
metadata: {
    partial_name: 'Ecommerce | Checkout | Checkout Account Info Page'
}
---

{% include 'modules/ecommerce/checkout/checkout_redirect_step' %}

<div class="grid-x grid-padding-x">
    <div class="large-offset-2 medium-offset-1 small-offset-0 large-8 medium-10 small-12 cell">
        {% include 'modules/ecommerce/layout/checkout_steps', clickable: true %}
    </div>
</div>

<div class="spacer xxxx-large"></div>

<h3 class="heading-1 font-color-head">Contact</h3>
<div class="spacer xxx-large"></div>

<div class="grid-x grid-padding-x">
    <div class="large-7 medium-12 small-12 cell">
        {%- if context.current_user -%}
            {% comment %} The user is logged in: Get the company_name first {% endcomment %}
            {%- graphql user = 'modules/ecommerce/account/get_current_user' -%}
            {% assign company_uuid = user.current_user.crm_contact[0].company_uuid %}
            {%- assign company_name = "" -%}
            {%- if company_uuid and company_uuid != '' -%}
                {%- graphql company = "modules/ecommerce/companies/get_company", 
                    uuid: company_uuid | dig: 'items','results' | first -%}
                {%- assign company_name = company.company_name -%}
            {%- endif -%}

            {% comment %} Edit current_user {% endcomment %}
            {% include_form 'modules/ecommerce/checkout_user_update', 
                id: context.current_user.id, 
                company_name: company_name %}

        {%- elsif context.session.guest_user.uuid -%}
            {% comment %} Guest user: Get the guest_id first if it has not yet been added to the session under guest_user {% endcomment %}
            {%  liquid 
                if context.session.guest_user.id
                    assign guest_id = context.session.guest_user.id
                else 
                    graphql guest = "modules/ecommerce/account/check_user_email_signup", email: context.session.guest_user.email | dig: 'items','results' | first
                    assign guest_id = guest.id
                    assign guest_user = context.session.guest_user | add_hash_key: 'id', guest_id 
                    session guest_user = guest_user
                endif
            %}
            {% comment %} Edit User form where id=guest_id {% endcomment %}
            {% include_form 'modules/ecommerce/checkout_user_update', 
                id: guest_id, 
                company_name: context.session.contact_company_name %}
        {%- else -%}
            {% include 'modules/ecommerce/checkout/checkout_user_create', company_name: context.session.contact_company_name %}
        {%- endif -%}
    </div>
    <div class="large-4 large-offset-1 medium-12 small-12 cell">
        <div class="hide-for-large spacer xxx-large"></div>
        {%- include 'modules/ecommerce/layout/order_summary', 
            show_product: true,
            check
            form_update: true,
            form_delete: true -%}
    </div>
</div>

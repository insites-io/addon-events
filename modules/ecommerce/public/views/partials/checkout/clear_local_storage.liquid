---
metadata: {
    partial_name: 'Ecommerce | Checkout | Clear Local Storage'
}
---
{%- comment %} Inject JavaScript to clear localStorage when the order is success {% endcomment %}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (window.localStorage) {
            let currentUrl = new URL(window.location.href);
            let rParam = currentUrl.searchParams.get('r');
            
            // Clear the cart from localStorage
            localStorage.setItem('carts', JSON.stringify([]));
            localStorage.setItem('discount_uuids', JSON.stringify([]));
            console.info('localStorage has been cleared.');

            // Reload the page with 'r=true' parameter only if 'r' is not already 'true'
            if (rParam !== 'true') {
                currentUrl.searchParams.set('r', 'true');
                window.location.href = currentUrl.toString();
            } else {
                console.info('Page already reloaded after clearing localStorage.');
            }      
        }
    });
</script>
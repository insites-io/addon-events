{% comment %} 
    * NOTE: The discount feature work is incomplete, as we paused development due to upcoming breaking changes.
    * CONTEXT:
        I moved the discount computation into a separate file to enable reuse for both logged-in and guest users.
    Parameters from parent: 
        - discounts
        - product_uuid
        - item_total_price
        - sub_total_discount
        - used_discounts
{% endcomment %}

{% assign discounts = payload.discounts %}
{% assign product_uuid = payload.product_uuid %}
{% assign item_total_price = payload.item_total_price %}
{% assign sub_total_discount = payload.sub_total_discount %}
{% assign used_discounts = payload.used_discounts %}

{% for discount in discounts %}
    
    {% assign in_product_ids =  discount.product_uuids | array_any: product_uuid %}
        
    {% if discount.is_applicable_to_all_products or in_product_ids %}

        {% if item_total_price >= discount.minimum_cart_value %}

            {% assign discount_type = discount.discount_type | downcase %}
            {% assign discount_value = discount.discount_value %}
            {% assign is_discount_used = used_discounts | array_any: discount.discount_code %}

            {% if discount_type == "fixed_amount" and is_discount_used == false %}

                {% assign sub_total_discount = sub_total_discount | plus: discount_value %}
                {% assign used_discounts = used_discounts | array_add: discount.discount_code %}

            {% elsif discount_type == "percentage" %}

                {% assign temp = item_total_price | times: discount_value | divided_by: 100 %}
                {% assign sub_total_discount = sub_total_discount | plus: temp %}   

            {%- elsif discount_type contains "shipping" -%}                          
            
                {%- liquid                
                    assign shipping_discount = 0                             

                    if discount_type contains "fix" and is_free_shipping == false
                        assign shipping_discount = discount_value | times: item.quantity
                    elsif discount_type contains "percent" and is_free_shipping == false
                        assign shipping_discount = freight_amount | times: discount_value | divided_by: 100 | times: item.quantity
                    elsif discount_type contains 'free shipping'
                        assign shipping_discount = freight_amount | times: item.quantity
                    endif
                    
                    if shipping_discount > sub_freight_amount
                        assign shipping_discount = sub_freight_amount
                    endif

                    assign sub_total_discount = sub_total_discount | plus: shipping_discount
                -%}

        {% endif %}             
        {% endif %}
    {% endif %}        
{% endfor %}

{% parse_json processed_discount %}
{
    "sub_total_discount": {{ sub_total_discount }},
    "used_discounts": "{{ used_discounts }}"

}
{% endparse_json %}

{% liquid return processed_discount %}
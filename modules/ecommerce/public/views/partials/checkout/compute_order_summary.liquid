{% comment %} 
    Parameters from parent: 
        - user_uuid
        - user_cart
        - carts
        - products
{% endcomment %}

{%- assign user_id = context.current_user.id | default: null -%}
{% include 'modules/ecommerce/carts/cart_items' %}

{% comment %} Guest Order Summary {% endcomment %}
{% if user_id == null %}
    {% if context.session.guest_order_summary %}
        {% comment %}
            * NOTE: The discount feature work is incomplete, as we paused development due to upcoming breaking changes.
        {% endcomment %}
        {% assign guest_order_summary = context.session.guest_order_summary %}
        {% assign guest_cart = context.session.guest_cart %}
        {% assign discounts = context.session.guest_discount.discounts %}


        {% assign sub_total_amount = guest_order_summary.sub_total_amount %}
        {% assign total_amount = guest_order_summary.total_amount %}

        {% for cart in guest_cart %}
            {% parse_json payload %}
            {
                "discounts": {{ discounts }},
                "product_uuid": "{{ cart.product_uuid }}",
                "item_total_price": {{ cart.item_total_price | default: 0 }}
            }
            {% endparse_json %}
            {% function sub_total_discount = "modules/ecommerce/checkout/compute_discount", payload: payload %}
            
        {% endfor %}

        {% parse_json computed %}
            {
                "sub_total_amount": {{ guest_order_summary.sub_total_amount | default: 0 }},
                "shipping_amount": {{ guest_order_summary.shipping_amount | default: 0 }},
                "total_discount_amount": {{ sub_total_discountt | default: 0 }},
                "processing_fee": {{ guest_order_summary.processing_fee | default: 0 }},
                "tax_amount":  {{ guest_order_summary.tax_amount| default: 0 }},    
                "total_amount": {{ guest_order_summary.total_amount | default: 0 }}
            }
        {% endparse_json %}
    {% endif %}

{% else %}
    {% if user_uuid and user_cart and carts and products %}
    {% comment %} Do nothing {% endcomment %}
    {% else %}
        {% assign cart_items = context.exports.cart_items %}
        {% assign user_cart = cart_items.user_cart %}
        {% assign carts = cart_items.carts %}
        {% assign products = cart_items.products %}
    {% endif %}

    {% assign discounts = user_cart.discounts %}

    {% comment %} Initialize Variables {% endcomment %}
    {%  liquid 
        assign sub_total_amount = 0
        assign sub_total_discount = 0
        assign sub_total_shipping = 0
        assign sub_total_tax = 0
        assign used_discounts = '' | split: ','
    %}

    {% if carts.size > 0 %}

        {% for item in carts %}
                        
            {% include 'modules/ecommerce/carts/cart_details', products, item, user_uuid %}
            {% assign cart = context.exports.cart %}    
            {% assign item_total_price = cart.item_total_price %}
            {% assign sub_total_amount = sub_total_amount | plus: item_total_price %}

            {% comment %} Shipping Fee {% endcomment %}
            {%  liquid
                assign is_free_shipping = cart.selected_prop.is_free_shipping
                if is_free_shipping == true
                    assign freight_amount = 0
                else
                    assign freight_amount = cart.selected_prop.freight_amount
                endif
                assign sub_freight_amount = freight_amount | times: item.quantity
                assign sub_total_shipping = sub_total_shipping | plus: sub_freight_amount
            %}
            
            {% comment %} Tax {% endcomment %}
            {%  liquid
                if cart.is_tax_included == true
                    assign tax = 0
                else
                    if cart.selected_prop.is_fixed_tax_amount == true
                        assign tax = cart.selected_prop.tax_amount | times: item.quantity
                    else 
                        assign tax = cart.price | times: cart.selected_prop.tax_amount | divided_by: 100 | times: item.quantity
                    endif
                endif
                assign sub_total_tax = sub_total_tax | plus: tax
            %}

            {% comment %}
                * NOTE: The discount feature work is incomplete, as we paused development due to upcoming breaking changes.
                * CONTEXT:
                    I moved the discount computation into a separate file to enable reuse for both logged-in and guest users.
            {% endcomment %}

            {% parse_json payload %}
            {
                "discounts": {{ discounts }},
                "product_uuid": "{{ item.product_uuid }}",
                "item_total_price": {{ item_total_price | default: 0 }},
                "sub_total_discount": {{ sub_total_discount }},
                "used_discounts": {{ used_discounts }}
            }
            {% endparse_json %}

            {% function processed_discount = "modules/ecommerce/checkout/compute_discount", payload: payload %}

            {% assign sub_total_discount = processed_discount.sub_total_discount %}
            {% assign used_discounts = processed_discount.used_discounts %}
        {% endfor %}
    {% endif %}

    {% assign temp_total = sub_total_amount | plus: sub_total_shipping | minus: sub_total_discount | plus: sub_total_tax %}
    {% assign processing_fee = temp_total | times: 0.017 %}
    {% assign total_amount = temp_total | plus: processing_fee %}

    {% parse_json computed %}
    {
        "sub_total_amount": {{ sub_total_amount | default: 0 }},
        "shipping_amount": {{ sub_total_shipping | default: 0 }},
        "total_discount_amount": {{ sub_total_discount | default: 0 }},
        "processing_fee": {{ processing_fee | default: 0 }},
        "tax_amount": {{ sub_total_tax | default: 0 }},    
        "total_amount": {{ total_amount | default: 0 }}
    }
    {% endparse_json %}
    
{% endif %}

{% export computed %}
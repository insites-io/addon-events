---
metadata: {
    partial_name: 'Ecommerce | Checkout | Compute Order Summary'
}
---
{% comment %} 
    Parameters from parent: 
        - user_cart
        - carts
        - products
{% endcomment %}


{% comment %} Initialize Variables {% endcomment %}
{%  liquid 
    assign sub_total_amount = 0
    assign sub_total_discount = 0
    assign sub_total_shipping = 0
    assign sub_total_tax = 0
    assign sub_total_tax_included = 0 
    assign used_discounts = '' | split: ','
%}


    {% if user_cart and carts and products %}
        {% comment %} Do nothing {% endcomment %}
    {% else %}
        {% include 'modules/ecommerce/carts/cart_items' %}
        {% assign cart_items = context.exports.cart_items %}        
        {% assign user_cart = cart_items.user_cart %}
        {% assign carts = cart_items.carts %}
        {% assign products = cart_items.products %}
    {% endif %}

    {% assign discounts = user_cart.discounts %}
    


{% if carts.size > 0 %}

    {% for item in carts %}
                    
        {% include 'modules/ecommerce/carts/cart_details', products, item %}
        {% assign cart = context.exports.cart %}    
        {% assign item_total_price = cart.item_total_price %}
        {% assign sub_total_amount = sub_total_amount | plus: item_total_price %}

        {% comment %} Shipping Fee {% endcomment %}
        {%  liquid
            assign is_free_shipping = cart.selected_prop.is_free_shipping
            if is_free_shipping == true
                assign freight_amount = 0
            else
                assign freight_amount = cart.selected_prop.freight_amount
            endif
            assign sub_freight_amount = freight_amount | times: item.quantity
            assign sub_total_shipping = sub_total_shipping | plus: sub_freight_amount
        %}
        
        {% comment %} Tax {% endcomment %}
        {% comment %} 
            when is_tax_included = true, the tax is already included in the price of the product
        {% endcomment %}
        {%  liquid                            
            if cart.selected_prop.is_fixed_tax_amount == true
                assign tax = cart.selected_prop.tax_amount | times: item.quantity
            else 
                if cart.selected_prop.is_tax_included == true
                    ## tax = (Price x Tax Rate​) / (1 + Tax Rate​)
                    assign tax_rate = cart.selected_prop.tax_amount | divided_by: 100
                    assign temp_val = cart.price | times: tax_rate
                    assign temp_val2 = 1 | plus: tax_rate
                    assign tax = temp_val | divided_by: temp_val2 | times: item.quantity
                else 
                    assign tax = cart.price | times: cart.selected_prop.tax_amount | divided_by: 100 | times: item.quantity
                endif
            endif
            
            assign sub_total_tax = sub_total_tax | plus: tax

            if cart.selected_prop.is_tax_included == true                   
                ## save the tax that is already included in the price of the product 
                ## we will use this to subtract in the total amount
                assign sub_total_tax_included = sub_total_tax_included | plus: tax
                assign tax_label = 'Includes Tax'
            elsif sub_total_tax_included > 0
                assign tax_label = 'Includes Tax'
            else 
                assign tax_label = 'Tax'
            endif
        %}

        {% comment %} Discounts {% endcomment %}
        {% function sub_total_discount = 'modules/ecommerce/checkout/compute_discount', 
            discounts: discounts, 
            item: item, 
            item_total_price: item_total_price,
            used_discounts: used_discounts,
            sub_total_discount: sub_total_discount,
            is_free_shipping: is_free_shipping,
            freight_amount: freight_amount,
            sub_freight_amount : sub_freight_amount
        %}        
        {% assign used_discounts = context.exports.used_discounts %}
                    
    {% endfor %}
{% endif %}

{% if page_slug == 'shopping-cart' %}
    {% assign sub_total_shipping = 0 %}
{% endif %}

{% assign temp_total = sub_total_amount | plus: sub_total_shipping | minus: sub_total_discount | plus: sub_total_tax | minus: sub_total_tax_included %}

{% comment %} ? ADD VALUE FOR TAX INCLUDED AND NOT INCLUDED {% endcomment %}
{% assign sub_total_tax_not_included = sub_total_tax | minus: sub_total_tax_included %}
{% if sub_total_tax_not_included != 0 and sub_total_tax_included != 0 %}
    {% assign tax_applied = "both" %}
{% else %}
    {% assign tax_applied = "single" %}        
{% endif %}

{% assign processing_fee = temp_total | times: 0.017 %}
{% assign total_amount = temp_total | plus: processing_fee %}

{% comment %} tax_included_in_price represents the sum of taxes that are already included in the product price {% endcomment %}
{% parse_json computed %}
{
    "sub_total_amount": {{ sub_total_amount | default: 0 }},
    "shipping_amount": {{ sub_total_shipping | default: 0 }},
    "total_discount_amount": {{ sub_total_discount | default: 0 }},
    "processing_fee": {{ processing_fee | default: 0 }},
    "tax_label": "{{ tax_label }}",
    "tax_amount": {{ sub_total_tax | default: 0 }},
    "tax_included_in_price": {{ sub_total_tax_included | default: 0 }},
    "total_amount": {{ total_amount | default: 0 }},
    "sub_total_tax_not_included": {{ sub_total_tax_not_included | times: 1 | default: 0 }},
    "sub_total_tax_included": {{ sub_total_tax_included | times: 1 | default: 0 }},
    "tax_applied": "{{ tax_applied }}"
}
{% endparse_json %}

{% comment %} ? add to session for confirmation {% endcomment %}
 {% session sub_total_tax_not_included = sub_total_tax_not_included | times: 1 | default: 0 %}
 {% session sub_total_tax_included = sub_total_tax_included | times: 1 | default: 0 %}
 {% session tax_applied = tax_applied %}
 
{% export computed %}
---
metadata: {
    partial_name: 'Ecommerce | Checkout | Create CRM Company on Submit'
}
---
{% comment %} Check if company exist {% endcomment %}
{% comment %}  - IF does not exist, create CRM company {% endcomment %}
{% comment %}  - IF exist, get company id {% endcomment %}
{% comment %}  - Assign Contact to company {% endcomment %}

{%- liquid 

    if company_name and user_id

        ## Get Company
        graphql company = 'modules/ecommerce/companies/get_company', company_name: company_name | dig: 'items','results' | first
        
        ## If not exist: Create new Company
        unless company.id 
            assign uuid = '' | uuid
            assign data = '{}' | parse_json
            assign properties = '{}' | parse_json
            assign properties = properties | add_hash_key: 'company_name', 'Liquid Sample'
            assign data = data | add_hash_key: 'properties', properties

            graphql add_company = 'modules/website/trigger_api_call', name: 'modules/portal/add_company', data: data | dig: 'items','response','body' | parse_json
            assign company = add_company | dig: 'items'
        endunless 
        
        ## Assign Company to Contact
        assign api_data = '{}' | parse_json
        assign api_data = api_data | add_hash_key: 'company_uuid', company.uuid
        assign api_data = api_data | add_hash_key: 'contact_ids', user_id
        graphql assign_contact = 'modules/website/trigger_api_call', name: 'modules/portal/assign_company_contact', data: api_data | dig: 'items','response','body' | parse_json

        assign company_id = company.id
        assign company_uuid = company.uuid
        assign company_name = company.company_name
        
    endif

    export company_id
    export company_uuid
    export company_name -%}

{% liquid
    assign formatted_shipping_mobile_phone = null
    assign formatted_account_mobile_phone = null

    assign country_code = data.country_code | default: '61'
    assign phone_number = data.phone_number
    assign account_phone = data.account_phone | default: null
    assign shipping_phone = data.shipping_phone | default: null

    if phone_number
        assign mobile_country_code = '(' | append: country_code | append: ') '
        assign phone_first_part = phone_number | slice: 0, 3
        assign phone_second_part = phone_number | slice: 3, 10
        assign mobile_phone = mobile_country_code | append: phone_first_part | append: phone_second_part
    endif

    if account_phone
        assign formatted_account_mobile_phone = mobile_phone
        export formatted_account_mobile_phone
    elsif shipping_phone
        assign formatted_shipping_mobile_phone = mobile_phone
        export formatted_shipping_mobile_phone
    endif
%} 
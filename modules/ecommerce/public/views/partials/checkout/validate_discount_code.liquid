{% comment %}
This partial accepts:
payload: {
    check_duplicates: Boolean
    form_update: Boolean 
    form_delete: Boolean 
    contact_uuid: ID! / String!
    discount_code: String!
    discount_code_uuid: String!
}
{% endcomment %}

{%- assign contact_uuid = payload.contact_uuid | default: blank -%}
{%- assign discount_code =  payload.discount_code | default: blank -%}
{% assign guest_discounts = context.session.guest_discount.discounts %}
{% assign guest_discount_uuids = context.session.guest_discount.discount_uuids %}
{% assign discount_duplicate = false %}
{% assign guest_user = false %}
{% assign variable = value %}


{% comment %} Step 1: Check if code exist {% endcomment %}
{% if discount_code and discount_code != blank %}
    {% graphql discount = "modules/ecommerce/discount/get_discount_by_code",
        discount_code: discount_code | dig: 'items' | dig: 'results' | first %}
{% endif %}
    

{% if discount.uuid %}
    {% comment %} Step 2-A: If valid, check if code is already been used to avoid duplicate{% endcomment %}
    {%- if payload.check_duplicates -%}
        {%- if contact_uuid != blank -%}
            {% graphql current_codes = 'modules/ecommerce/carts/get_cart_discount',
                    contact_uuid: contact_uuid, discount_code_uuids: discount.uuid
                    | dig: 'items' %}

           {% if current_codes.results.size > 0 %}
                {% assign discount_duplicate = true %}
           {% endif %}
        {%- else -%}
            {% assign guest_user = true %}
            {% comment %} Check guest cart discout codes {% endcomment %}
   
            {%- if guest_discount_uuids contains discount.uuid -%}
                {% assign discount_duplicate = true %}
            {%- endif -%}
 
        {%- endif -%}
    {%- endif -%}

    {%- if discount_duplicate == true -%}
        {%- assign message = "Discount code has already been applied." -%}
        {%- assign is_valid = "duplicate" -%}
    {%- else -%}

        {% comment %} Step 3.2: If valid, validate if discount code # of uses has not been reached {% endcomment %}        
        {%- if discount.usage_count >= discount.usage_limit  -%}
            {% assign message = "Sorry, the discount code's maximum uses has been reached." %}
            {% assign is_valid = "limited use" %}
        {%- endif -%}
        

        {% comment %} Step 3.3: If valid, validate if discount code # of uses per user has not been reached {% endcomment %}        
        {% graphql used_discounts = 'modules/ecommerce/orders/get_order_discounts',
                order_contact_email: order_contact_email, discount_code_uuids: discount.uuid
                | dig: 'items' %}

        {%- if used_discounts.total_entries >= discount.usage_limit_per_user  -%}
            {% assign message = "Sorry, you have reached the limit of using this discount code." %}
            {% assign is_valid = "limited use per user" %}
        {%- endif -%}
        

        {% comment %}Step 4: If discount code is still valid, continue other validation checks {% endcomment %}
        {%- if is_valid == blank or is_valid == "" or is_valid == true  -%}

            {% comment %} Step 4-1: If valid, check if cart applies to any items within the cart item{% endcomment %}                        

            {% if discount.applicable_to == 'products' and discount.is_applicable_to_all_products == true %}
                {%- assign is_valid = true -%}
            {% elsif discount.applicable_to == 'categories' and discount.is_applicable_to_all_categories == true %}
                {%- assign is_valid = true -%}
            {% else %}

                {%- if contact_uuid != blank -%}
                    {% graphql user_cart = 'modules/ecommerce/carts/get_user_cart', 
                        contact_uuid: contact_uuid | dig: 'items','results' | first %}
                {% else %}
                    {% comment %} check cart local storage {% endcomment %}
                    {% assign guest_cart_items = context.session.guest_cart %}
                {% endif %}

                {% if user_cart.items.size > 0 or guest_cart_items.size > 0 %}                        
                    {%  liquid
                        ## Convert an array of strings into an array of objects
                        assign item_obj = '' | split: ',' 
                        assign cart_items = user_cart.items | default: guest_cart_items

                        for item in cart_items
                            assign item_json = item | parse_json
                            assign item_obj = item_obj | array_add: item_json
                        endfor

                        assign cart_product_uuids = item_obj | array_map: 'product_uuid' | array_flatten  

                        ## Get cart category_uuids 
                        if discount.applicable_to == 'categories' 
                            graphql products = 'modules/ecommerce/products/get_cart_products', uuid: cart_product_uuids, size: cart_items.size | dig: 'items','results'
                            assign cart_category_uuids = products | map: "category_uuids" | flatten | array_uniq
                        endif
                    %}
               
                {% endif %}

                {% comment %} Check if any of the products in the cart is included in discount_code products  {% endcomment %}
                {% if discount.applicable_to == 'products' %}
                    {% assign product_matched = discount.product_uuids | array_intersect: cart_product_uuids %}
                {% elsif discount.applicable_to == 'categories' %}
                    {% assign product_matched = discount.category_uuids | array_intersect: cart_category_uuids %}
                {% endif %}

                {%- if product_matched and product_matched.size > 0 -%}
                    {%- assign is_valid = true -%}
                {% endif %}

            {% endif %}

            {%- if is_valid == true -%}
                {% comment %} Step 4-A: If valid, save discount code on 'insites_cart_discount_code' {% endcomment %}
                {%- assign message = "Discount code has been applied." -%}

                {%- if guest_user == false -%}
                    {% comment %} Update cart, add new discount_code_uuid {% endcomment %}
                    {% include 'modules/ecommerce/discounts/update_discount', 
                        user_uuid: contact_uuid,
                        type: 'add', 
                        discount_uuid: discount.uuid %}
                {% else %}
                   {% comment %} Update guest discount {% endcomment %}
                    {% assign new_discount_uuid = discount.uuid %}  

                    {% if guest_discount_uuids.size > 0 %}
                        {% assign updated_discount_uuids = guest_discount_uuids | join: ',' | append: ',' | append: new_discount_uuid %}
                    {% else %}
                        {% assign updated_discount_uuids = new_discount_uuid %}
                    {% endif %}

                    {% assign guest_discounts = guest_discounts | parse_json %}
                    {% assign new_discount = discount | parse_json %}
                    
                    {% assign updated_discounts = guest_discounts | array_add: new_discount %}

                    {% comment %} Ensure proper formatting {% endcomment %}
                    {% assign updated_discount_uuids = updated_discount_uuids | split: ',' %}

                    {%- parse_json guest_discount -%}
                    {
                        "discount_uuids": {{ updated_discount_uuids | json }},
                        "discounts": {{ updated_discounts | json  }}
                    }
                    {%- endparse_json -%}

                    {%- session guest_discount = guest_discount -%}
                {% endif %}

            {%- else -%}
                {% comment %} Step 4-B: Else invalid, return error & delete from 'cart_discount_code' {% endcomment %}
                {% assign message = "There are no products in your cart is eligible for this discount code." %}
                {% assign is_valid = "no products" %}
                {%log "No products elegible" %}

            {%- endif -%}

        {%- endif -%}
        
    {%- endif -%}
{% else %}
  {% comment %} Step 2-B: Discount code exist, but disabled / expired / not yet active. {% endcomment %}
  {% comment %} Return state true with discount code's error message {% endcomment %}
  {% assign message = "Sorry, that discount code is not valid. Please check the code has been entered correctly and is within the validation period." %}
  {% assign is_valid = "invalid / expired" %}
{% endif %}


{%- comment -%} ==== API RESPONSE ==== {%- endcomment -%}
{%- comment -%}Status code 400: API or GraphQL error{%- endcomment -%}
{%- if discount == blank or discount == '' %}
    {%- assign status = 400 -%}
    {%- assign message = "Discount code is not found or has been deleted." -%}
    {%- assign is_valid = "not found" -%}
{%- endif -%}

{% comment %} 
    OPTIONAL STEP: 
     - If payload.form_delete === true and code is not valid, auto delete cart discount code if invalid 
{% endcomment %}
{%- if payload.form_delete == true and is_valid != true -%}

    {% comment %} Update cart, delete the discount_code {% endcomment %}
    {% include 'modules/ecommerce/discounts/update_discount', 
        user_uuid: contact_uuid,
        type: 'remove', 
        discount_uuid: discount.uuid %}

{%- endif -%}

{%- parse_json validate_code -%}
{
  "is_valid": "{{ is_valid }}",
  "message": "{{ message }}",
  "guest_user": {{ guest_user | default: false }}
}
{%- endparse_json -%}

{% liquid return validate_code %}
---
metadata: {
    partial_name: 'Ecommerce | Discounts | Update Discount'
}
---
{% comment %} 
    Parameters from parent:
     - discount_uuid
     - user_uuid
     - type
{% endcomment %}
{%- if user_uuid != blank -%}

    {% unless user_cart %}
        {% graphql user_cart = 'modules/ecommerce/carts/get_cart', 
        contact_uuid: user_uuid | dig: 'items','results' | first %}
    {% endunless %}

    {% if type == 'add' %}
        {% assign new_discount_code_uuids = user_cart.discount_code_uuids | array_add: discount_uuid | array_uniq %}
    {% elsif type == 'remove' %}
        {% assign new_discount_code_uuids = user_cart.discount_code_uuids | array_delete: discount_uuid | array_uniq %}
    {% endif %}

    {% parse_json args %}
    {
        "id": "{{ user_cart.id }}",
        "discount_code_uuids": {{ new_discount_code_uuids }}
    }
    {% endparse_json %}
    {% graphql update_cart_discount = 'modules/ecommerce/carts/update_cart_discount', args: args %}

{% endif %}

{% export update_cart_discount %}
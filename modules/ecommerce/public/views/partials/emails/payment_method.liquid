{%  assign source = data.source %}

{% comment %} Card Type {% endcomment %}
<table role="module" border="0" cellpadding="0" cellspacing="0" width="100%">
     <tbody>
          <tr>
          <td height="100%" valign="top" role="module-content" align="left">
               
               <table style="width:100%;letter-spacing:normal" cellpadding="0" cellspacing="0" border="0" bgcolor="#FDFDFD">
               <tbody><tr>
               <td style="padding:32px 0px 0px" align="left" valign="middle}.font-article">
               </td>
               </tr>
               <tr>
               <td align="left" bgcolor="#FDFDFD" style="width:100%;padding:0px 40px" valign="middle}.font-article">
                    <p style="color:#0d0d0d;font-size:14px;line-height:22px;font-weight:600;font-family:inherit;margin:0px;padding:0">Card Type</p>
               </td>
               </tr>
               <tr>
               <td style="padding:8px 0px 0px" align="left" valign="middle}.font-article">
               </td>
               </tr>
               <tr>
               <td align="left" bgcolor="#FDFDFD" style="width:100%;padding:0px 40px" valign="middle}.font-article">
                    <p style="color:#525252;font-size:14px;line-height:22px;font-family:inherit;margin:0px;padding:0">{{ source.brand }}</p>
               </td>
               </tr>
               </tbody></table>
          </td>
          </tr>
     </tbody>
</table>


{% comment %} Card Number {% endcomment %}
<table role="module" border="0" cellpadding="0" cellspacing="0" width="100%">
     <tbody>
          <tr>
          <td height="100%" valign="top" role="module-content" align="left">
               
               <table style="width:100%;letter-spacing:normal" cellpadding="0" cellspacing="0" border="0" bgcolor="#FDFDFD">
               <tbody><tr>
               <td style="padding:16px 0px 0px" align="left" valign="middle}.font-article">
               </td>
               </tr>
               <tr>
               <td align="left" bgcolor="#FDFDFD" style="width:100%;padding:0px 40px" valign="middle}.font-article">
                    <p style="color:#0d0d0d;font-size:14px;line-height:22px;font-weight:600;font-family:inherit;margin:0px;padding:0">Card Number</p>
               </td>
               </tr>
               <tr>
               <td style="padding:8px 0px 0px" align="left" valign="middle}.font-article">
               </td>
               </tr>
               <tr>
               <td align="left" bgcolor="#FDFDFD" style="width:100%;padding:0px 40px" valign="middle}.font-article">
                    <p style="color:#525252;font-size:14px;line-height:22px;font-family:inherit;margin:0px;padding:0">{{ source.last4 |  prepend: '**** *** **** '  }}</p>
               </td>
               </tr>
               </tbody></table>
          </td>
          </tr>
     </tbody>
</table>
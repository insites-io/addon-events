---
metadata: {
    partial_name: 'Ecommerce | Layout | Checkout Steps'
}
---
{%- assign latestStep = context.session.latest_step | default: 1 -%}
{%- assign currentStep = 1 -%}

{% case context.page.slug %}
    {% when 'checkout' %}
        {%- assign currentStep = 1 -%}
    {% when 'checkout/shipping' %}
        {%- assign currentStep = 2 -%}
    {% when 'checkout/billing' %}
        {%- assign currentStep = 3 -%}
    {% when 'checkout/payment' %}
        {%- assign currentStep = 4 -%}
    {% when 'confirmation' %}
        {%- assign currentStep = 5 -%}
    {% else %}
{% endcase %}

<ins-steps
    inline
    clickable  with-validation
    {% if context.location.pathname == '/confirmation' %} complete {% endif %}
    id="checkout-nav">
    
    <ins-step 
        {% if currentStep == 1 %}active{% endif %}
        {% if currentStep == 1 %}disabled {% endif %}
        {% if latestStep > 1 and currentStep > 1 %}complete{% endif %}
        {% if context.current_user %}
            data-page="/checkout"
        {% else %}
            data-page="/checkout?guest=true"
        {% endif %}
        description="Contact" 
        class="checkout-step">
    </ins-step>

    <ins-step
        {% if currentStep == 2 %}active{% endif %}
        {% if currentStep == 2 or latestStep < 2 %}disabled {% endif %}
        {% if latestStep > 2 and currentStep > 2 %}complete{% endif %}
        data-page="/checkout/shipping"
        description="Shipping" 
        class="checkout-step">
    </ins-step>

    <ins-step
        {% if currentStep == 3 %}active{% endif %}
        {% if currentStep == 3 or latestStep < 3 %}disabled {% endif %}
        {% if latestStep > 3 and currentStep > 3 %}complete{% endif %} 
        data-page="/checkout/billing"
        description="Billing" 
        class="checkout-step">
    </ins-step>

    <ins-step
        {% if currentStep == 4 %}active{% endif %}
        {% if currentStep == 4 or latestStep < 4 %}disabled {% endif %}
        {% if latestStep > 4 and currentStep > 4 %}complete{% endif %}
        data-page="/checkout/payment"
        description="Payment" 
        class="checkout-step">
    </ins-step>

</ins-steps>
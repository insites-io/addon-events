---
metadata: {
    partial_name: 'Ecommerce | Order Items | Create Order Items'
}
---
{%- comment -%} Get user cart {%- endcomment -%}
{% graphql user_cart = 'modules/ecommerce/carts/get_user_cart', 
        contact_uuid: user_uuid | dig: 'items','results' | first %}


{%  liquid    
    ## Get cart
    if guest_user == false
        assign cart_items = '' | split: ','     
        graphql user_cart = 'modules/ecommerce/carts/get_user_cart', contact_uuid: user_uuid | dig: 'items','results' | first 

        for cart_item in user_cart.items
            ## Convert an array of strings into an array of objects
            assign temp_item = cart_item | parse_json
            assign cart_items = cart_items | array_add: temp_item                
        endfor

    else 
        assign cart_items = context.session.guest_cart
    endif

    ## Get product info
    assign product_uuids = cart_items | array_map: 'product_uuid' | array_flatten
    graphql products = 'modules/ecommerce/products/get_cart_products', uuid: product_uuids, size: cart_items.size | dig: 'items','results'
%}    

{% comment %} Create data for order_items  {% endcomment %}
{%  liquid   
    assign order_items = '' | split: ','

    for cart_item in cart_items

        assign product = products | array_detect: uuid: cart_item.product_uuid
        assign product_name = product.product_name

        ## to fix issues in comparing '' versus null
        if product.product_sku == null 
            assign product = product | add_hash_key: 'product_sku', ''
        endif
        
        ## Check if the cart_item is a product or a variant of the product
        assign temp_variant_uuid = ''
        if cart_item.product_sku == product.product_sku
            ## item is NOT a variant
            assign selected_prop = product
        else 
            ## cart_item is a variant                
            for variant in product.variants
                if cart_item.product_sku == variant.product_sku
                    assign selected_prop = variant
                    assign temp_variant_uuid = variant.uuid
                endif
            endfor
        endif            

        if selected_prop.is_on_sale == true 
            assign price = selected_prop.sale_price
        else 
            assign price = selected_prop.regular_price
        endif          

        assign order_item_image = selected_prop.product_image.url | default: ''

        assign properties = '' | parse_json

        assign properties = properties | add_hash_key: 'order_uuid', order_uuid
        assign properties = properties | add_hash_key: 'product_uuid', cart_item.product_uuid
        assign properties = properties | add_hash_key: 'product_variant_uuid', temp_variant_uuid
        assign properties = properties | add_hash_key: 'order_item_image', order_item_image
        assign properties = properties | add_hash_key: 'order_item_name', product_name
        assign properties = properties | add_hash_key: 'sku', cart_item.product_sku
        assign temp_cart_item_quantity = cart_item.quantity | plus: 0
        assign properties = properties | add_hash_key: 'quantity', temp_cart_item_quantity
        assign properties = properties | add_hash_key: 'is_fixed_tax_amount', selected_prop.is_fixed_tax_amount
        assign properties = properties | add_hash_key: 'unit_price', price
        assign temp_tax_amount = selected_prop.tax_amount | default: 0.0
        assign properties = properties | add_hash_key: 'tax_amount', temp_tax_amount
        assign properties = properties | add_hash_key: 'item_tax', temp_tax_amount
        comment
            These items are to be readded when needed, consult Insites for changes in fields
            assign temp_line_item_price = price | times: temp_cart_item_quantity
            assign properties = properties | add_hash_key: 'line_item_price', temp_line_item_price
            assign temp_line_item_tax = temp_tax_amount | times: temp_cart_item_quantity
            assign properties = properties | add_hash_key: 'line_item_tax', temp_line_item_tax
            assign properties = properties | add_hash_key: 'item_price', price
        endcomment
        assign line_item_total = price | times: cart_item.quantity | times: 1.00
        assign properties = properties | add_hash_key: 'line_item_total', line_item_total

        assign order_items = order_items | array_add: properties
    endfor

    assign order_items_payload = '{}' | parse_json
    assign order_items_payload = order_items_payload | add_hash_key: 'payload', order_items

%}

{% graphql create_order_item = 'modules/ecommerce/system/trigger_api_call', name: "modules/ecommerce/add_order_items", data: order_items_payload %}
{% log create_order_item, type: "cREATE order ITEM Response" %}
{%- comment %}
{% graphql create_order_item = 'modules/ecommerce/order_items/create_order_items', items: order_items %}
{%- endcomment %}

{% export user_cart %}
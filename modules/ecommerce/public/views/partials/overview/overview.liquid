---
metadata: {
    partial_name: 'Ecommerce | Overview | Overview'
}
---
{% graphql orders = "modules/ecommerce/orders/get_orders_to_receive", 
    order_contact_uuid: context.session.user_uuid | dig: "items" %}

<section>
    <h2>Overview</h2>
    <div class="spacer"></div>

    <div class="grid-padding-x grid-x">
        <div class="cell large-4 medium-12 small-12">
            <ins-card steady class="overview no-hover-border">
                <a href="/">
                <div class="grid-y cell wrap font-color-head">
                    <div>
                        <p class="body-small bold">
                            <i class="icon-shopping-bag"></i> 
                            <span>Orders to receive</span>
                        </p>                         
                        <div class="spacer x-small"></div>
                        <h2>{{orders.total_entries | default: 0}}</h2>                        
                    </div>                   
                    <div class="text-right">
                        <a href="/order-history" class="font-color-head">View Details</a>
                    </div>
                </div>
                </a>
            </ins-card>
        </div>
    </div>

    <div class="spacer x-large"></div>
</section>
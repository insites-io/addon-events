{%- if carts.size > 0 -%}
    <h2>Cart Items</h2>
    <div class="spacer x-large"></div>
    <div id="shopping-cart-list" class="shopping-cart grid-y">

        {%- for item in carts -%}          

            {% include 'modules/ecommerce/carts/cart_details', products, item, user_uuid %}
            {% assign cart = context.exports.cart %}
            
                                                
            <div id="cart-item-{{cart.selected_prop.id}}" class="cart-item-wrap cell">
                {% if forloop.first == false %}
                    <hr>
                    <div class="spacer x-large"></div>
                {% endif %}
                <div class="grid-x" >
                    <div class="img-wrap" style="width:88px;">
                        {% if cart.selected_prop.product_image.url %}
                            <img  src="{{ cart.selected_prop.product_image.url }}" alt="{{ cart.product_name }}" >
                        {% else %}
                            {% include 'modules/website/layout/placeholder_image', size: 'medium' %}
                        {% endif %}
                    </div>
                    <div class="flex-grow-1">
                        <h6>
                            {{ cart.product_name }} 
                            {% if cart.selected_prop.stock_level < 1 %}
                            <ins-tag label="Pre-Order" class='preorder-tag body-x-small' ></ins-tag>
                            {% endif %}
                        </h6> 
                        <p class="body-small">SKU: {{ item.product_sku }}</p>
                        <div class="spacer small"></div>
                        {% comment %} Get variant info {% endcomment %}
                        {% if cart.is_variant == true %}
                            {%  liquid 
                                ## Convert an array of strings into an array of objects
                                assign options = '' | split: ',' 
                                for option in selected_prop.product_options
                                    assign option_json = option | parse_json
                                    assign options = options | array_add: option_json
                                endfor
                            %}
                            {% for option in options %}
                                <p>
                                    <span class="body-x-small-bold">{{ option.product_option_label | titleize }}:</span>
                                    <span class="body-x-small">{{ option.product_option_value | titleize }}</span>
                                </p>
                            {% endfor %}
                        {% endif %}
                        <p>
                            <span class="body-x-small-bold">Price:</span>
                            <span class="body-x-small item-price">{{ cart.price | pricify }}</span>
                            {% if cart.selected_prop.is_on_sale == true %}
                            <span class="body-x-small strikethrough">{{ cart.price_strikethrough | pricify }}</span>
                            {% endif %}
                        </p>
                    </div>
                    <div class="btn-wrap grid-y">
                        <p class="cart-price compute-price">{{ cart.item_total_price | pricify }}</p>
                        <div class="spacer small"></div>
                        <ins-input-stepper
                            class="cart-stepper" 
                            data-product_uuid="{{ item.product_uuid }}"
                            data-product_sku="{{ item.product_sku }}"
                            value="{{ item.quantity }}" 
                            step="1" min="1" 
                            max="{{ cart.selected_prop.stock_level  }}" 
                            small>
                        </ins-input-stepper>
                        <div class="spacer small"></div>
                        <div class="text-right" >
                            {% parse_json remove_item %}
                            {
                                "product_uuid": "{{ item.product_uuid }}",
                                "product_sku": "{{ item.product_sku }}"
                            }
                            {% endparse_json %}
                            <ins-button label="Remove" icon="icon-trash-2" size="small" class="cart-remove-btn" data='{{ remove_item }}' ></ins-button>
                            
                        </div> 
                    </div>        
                </div>                   
                <div class="spacer x-large"></div>
            </div>  
            
        {%- endfor -%}
        
    </div>
    <ins-loader
        id="shopping-cart-loader"
        state-title="Processing"
        state-message="Please wait, we're processing your data."
        state-icon="processing"
        style="display: none;">
    </ins-loader>
{%- else -%}

    {% if context.current_user %}

        <div id="shopping-cart-list" class="shopping-cart grid-x grid-padding-x grid-padding-y">
            <div class="small-12 cell">
                <ins-card steady class="empty-state">
                    <span>No Cart Items</span>
                </ins-card>
            </div>
        </div>

    {%- else -%}

        <div id="shopping-cart-items-wrap">
            {% comment %} Javascript generated content will be place here {% endcomment %}
        </div>        

    {%- endif -%}

{%- endif -%}
{%- if cartList.size > 0 -%}
    <h2>Cart Items</h2>
    <div class="spacer x-large"></div>
    <div id="shopping-cart-list" class="shopping-cart grid-y">
        {%- for item in cartList -%}          

            {% liquid 
                assign product = products | array_detect: uuid: item.product_uuid
                assign product_name = product.product_name

                ## to fix issues in comparing '' versus null
                if product.product_sku == null 
                    assign product = product | add_hash_key: 'product_sku', ''
                endif
                
                ## Check if the item is a product or a variant of the product
                if item.product_sku == product.product_sku
                    ## item is NOT a variant
                    assign selected_prop = product
                else 
                    ## item is a variant                
                    for variant in product.variants
                        if item.product_sku == variant.product_sku
                            assign selected_prop = variant
                        endif
                    endfor
                endif             

                if selected_prop.is_on_sale == true 
                    assign price = selected_prop.sale_price
                    assign price_strikethrough = selected_prop.regular_price
                else 
                    assign price = selected_prop.regular_price
                    assign price_strikethrough = ''
                endif          

                assign product_id = selected_prop.id
                assign item_total = price | times: item.quantity
                assign subtotal = subtotal | plus: item_total
            %}                                          

            <div id="cart-item-{{product_id}}" class="cart-item-wrap cell">
                {% if forloop.first == false %}
                    <hr>
                    <div class="spacer x-large"></div>
                {% endif %}
                <div class="grid-x" >
                    <div class="img-wrap" style="width:88px;">
                        {% if selected_prop.product_image.url %}
                            <img  src="{{ selected_prop.product_image.url }}" alt="{{ product.product_name }}" >
                        {% else %}
                            {% include 'modules/website/layout/placeholder_image', size: 'medium' %}
                        {% endif %}
                    </div>
                    <div class="flex-grow-1">
                        <h6>
                            {{ product_name }} 
                            {% if selected_prop.stock_level < 1 %}
                            <ins-tag label="Pre-Order" class='preorder-tag body-x-small' ></ins-tag>
                            {% endif %}
                        </h6> 
                        <p class="body-small">SKU: {{ item.product_sku }}</p>
                        <div class="spacer small"></div>
                        {% comment %} Get variant info {% endcomment %}
                        {% if item.product_sku != product.product_sku %}
                            {%  liquid 
                                ## Convert an array of strings into an array of objects
                                assign options = '' | split: ',' 
                                for option in selected_prop.product_options
                                    assign option_json = option | parse_json
                                    assign options = options | array_add: option_json
                                endfor
                            %}
                            {% for option in options %}
                                <p>
                                    <span class="body-x-small-bold">{{ option.product_option_label | titleize }}:</span>
                                    <span class="body-x-small">{{ option.product_option_value | titleize }}</span>
                                </p>
                            {% endfor %}
                        {% endif %}
                        <p>
                            <span class="body-x-small-bold">Price:</span>
                            <span class="body-x-small item-price">{{ price | pricify }}</span>
                            {% if selected_prop.is_on_sale == true %}
                            <span class="body-x-small strikethrough">{{ price_strikethrough | pricify }}</span>
                            {% endif %}
                        </p>
                    </div>
                    <div class="btn-wrap grid-y">
                        <p class="cart-price compute-price">{{ item_total | pricify }}</p>
                        <div class="spacer small"></div>
                        <ins-input-stepper
                            class="cart-stepper" 
                            data-product_uuid="{{ item.product_uuid }}"
                            data-product_sku="{{ item.product_sku }}"
                            value="{{ item.quantity }}" 
                            step="1" min="1" 
                            max="{{ selected_prop.stock_level  }}" 
                            small>
                        </ins-input-stepper>
                        <div class="spacer small"></div>
                        <div class="text-right" >
                            {% parse_json remove_item %}
                            {
                                "product_uuid": "{{ item.product_uuid }}",
                                "product_sku": "{{ item.product_sku }}"
                            }
                            {% endparse_json %}
                            <ins-button label="Remove" icon="icon-trash-2" size="small" class="cart-remove-btn" data='{{ remove_item }}' ></ins-button>
                            
                        </div> 
                    </div>        
                </div>                   
                <div class="spacer x-large"></div>
            </div>  
            
        {%- endfor -%}
        
    </div>
{%- else -%}
    <div id="shopping-cart-list" class="shopping-cart grid-x grid-padding-x grid-padding-y">
        <div class="small-12 cell">
            <ins-card steady class="empty-state">
                <span>No Cart Items</span>
            </ins-card>
        </div>
    </div>
{%- endif -%}
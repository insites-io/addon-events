---
metadata: {
    partial_name: 'Ecommerce | Stripe | Checkout Payment'
}
---
{% assign prop = form.properties %}

{%- liquid
    assign stripe_customer_id = blank
    assign customer_name = prop.order_contact_first_name | append: ' ' | append: prop.order_contact_last_name
    assign charge_to_this_card = false
-%}

{% comment %} Get Email {% endcomment %}
{%- liquid
    function has_profile = "modules/website/layout/check_if_user_has_profile" 
    if has_profile
        assign customer_email = context.current_user.email
    else
        assign customer_email = context.session.contact_email
    endif
-%}

{%- comment -%} 
    - STEP 1: Fetch user details and stripe customer information for logged-in users
{%- endcomment -%}
{%  liquid
    graphql stripe_customer = 'modules/portal/customers/get_user_stripe_id', email: customer_email | dig: 'items', 'results' | first

    if stripe_customer.id 
        assign stripe_customer_id = stripe_customer.profiles[0].stripe_id
        assign user_uuid = stripe_customer.external_id
        assign charge_to_this_card = prop.stripe_credit_card
    endif 
%}
   


    {%- comment -%} 
        - STEP 2: Prepare Stripe Charge API request with relevant details
    {%- endcomment -%}
    {% assign stripe_amount = prop.total_amount | times: 100 %}
    {% function stripe_settings = "modules/portal/stripe/get_stripe_settings" %}
    {% parse_json create_charge %}
    {
        "sk_key": "{{ stripe_settings.sk_key }}",
        "stripe_account_id": "{{ stripe_settings.account_id }}",
        "sk_key_insites": "{{ stripe_settings.sk_key }}",
        "idempotency_key": "{{ '' | uuid }}",
        "currency": "{{ currency }}",
        "amount": "{{ stripe_amount | advanced_format: '%.0f' }}",
        "customer": "{{ stripe_customer_id }}",
        {%- if charge_to_this_card -%}
            "source": "{{ charge_to_this_card }}",
        {%- endif -%}
        "description": "Insites Order ID: {{ form.id }} (Insites Customer UUID: {{ user_uuid }})",
        "metadata": {
            "Insites Order ID": "{{ form.id }}",
            "Insites Customer UUID": "{{ user_uuid }}",
            "Insites Company Name": "{{ prop.billing_company_name }}",
            "Insites Order": "https://{{ context.location.host }}/admin/insites#/ecommerce/orders/{{ prop.uuid }}"
        },
        "billing_details": {
            "name": "{{ customer_name }}",
            "email": "{{ customer_email }}"
        },
        "statement_descriptor": "{{ prop.statement_descriptor }}"
    }
    {% endparse_json %}

    {% log "=== START PROCESS: STRIPE PAYMENT ===" %} 

    {%- comment -%} 
        - STEP 3: Trigger the Stripe API to create the charge 
    {%- endcomment -%}
    {% graphql stripe_create_charge = 'modules/ecommerce/system/trigger_api_call', 
        name: "modules/portal/create_charge",
        data: create_charge 
        | dig: "items" | dig: "response" %}
        
    {%- assign payment_response = stripe_create_charge.body | parse_json -%}

    {% log "=== END PROCESS: STRIPE PAYMENT ===" %} 

    {% export payment_response %}


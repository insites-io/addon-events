---
name: order_success_workflow
delay: 0
enabled: true
trigger_condition: true
to: >
    {%- include 'modules/portal/emails/autoresponder_reply_to' -%}
from: >
    {%- include 'modules/insites_core/email_layout/workflow_from' -%}
reply_to: >
    {%- include 'modules/insites_core/email_layout/workflow_from' -%}
cc: 
bcc: 
subject: New ecommerce order 
layout: modules/insites_core/insites_internal_email_layout
---
{% assign order_uuid = data.order_info.properties.uuid | default: '' %}
{% assign order_id = data.order_info.id %}
{% assign order_reference = data.order_info.properties.order_reference %}
{% assign order_number = order_id |  append: '-' |  append: order_reference %}

{%- capture cta_link -%}
    {{ platform_context.host }}/admin/insites#/ecommerce/orders/{{ order_uuid }}
{%- endcapture -%}


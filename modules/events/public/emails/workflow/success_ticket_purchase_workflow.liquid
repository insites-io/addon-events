---
name: success_ticket_purchase_workflow
delay: 0
enabled: true
trigger_condition: true
to: >
    {%- include 'modules/portal/emails/autoresponder_reply_to' -%}
from: >
    {%- include 'modules/portal/emails/workflow_from' -%}
reply_to: >
    {%- include 'modules/portal/emails/workflow_from' -%}
cc: 
bcc: 
subject: New ticket order
layout: modules/insites_core/insites_internal_email_layout
metadata: {
    "email_name": "Success Ticket Order | Workflow"
}
---

{%- capture cta_link -%}
    {{ platform_context.host }}/admin/insites#/ecommerce/orders/{{ data.order_data.uuid }}
{%- endcapture -%}

{% include 'modules/events/emails/spacer_table_body', spaceSize: 56 %}

{% comment %} <!-- Heading --> {% endcomment %}
<table class="module" role="module" data-type="text" border="0" cellpadding="0"
cellspacing="0" width="100%" style="table-layout: fixed;"
data-muid="9a6f2278-aafa-434e-9a1f-1bb56840e20e">
    <tbody>
        <tr>
        <td style="padding:0px 40px 0px 40px; line-height:40px; text-align:inherit;"
            height="100%" valign="top" bgcolor="" role="module-content">
            <div>
            <div style="font-family: inherit; text-align: left"><span
                style="font-size: 32px; color: #0d0d0d"><strong>New Ticket Order</strong></span></div>
            <div></div>
            </div>
        </td>
        </tr>
    </tbody>
</table>

{% comment %} <!-- Spacer --> {% endcomment %}
{% include 'modules/events/emails/spacer_table_body', spaceSize: 40 %}

{% comment %} <!-- Content --> {% endcomment %}
<table class="module" role="module" data-type="text" border="0" cellpadding="0"
  cellspacing="0" width="100%" style="table-layout: fixed;">
  <tbody>
    <tr>
      <td style="padding:0px 40px 0px 40px; line-height:26px; text-align:inherit;"
        height="100%" valign="top" bgcolor="" role="module-content">
          <div style="font-family: inherit; text-align: inherit"><span
            style="white-space-collapse: preserve; text-wrap: wrap">A new ticket order has been placed with order number {{ data.order_data.id }} for the event <strong>"{{ data.event.name }}"</strong>.</span></div>
      </td>
    </tr>
</tbody>

{% comment %} <!-- Spacer --> {% endcomment %}
{% include 'modules/events/emails/spacer_table_body', spaceSize: 32 %}

{% comment %} <!-- Content --> {% endcomment %}
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td style="padding:0px 40px 0px 40px;">
      <p style="font-size:16px; line-height:26px; color:#525252; margin:0;">
        Click the button below to view the order in your instance admin.
      </p>
    </td>
  </tr>
</table>

{% comment %} <!-- Spacer --> {% endcomment %}
{% include 'modules/events/emails/spacer_table_body', spaceSize: 40 %}

{% comment %} <!-- View Button --> {% endcomment %}
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td height="100%" valign="top" role="module-content">
      <table style="width:100%;background:#FDFDFD;" cellpadding="0" cellspacing="0" border="0">
        <tr style="width:100%;">
          <td align="center" style="width:100%;border-radius:6px;padding:0px 40px;font-size:16px; text-align:center;">
            <table style="width:100%;background:#FDFDFD;" cellpadding="0" cellspacing="0" border="0">
              <tr style="width:100%;">
                <td align="center" style="width:100%;border-radius:6px;padding:0px 40px;font-size:16px; text-align:center; background-color:#3044FF">
                  <a href="{{- cta_link -}}" target="_blank"
                    style="background-color:#3044FF; border:0px solid #3044FF; border-radius:4px; border-width:0px; color:#ffffff; display:inline-block; font-size:16px; font-weight:600; letter-spacing:0px; line-height:normal; padding:16px 0px 16px 0px; text-align:center; text-decoration:none; border-style:solid; font-family:inherit; width:100%;" 
                    >View Order</a>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>  

{% comment %} <!-- Spacer --> {% endcomment %}
{% include 'modules/events/emails/spacer_table_body', spaceSize: 40 %}


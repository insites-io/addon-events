      <p style="font-size:16px; color:#525252; margin:0;">
        Or, paste this link into your browser:
      </p>
    </td>
  </tr>
</table>

{% comment %} <!-- Spacer --> {% endcomment %}
{% include 'modules/events/emails/spacer_table_body', spaceSize: 8 %}

{% comment %} <!-- Link: Browser link --> {% endcomment %}
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td style="padding:0px 40px 0px 40px;">
      <p style="font-size:14px; line-height:22px; color:#3044ff; margin:0;">
        {{- cta_link -}}
      </p>
    </td>
  </tr>
</table>



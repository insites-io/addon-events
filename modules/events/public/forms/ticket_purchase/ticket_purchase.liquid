---
name: ticket_purchase
resource: modules/insites_ecommerce/order
resource_owner: anyone
redirect_to: /purchase-ticket
flash_alert: Error-PayBill
flash_notice: Success-PayBill
fields:
  properties:
    order_reference:    
      validation: 
        presence:
          message: Order Reference Number is required  
    subtotal_amount:    
      validation: 
        presence:  
          message: Minimum of 1, maximum of 983283.99
    uuid:
      validation: 
        presence: true
    total_tax_amount:    
      validation: 
        presence:
          message: Tax Amount is required  
    currency:    
      validation: 
        presence: true
    date_time:    
      validation: 
        presence: true

    total_amount:    
      validation: 
        presence: true
    total_discount_amount:    
      validation: 
        presence: true
    order_status:
    order_payment_status:
    order_shipping_status:
    notes:
    ticket_type: 
      validation: 
        presence:
          message: Please select a ticket
      property_options:
        virtual: true
    ticket_qty: 
      validation: 
        presence:
          message: Please select a quantity
      property_options:
        virtual: true
    capacity_per_group:
      validation: 
        presence: true
      property_options:
        virtual: true
    ticket_type_name:
      validation: 
        presence: true
      property_options:
        virtual: true
    ticket_orig_price:
      validation: 
        presence: true
      property_options:
        virtual: true
    ticket_orig_price_group:
      validation: 
        presence: true
      property_options:
        virtual: true
    venue_name:
      validation: 
        presence: true
      property_options:
        virtual: true
    venue_uuid:
      validation: 
        presence: true
      property_options:
        virtual: true
    event_uuid:
      validation: 
        presence: true
      property_options:
        virtual: true
    ticket_group_capacity:
      validation: 
        presence: true
      property_options:
        virtual: true

    # Other Details 
    stripe_credit_card:
      property_options:
          virtual: true   
          
    # DISCOUNT 
    discount_id:
      property_options:
          virtual: true
    discount_name:
      property_options:
          virtual: true      
    discount_usage_count:
      property_options:
          virtual: true    
          
    # Additional details for Events
    event_name:
      property_options:
          virtual: true
    event_reference:
      property_options:
          virtual: true
    event_start_date:
      property_options:
          virtual: true
    event_start_time:
      property_options:
          virtual: true
    event_location:
      property_options:
          virtual: true
    calendar_invitation:
      property_options:
          virtual: true
    event_region:
      property_options:
        virtual: true

default_payload: >
  {% graphql current_user = 'modules/client/account/get_current_user' | dig: 'current_user' %}

  {% assign crm_contact = current_user.crm_contact | first %}
  {% assign client = current_user.client | first %}

  {% function settings = "modules/client/pay_bills/get_settings" %}
  {%  assign uuid =  '' | uuid %}
  {
    "properties_attributes":{
        "user_id": "{{ context.current_user.id }}",
        "user_uuid": "{{ current_user.external_id }}",
        "company_uuid": "{{ client.company_uuid }}",
        "currency": "{{ settings.currency }}",
        "date_time": "{{ 'now' | date: '%Y-%m-%dT%H:%M:%S'}}",
        "is_enabled": true,
        "order_status": "Open",
        "order_payment_status": "Pending Funds",
        "shipping_status": "Not Applicable"
    }
  }  
callback_actions: >
  {%- include 'modules/client/pay_bills/callback_init', 
      context: context,
      form: form -%}      
---



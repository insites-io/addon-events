---
slug: api/add-password
format: json
method: put
searchable: false
---

{%- assign payload = context.params | parse_json -%}
{%- assign status = 400 -%}
{%- assign errors = "" -%}

{%- assign password = payload.password | base64_url_safe_decode -%}

{%- graphql user = "modules/portal/account/get_user_by_email" email: payload.email | dig: "items","results" | first -%}

{%- if user.id -%}
    {%- comment -%} Generate temporary token {%- endcomment -%}
    {%- graphql temporary_token = 'modules/portal/account/generate_user_temporary_token',
          email: payload.email | dig: 'items','results' | first -%}

    {%- comment -%} Create portal profile: 'modules/portal/portal' {%- endcomment -%}
    {%- graphql create_user_profile = 'modules/portal/account/create_user_profile',
          id: user.id, token: temporary_token.temporary_token, is_enabled: true, primary_account_holder: true -%}

    {%- comment -%} Set password {%- endcomment -%}
    {%- graphql create_user_password = 'modules/events/account/create_user_password', id: user.id, password: password -%}

    {%- comment -%} Clear guest event_guest_temp_uuid from notes now that the account is created {%- endcomment -%}
    {%- parse_json clear_notes_data -%}
    {
      "uuid": "{{ user.uuid }}",
      "email": "{{ user.email }}",
      "notes": ""
    }
    {%- endparse_json -%}
    {%- function clear_notes_result = "crm/controller/contacts/update", uuid: user.uuid, params: clear_notes_data -%}
{%- else -%}
    {%- assign errors = "Email address not found" -%}
{%- endif -%}

{%- if create_user_password.user_update.id -%}
    {%- assign errors = "" -%}
{%- else -%}
    {%- assign errors = "Failed to create password" -%}
{%- endif -%}

{%- if errors != "" -%}
{%- parse_json data -%}
{
  "has_error": true,
  "message":  "{{ errors }}"
}
{%- endparse_json -%}
{%- else -%}
{%- parse_json data -%}
{
  "has_error": false,
  "message": "Account successfully created"
}
{%- endparse_json -%}
{%- assign status = 200 -%}
{%- endif -%}

{{ data }}
{%- response_status status -%}

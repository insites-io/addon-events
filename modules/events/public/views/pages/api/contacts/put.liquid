---
slug: api/update-contact
format: json
method: put
searchable: false
---

{%- assign payload = context.params | parse_json -%}

{% comment %} Convert email to lowercase {% endcomment %}
{%- assign email = payload.email | downcase -%}
{%- assign payload = payload | add_hash_key: "email", email -%}


{%- assign status = 400 -%}


{%- if context.current_user -%}
     {%- comment -%} Logged-in user {%- endcomment -%}
     {%- assign user_uuid = context.current_user.external_id -%}
{%- else -%}
     {%- comment -%} Guest user {%- endcomment -%}
     {%- assign user_uuid = payload.user_uuid -%}
     {%- function event_guest_temp_uuid = 'modules/events/users/get_user_uuid' -%} 
{%- endif -%}


{% comment %} 
     Use selected billing_address_uuid as default_address_uuid 
     — updates the default address shown on the /my-details portal page.
{% endcomment %}
{%- if context.current_user -%}
     {%- assign default_address_uuid = payload.billing_address_uuid -%}
{%- else -%}
     {%- assign default_address_uuid = context.session.default_address_uuid -%}

     {% comment %} Add event_guest_temp_uuid to notes to be able to edit the contact later while in guest mode {% endcomment %}
     {%- assign payload = payload | add_hash_key: "notes", event_guest_temp_uuid -%}
{%- endif -%}
{%- assign payload = payload | add_hash_key: "default_address_uuid", default_address_uuid -%}

{%- comment -%} Update contact {%- endcomment -%}
 {%- function update_contact = "crm/controller/contacts/update", uuid: user_uuid, params: payload -%}


 {%- comment -%} Save to session for later use {%- endcomment -%}
 {%- session event_guest_id = update_contact.id -%}
 {%- session event_guest_uuid = update_contact.uuid -%}


{% comment %} Guest user: Update Address  {% endcomment %}
{%- if context.current_user == null -%}
     {%- parse_json update_address_data -%}
     {
          "address.uuid" : "{{ context.session.default_address_uuid }}",
          "address_label" : "Billing",
          "address_1" : "{{ payload.billing_address_1 }}",
          "address_2" : "{{ payload.billing_address_2 }}",          
          "state" : "{{ payload.billing_state }}",
          "suburb" : "{{ payload.billing_suburb }}",
          "country" : "{{ payload.billing_country }}",          
          "postcode" : "{{ payload.billing_postcode }}"
     }
     {%- endparse_json -%}
     {%- function data = "crm/controller/addresses/update", type: "contact", uuid: context.session.default_address_uuid, params: update_address_data -%}     
{%- endif -%}     


{% comment %} Check if profile portal exists {% endcomment %}
{%- graphql user = 'modules/events/account/check_user_email', email: email | dig: 'items', 'results' | first  -%}
{%- assign portal_profile = user| dig: 'portal' | first -%}

{%- if portal_profile.id == null or portal_profile.id == '' or portal_profile.id == nil -%}
     {%- comment -%} Generate temporary token {%- endcomment -%}
     {%- graphql temporary_token = 'modules/portal/account/generate_user_temporary_token', 
          email: email | dig: 'items','results' | first -%}

     {% comment %} Create user profile: 'modules/portal/portal' {% endcomment %}
     {%- graphql create_user_profile = 'modules/portal/account/create_user_profile', 
          id: update_contact.id, token: temporary_token.temporary_token, is_enabled: true, primary_account_holder: true -%}
{%- endif -%}


{% comment %} Update sessions {% endcomment %}
{% include 'modules/events/ticket/ticket_purchase_sessions', payload: payload %} 


{%- comment -%} Set Status {%- endcomment -%}
{%- if update_contact.id -%}  
     {%- assign status = 200 -%}
{%- endif -%}


{% comment %} Guest user: Add is_guest flag to update_contact {% endcomment %}
{%- unless context.current_user -%}
     {%- assign update_contact = update_contact | add_hash_key: 'is_guest', 'true' -%}
{%- endunless -%}


{{ update_contact  }}
{%- response_status status -%}
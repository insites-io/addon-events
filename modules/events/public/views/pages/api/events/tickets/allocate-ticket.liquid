---
slug: api/allocate-ticket
format: json
method: put
searchable: false
---

{%- assign payload = context.params | parse_json -%}
{%- assign status = 400 -%}
{%- assign errors = "" -%}

{%- assign ticketData = payload.ticketData | parse_json -%}
{%- assign event_uuid = payload.eventUUID -%}
{%- assign ticket_uuid = payload.ticketUUID -%}

{%- comment -%}
  assign_contact controller always writes purchased_by_uuid (nulls it if absent),
  so re-send the current buyer's uuid to preserve ticket ownership.
{%- endcomment -%}
{%- if context.current_user -%}
    {%- assign purchased_by_uuid = context.current_user.external_id -%}
{%- else -%}
    {%- assign purchased_by_uuid = context.session.event_guest_uuid -%}
{%- endif -%}

{%- comment -%}
  Ownership check: the ticket identified by ticket_uuid must have been purchased by the
  caller. Without this, a caller could pass any ticketUUID and re-allocate it — and since
  assign_contact rewrites purchased_by_uuid, even steal ownership of someone else's ticket.
{%- endcomment -%}
{%- graphql ticket_owner = 'modules/events/event_tickets/get_ticket_by_uuid', uuid: ticket_uuid | dig: 'items', 'results' | first -%}

{%- if purchased_by_uuid == blank or ticket_owner == nil or ticket_owner.purchased_by_uuid != purchased_by_uuid -%}
{
    "has_error": true,
    "message": "Ticket not found."
}
{%- response_status 403 -%}
{%- else -%}

{%- assign ticketData = ticketData | add_hash_key: "purchased_by.uuid", purchased_by_uuid -%}

{%- comment -%} Use the ticket's own event from the DB, not the body-supplied eventUUID {%- endcomment -%}
{%- assign event_uuid = ticket_owner.event_uuid -%}

{% function allocate_ticket = "events/event_tickets/assign_contact", uuid: ticket_uuid, event_uuid: event_uuid, params: ticketData %}

{% if allocate_ticket.errors  %}
    {% assign errors = allocate_ticket %}
{% endif %}

{%- assign data = '{}' | parse_json -%}

{%- if errors != "" -%}
    {% assign data = data | add_hash_key: "has_error", true %}
    {% assign data = data | add_hash_key: "message", errors %}
{%- else -%}
    {% assign data = data | add_hash_key: "has_error", false %}
    {% assign data = data | add_hash_key: "message", "Ticket successfully allocated" %}
    {% assign data = data | add_hash_key: "data", allocate_ticket %}
    {%- assign status = 200 -%}
{%- endif -%}

{{ data }}

{%- response_status status -%}

{%- endif -%}
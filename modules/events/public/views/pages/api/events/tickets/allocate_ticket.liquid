---
slug: api/allocate-ticket
format: json
method: put
searchable: false
---

{%- assign payload = context.params | parse_json -%}
{%- assign status = 400 -%}
{% assign errors = "" %}


{%- assign ticketData = payload.ticketData | parse_json -%}
{%- assign event_uuid = payload.eventUUID -%}
{%- assign ticket_uuid = payload.ticketUUID -%}

{% assign ticketPayload = '{}' | parse_json %}
{% assign data = '{}' | parse_json %}
{% assign ticketPayload = ticketPayload | add_hash_key: "event_uuid", event_uuid %}
{% assign ticketPayload = ticketPayload | add_hash_key: "ticket_uuid", ticket_uuid %}
{% assign ticketPayload = ticketPayload | add_hash_key: "data", ticketData %}

{%- graphql allocate_ticket = 'modules/website/trigger_api_call', 
     name: 'modules/events/update_ticket', 
     data: ticketPayload 
     | dig: 'items','response','body' | parse_json -%}   
     
{% if allocate_ticket.errors  %}
    {% assign errors = allocate_ticket %}
{% endif %}     


{% log errors %}
{%- if errors != "" -%}
    {% assign data = data | add_hash_key: "has_error", true %}
    {% assign data = data | add_hash_key: "message", errors %}
{%- else -%}
    {% assign data = data | add_hash_key: "has_error", false %}
    {% assign data = data | add_hash_key: "message", "Ticket(s) successfully allocated" %}
    {% assign data = data | add_hash_key: "data", allocate_ticket %}
    {%- assign status = 200 -%}
{%- endif -%}

{{ data }}

{% comment %} {{ add_order  }} {% endcomment %}
{%- response_status status -%}
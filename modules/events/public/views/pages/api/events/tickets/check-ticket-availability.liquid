---
slug: api/check-ticket-availability
format: json
method: get
searchable: false
---

{%- assign payload = context.params | parse_json -%}
{%- assign status = 400 -%}


{% comment %} Validate tickets availability; Export: errors {% endcomment %}
{%- include 'modules/events/purchase_ticket/check_ticket_availability', payload: payload -%}
{%- assign errors = context.exports.errors -%}


{% comment %} Session will be saved to revalidate ticket availability in the payment step {% endcomment %}
{%- liquid
    assign tickets_selected_type = context.session.tickets_selected | type_of 

    if context.session.tickets_selected[payload.eventuuid] or tickets_selected_type == 'Hash'
      ## Session already exists
      assign tickets_selected = context.session.tickets_selected
    else
      ## Session does not exist yet
      assign tickets_selected = '{}' | parse_json
    endif

    assign tickets_selected = tickets_selected | add_hash_key: payload.eventuuid, payload
    session tickets_selected = tickets_selected
-%}


{%- if errors != '' -%}
{
  "has_error": true,
  "message": "{{ errors | strip }}"
}
{%- else -%}
{%- assign status = 200 -%}
{
  "has_error": false,
  "message": "All tickets are available ok"
}
{%- endif -%}

{%- response_status status -%}
---
slug: api/create-tickets
format: json
method: post
searchable: false
---

{%- assign payload = context.params | parse_json -%}
{%- assign status = 400 -%}
{% assign errors = "" %}


{%- assign ticketData = payload.ticketData | parse_json -%}
{%- assign event_uuid = payload.eventuuid -%}
{% assign ticketPayload = '{}' | parse_json %}
{% assign data = '{}' | parse_json %}
{% assign ticketPayload = ticketPayload | add_hash_key: "uuid", event_uuid %}
{% assign ticketPayload = ticketPayload | add_hash_key: "data", ticketData %}

{% function add_tickets = "events/event_tickets/create", params: ticketPayload %}

{% if add_tickets.errors  %}
    {% assign errors = add_tickets %}
{% endif %}     

{%- if errors != "" -%}
    {% assign data = data | add_hash_key: "has_error", true %}
    {% assign data = data | add_hash_key: "message", errors %}
{%- else -%}
    {% assign data = data | add_hash_key: "has_error", false %}
    {% assign data = data | add_hash_key: "message", "Ticket(s) successfully created" %}
    {% assign data = data | add_hash_key: "data", add_tickets %}
    {%- assign status = 200 -%}
{%- endif -%}

{{ data }}

{%- response_status status -%}
---
slug: api/create-tickets
format: json
method: post
searchable: false
---

{%- assign payload = context.params | parse_json -%}
{%- assign status = 400 -%}
{% assign errors = "" %}


{% comment %} Get user_uuid {% endcomment %}
{%- if context.current_user -%}
    {%- comment -%} Logged-in user {%- endcomment -%}
    {%- assign user_uuid = context.current_user.external_id -%}
{%- else -%}
    {%- comment -%} Guest user {%- endcomment -%}
    {%- assign user_uuid = context.session.guest_uuid -%}
{%- endif -%}

{% comment %} Inject purchased_by.uuid (user_uuid) into ticketData {% endcomment %}
{%- assign tempTicketData = payload.ticketData | parse_json -%}
{%- assign ticketData = '' | split: ',' -%}
{%- for ticket in tempTicketData -%}
    {% assign ticket = ticket | add_hash_key: "purchased_by.uuid", user_uuid %}
    {% assign ticketData = ticketData | array_add: ticket %}
{% endfor %}


{%- assign event_uuid = payload.eventuuid -%}
{% assign ticketPayload = '{}' | parse_json %}
{% assign data = '{}' | parse_json %}
{% assign ticketPayload = ticketPayload | add_hash_key: "uuid", event_uuid %}
{% assign ticketPayload = ticketPayload | add_hash_key: "data", ticketData %}

{% function add_tickets = "events/event_tickets/create", event_uuid: ticketPayload.uuid, params: ticketPayload.data %}

{% if add_tickets.errors  %}
    {% assign errors = add_tickets %}
{% endif %}     

{%- if errors != "" -%}
    {% assign data = data | add_hash_key: "has_error", true %}
    {% assign data = data | add_hash_key: "message", errors %}
{%- else -%}
    {% assign data = data | add_hash_key: "has_error", false %}
    {% assign data = data | add_hash_key: "message", "Ticket(s) successfully created" %}
    {% assign data = data | add_hash_key: "data", add_tickets %}
    {%- assign status = 200 -%}
{%- endif -%}

{{ data }}

{%- response_status status -%}
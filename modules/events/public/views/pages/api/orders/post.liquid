---
slug: api/create-order
format: json
method: post
searchable: false
---

{%- assign payload = context.params | parse_json -%}

{%- comment -%} Revalidate if tickets are still available; Export: errors {%- endcomment -%}
{%- include 'modules/events/purchase_ticket/check_ticket_availability', payload: context.session.tickets_selected[payload.event_uuid] -%}
{%- assign ticket_availability_error = context.exports.errors -%}


{%- assign status = 400 -%} 

{%- if ticket_availability_error == '' -%}
              
     {%- assign errors = "" -%}

     {%- assign payload = payload | add_hash_key: "is_use_crm_billing_address", true -%}
     

     {% comment %} billing_contact_uuid {% endcomment %}
     {%- if context.current_user and payload.is_billing_same_with_contact == true -%}
          {%- assign payload = payload | add_hash_key: "billing_contact_uuid", context.current_user.external_id -%}     
     {%- elsif payload.is_billing_same_with_contact == true -%}
          {%- assign payload = payload | add_hash_key: "billing_contact_uuid", context.session.event_guest_uuid -%}     
     {%- endif -%}

     {% comment %} Guest purchase: order_company_uuid, billing_company_uuid {% endcomment %}
     {%- if context.current_user == null -%}
          {%- assign payload = payload | add_hash_key: "order_company_uuid", context.session.event_guest_company_uuid -%}
          {%- if payload.is_billing_same_with_contact == true -%}
               {%- assign payload = payload | add_hash_key: "billing_company_uuid", context.session.event_guest_company_uuid -%}
          {%- endif -%}
     {%- endif -%}

     {% comment %} Additional Payload {% endcomment %}
     {%- assign uuid = '' | uuid -%}
     {%- assign date_time = "now" | date: "%Y-%m-%dT%H:%M:%SZ" -%}
     {%- assign payload = payload | add_hash_key: "order_reference", uuid -%}
     {%- assign payload = payload | add_hash_key: "date_time", date_time -%}
     {%- assign payload = payload | add_hash_key: "order_status", "placed" -%}
     {%- assign payload = payload | add_hash_key: "order_payment_status", "unpaid" -%}     
     {%- assign payload = payload | add_hash_key: "currency", "AUD" -%}
     

     {% comment %} Computed Prices {% endcomment %}
     {%- function computed = "modules/events/purchase_ticket/compute_prices", data: payload -%} 

     {% comment %} Prices Payload {% endcomment %}
     {%- assign payload = payload | add_hash_key: "subtotal_amount", computed.subtotal_amount -%}
     {%- assign payload = payload | add_hash_key: "processing_fee", computed.processing_fee -%}
     {%- assign payload = payload | add_hash_key: "total_tax_amount", computed.total_tax_amount -%}
     {%- assign payload = payload | add_hash_key: "total_amount", computed.total_amount -%}
     {%- assign payload = payload | add_hash_key: "total_amount_paid", computed.total_amount_paid -%}
     {%- assign payload = payload | add_hash_key: "total_discount_amount", computed.total_discount_amount -%}
     {%- assign payload = payload | add_hash_key: "total_shipping_amount", computed.total_shipping_amount -%}
     

     {%- comment -%} Create order {%- endcomment -%}
     {% function add_order = "ecommerce/controller/order/create", params: payload %}   

     {%- if add_order.id -%}
          {%- include 'modules/events/orders/callback_init', 
               payload: payload,
               order_data: add_order -%}   
          {%- assign errors = context.session.paybill_error -%}
     {%- else -%}
          {%- assign errors = add_order -%}
     {%- endif -%}
     
     {%- if errors != nil -%}
     {
     "has_error": true,
     "message": {{ errors }}
     }
     {%- else -%}
     {
     "has_error": false,
     "message": "Order successfully created",
     "data": {{ add_order  }}
     }
     {%- session order_uuid = add_order.uuid -%}
     {%- session last_purchased_user_uuid = add_order.order_contact.uuid -%}
     {%- assign status = 200 -%}
     {%- endif -%}

{%- else -%}
{
  "has_ticket_availability_error": true,
  "message": "{{ ticket_availability_error }}"
}
{%- endif -%}

{%- response_status status -%}
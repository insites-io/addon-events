---
slug: api/create-order
format: json
method: post
searchable: false
---

{%- assign payload = context.params | parse_json -%}

{%- comment -%} Revalidate if tickets are still available; Export: errors {%- endcomment -%}
{%- include 'modules/events/purchase_ticket/check_ticket_availability', payload: context.session.tickets_selected[payload.event_uuid] -%}
{%- assign ticket_availability_error = context.exports.errors -%}


{%- assign status = 400 -%} 

{%- if ticket_availability_error == '' -%}
              
     {%- assign errors = "" -%}

     {%- comment -%} Create order {%- endcomment -%}
     {%- graphql add_order = 'modules/website/trigger_api_call', 
          name: 'modules/events/add_order', 
          data: payload 
          | dig: 'items','response','body' | parse_json -%}            

     {%- if add_order.id -%}
          {%- include 'modules/events/orders/callback_init', 
               payload: payload,
               order_data: add_order -%}   
          {%- assign errors = context.session.paybill_error -%}
     {%- else -%}
          {%- assign errors = add_order -%}
     {%- endif -%}
     
     {%- if errors != nil -%}
     {
     "has_error": true,
     "message": {{ errors }}
     }
     {%- else -%}
     {
     "has_error": false,
     "message": "Order successfully created",
     "data": {{ add_order  }}
     }
     {%- session order_uuid = add_order.uuid -%}
     {%- session last_purchased_user_uuid = add_order.order_contact.uuid -%}
     {%- assign status = 200 -%}
     {%- endif -%}

{%- else -%}
{
  "has_ticket_availability_error": true,
  "message": "{{ ticket_availability_error }}"
}
{%- endif -%}

{%- response_status status -%}
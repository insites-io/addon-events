---
slug: itinerary-upcoming
layout: modules/portal/portal_default
searchable: true
max_deep_level: 2
metadata: {
    "status": "published",
    "page_type": "content", 
    "page_name": "Upcoming Events | Insites",
    "page_title": "Upcoming Events | Insites",
    "meta_title": "Upcoming Events | Insites" 
}
dynamic_cache:
  layout: true
  key: |-
    {%- parse_json models -%}
    [
      "modules/insites_cms/global",
      "modules/insites_core/localisation",
      "modules/insites_events/event",
      "modules/insites_events/venue",      
      "modules/insites_events/event_speaker",
      "modules/insites_events/event_sponsor",
      "modules/insites_events/event_faq"
    ]
    {%- endparse_json -%}
    {%- include "modules/website/cache/generate_cache_key", models: models -%}
    {{context.current_user.id}}
---

{% graphql user_event_uuids = "modules/events/event_tickets/get_user_event_tickets", 
     contact_uuid: context.current_user.external_id | dig: 'items','results' | map: 'event_uuid' %}

{% if context.params.slug2 %}
    {% comment %} Details view {% endcomment %}

    {% include 'modules/events/events/details/upcoming' %}

{% else %}
    {% comment %} List view {% endcomment %}

    <h1 class="heading-1-xsmall">Upcoming Events</h1>
    <div class="spacer"></div>
    <p>Your go-to spot for a complete list of your purchased tickets and all the details for upcoming events.</p>
    <div class="spacer xxx-large"></div>

    <div class="portal-wrapper">
     {% include 'modules/events/events/list/list', page: 'itinerary-upcoming', user_event_uuids: user_event_uuids %}
    </div>

{% endif  %}
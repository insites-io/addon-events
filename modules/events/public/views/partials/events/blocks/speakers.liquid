---
metadata: {
    partial_name: 'Events | Blocks | Speakers'
}
---

{% parse_json params %}
{
     "page" : 1,
     "size" : 50,
     "sort_by" : "speaker_weighting",     
     "sort_order" : "ASC"
}
{% endparse_json %}
{% function event_speakers = "events/event_speakers/list", uuid: event.uuid, params: params  %}

{% assign speakers = event_speakers.results %}
     
{% if speakers.size > 0 %}

     <section class="event-speakers wrapper width-1296">
          <h2 class="heading-2-xsmall">Speakers</h2>
          <div class="spacer"></div>
          <div class="grid-x grid-padding-x grid-padding-y event-card-wrap">

               {% for item in speakers %}

                    {% comment %} Add no-content class when empty to unset the cursor pointer {% endcomment %}
                    {% assign no_content = '' %}
                    {% if item.content == blank or item.content == '' %}
                         {% assign no_content = 'no-content' %}
                    {% endif %}

                    <div class="cell large-3 medium-6 small-12 {{ no_content }}" data-id="{{item.id}}"{% unless no_content == 'no-content' %} role="button" tabindex="0" aria-label="View bio for {{ item.first_name }} {{ item.last_name }}"{% endunless %}>
                         <div class="img-wrap">
                              {% if item.image.url %}
                                   <img src="{{ item.image.url | replace: ' ', '%20' | escape }}" loading="lazy" decoding="async" width="270" height="280" alt="{{ item.first_name }} {{ item.last_name }}">
                              {% else %}
                                   {% include 'modules/website/layout/placeholder_image', size: 'medium' %}
                              {% endif %}
                         </div>
                         <div class="spacer"></div>
                         <h3 class="heading-5">{{ item.first_name}} {{ item.last_name}}</h3>
                         <div class="spacer x-small"></div>                         

                         {% comment %} Job Title {% endcomment %}
                         {% liquid 
                              assign job_title = ''
                              if item.job_title and item.job_title != ''
                                   assign job_title = item.job_title
                              endif
                         %}

                         {% comment %} Company {% endcomment %}
                         {%   liquid
                              assign company_text = ''

                              if item.company_name and item.company_name != ''
                                   assign company_text = item.company_name
                              endif              

                              if job_title != '' and company_text != ''
                                   assign company_text = company_text | prepend: 'at '
                              endif
                         %}
                         <p class="body-small">{{ job_title }} {{ company_text }}</p>
                    </div>
               {% endfor %}

          </div>
     </section>
     <div class="spacer xxxx-large"></div>

     <ins-modal
          id="speaker-modal"
          class="event-speakers event-modal"
          heading=""
          full-height
          with-backdrop
          no-button>
          <div>
               <div class="spacer"></div>
               <div id="speaker-content"></div>
          </div>
     </ins-modal>

     {% comment %} Modal Script {% endcomment %}
     <script id="speakers-data" type="application/json">
     {
          "speakers": {{ speakers | default: '[]' | parse_json }}
     }
     </script>
     {% if context.environment == "staging" %}
          <script src="{{ 'modules/events/scripts/event-speakers.js' | asset_url }}" defer></script>
     {% else %}
          <script src="{{ 'modules/events/scripts/event-speakers.min.js' | asset_url }}" defer></script>
     {% endif %}  

{% endif %}
---
metadata: {
    partial_name: 'Events | Details | Banner'
}
---

<div class="wrap event-details" >
     <div class="img-wrap">
          {% if event.event_image.url %}
               <img src="{{ event.event_image.url | replace: ' ', '%20' | escape }}" decoding="async" width="920" height="585" alt="{{ event.event_name }}">
          {% else %}
               {% include 'modules/website/layout/placeholder_image', size: 'medium' %}
          {% endif %}
     </div>
</div>
<div class="spacer xxxx-large hide-for-small-only"></div>
<div class="spacer xxx-large show-for-small-only"></div>
---
metadata: {
    partial_name: 'Events | Details | Upcoming'
}
---

{% if context.params.slug2 and context.params.slug2 != '' %}
    {% graphql event = 'modules/events/events/get_event', slug: context.params.slug2 | dig: 'items','results' | first %}
{% endif %}

{% if event.id == null %}
     {% redirect_to '/404' %}
{% endif %}


{% comment %} Banner {% endcomment %}
{% include 'modules/events/events/details/banner', event: event %}


{% comment %} Main details {% endcomment %}
{% include 'modules/events/events/details/details', event: event %}


{% comment %} Speakers {% endcomment %}
{% include 'modules/events/events/blocks/speakers', event: event %}


{% comment %} Sponsors {% endcomment %}
{% include 'modules/events/events/blocks/sponsors', event: event %}


{% comment %} FAQ {% endcomment %}
{% if event.is_faqs_displayed == true %}
     {% include 'modules/events/events/blocks/faq', event: event %}
{% endif %}


{% comment %} Get tickets (mobile) {% endcomment %}
{% assign event_url = "/ticket-purchase?event=" | append: event.uuid %}
{% include 'modules/events/events/get_tickets_card', is_mobile: true, event_url: event_url %}
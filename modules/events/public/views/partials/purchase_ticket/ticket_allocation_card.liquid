{% comment %} ? GET DETAILS EVENT AND UUID OF LOGGED IN USER {% endcomment %}
 {% if context.params == 'purchase-ticket' %}
    {% assign event_uuid = context.params.event %}
{% else %}
    {% assign event_uuid = event.uuid %}
 {% endif %}

<input hidden type="hidden" id="event_uuid" value="{{ event_uuid }}">
{% assign contact_uuid = context.current_user.external_id %}

{% comment %} ? GET ALL ORDERS USING LOGGED IN USER'S CONTACT UUID {% endcomment %}
{%- graphql get_orders_by_contact_uuid = 'modules/client/events/orders/get_orders_by_contact_uuid', order_contact_uuid: contact_uuid | dig: 'items', 'results' -%}

{% comment %} ? FOR EMPTY STATE {% endcomment %}
{% assign ticket_count = false %}

{% comment %} ? Get System Fields {% endcomment %}
{%- function system_field_names =  "modules/insites_events/controllers/utilities/advanced_filters/get_filter_options" -%}
{% assign filter_options = '{}' | parse_json %}
{% for filter_option in system_field_names %}
    {% assign _data = '{}' | parse_json %}
    {% capture var %}filter-{{ forloop.index }}{% endcapture %}
    {% assign filter_options = filter_options | add_hash_key: var, _data %}
    {% assign filter_options[var] = filter_options[var] | add_hash_key: "field_name", filter_option[0] %}
    {% if filter_option[1].options != blank %}
        {% assign filter_options[var] = filter_options[var] | add_hash_key: "field_options", filter_option[1].options | parse_json %}
    {% endif %}

    {% comment %} ? Get ticket packages {% endcomment %}
    {% if filter_options[var].field_name == "Ticket Packages" %}
        {% assign ticket_groups = filter_options[var] %}
    {% endif %}
{% endfor %}

{% comment %} ? Isolate ticket group label {% endcomment %}
{% assign system_field_arr = event.system_fields_uuids %}
{% assign ticket_system_field  =  ticket_groups.field_options  %}

{% for object in ticket_system_field %}
  {% if system_field_arr contains object.uuid %}
    {% assign found = true %}
    {% assign ticket_group = object %}
    {% break %}
  {% endif %}
{% endfor %}

{% comment %} ? System Field Label {% endcomment %}
{% assign ticket_group_label = ticket_group.value %}

{% comment %} ? LOOP ORDERS: RELATE TO CONTACT UUID OF LOGGED IN USER {% endcomment %}
{% for ticket_uuid in get_orders_by_contact_uuid %}
 
    {% comment %} ? GET ALL EVENT TICKETS FROM ORDERS {% endcomment %}
    {%- graphql get_event_tickets_from_orders = 'modules/client/events/tickets/get_event_tickets_from_orders', uuid: ticket_uuid.id, event_uuid: event_uuid | dig: 'items', 'results' -%}

    {% comment %} ? CHECK IF TICKETS IS RELATED TO ORDER {% endcomment %}
    {% assign ticket_size = get_event_tickets_from_orders | size %}
    {% if ticket_size > 0 %}

        {% comment %} ? FOR EMPTY STATE {% endcomment %}
        {% assign ticket_count = true %}

        {% comment %} ? TICKET DETAILS {% endcomment %}
        <div class="spacer xxx-large"></div>
        <label class="heading-2-xsmall">Ticket Details</label>
        <div class="spacer"></div>

        {% comment %} ? LABEL AND COUNT OF TICKET TYPE {% endcomment %}
        {% for ticket_type in get_event_tickets_from_orders limit:1 %}
            <span class="paragraph-body-title-case">
                {% if ticket_type.ticket_type == "individual" %}
                    {{ ticket_uuid.order_item.quantity }} x Individual Ticket
                {% else %}
                    {{ ticket_uuid.order_item.quantity }} x {{ ticket_group_label | default: "Group Tickets"}} 
                {% endif %}
            </span>
            {% comment %} ? GUEST DETAILS {% endcomment %}
            <div class="spacer xxx-large"></div>
            <label class="heading-2-xsmall">Guest Details</label>
            {% comment %} ? Ticket payment integration  {% endcomment %}
            {%- if context.params.forAllocation == "true" -%}
                {% if ticket_type.allocation_status == 'unallocated' %}
                    <div class="spacer"></div>
                    <p>Know who's coming? You can allocate tickets and personalise them now, or skip this step and do it later in the portal.</p>
                {% endif %}
            {% endif %}
            <div class="spacer"></div>

        {% endfor %}



    {% endif %}

    {% comment %} ? LOOP TICKETS: RELATE TO ORDER NUMBER AND EVENT UUID {% endcomment %}
    {% for ticket in get_event_tickets_from_orders %}
        <div class="allocation-cards">
            {% comment %} ? CARD COUNT {% endcomment %}
            <div class="allocation-card-count">
                <div class="allocation-card-number">
                    <span class="heading-4">
                        {{ forloop.index }}
                    </span>
                </div>
            </div>

            {% comment %} ? CARD DETAILS {% endcomment %}
            <div class="allocation-card-details">
                <div class="allocation-ticket-number-details">
                    <p class="p-body-bold">Ticket Number: {{ ticket.id }}</p>
                </div>

                {% if ticket.allocation_status == 'unallocated' %}
                    <p class="p-body txt-sub2">No guest assigned</p>
                {% else %}
                    <div class="allocation-customer-details">
                        <div class="allocation-details">
                            <p class="p-body">{{ ticket.contact_first_name }} {{ ticket.contact_last_name }} </p>
                        </div>
                        <div class="allocation-details">
                            <p class="p-body">{{ ticket.contact_email }} </p>
                        </div>
                        <div class="allocation-details">
                            <p class="p-body">{{ ticket.dietary_notes | default: "N/A" }} </p>
                        </div>
                    </div>        
                {% endif %}
            </div>

            {% comment %} ? Condition if Allocated or Not {% endcomment %}
            {% if ticket.allocation_status == 'unallocated' %}
                {% comment %} ? CARD BUTTON {% endcomment %}
                <div class="allocation-card-button">
                    <div data-id="{{ ticket.id }}" class="allocation-button">
                        <span class="allocate-button button-default-2">
                            Allocate Ticket
                            <i class="icon-arrow-forward"></i>
                        </span>
                    </div>
                </div>
            {% endif %}
        </div>
        <div class="spacer x-small"></div>
    {% endfor %}
{% endfor %}

<input type="hidden" id="company_name" name="{{ props.company_name.name }}" value="{{ data.properties.company_name |  default: "" }}" >
{% comment %} ? ALLOCATE MODAL {% endcomment %}
<ins-modal id="allocationModal"
    data=""
    with-backdrop
    no-button
    class="allocationModal">

    <div class="allocationModalBodyContainer">
        <div class="allocationModalDetails">
            <label class="heading-2-xsmall">Allocate Ticket</label>
            <div class="spacer small"></div>
            <p class="p-body">
                Before submitting, please review your details carefully. Once submitted, changes cannot be made. Contact us if you need assistance.
            </p>
            <div class="spacer"></div>

            {% comment %} ? TICKET NUMBER {% endcomment %}
            <ins-input 
                id="allocate-ticket"
                disabled
                label="Ticket Number"
                name="" 
                value="">
            </ins-input>

            {% comment %} ? EMAIL ADDRESS {% endcomment %}
            <div class="allocationModalEmailAddress">
                <div class="allocationName">
                    <ins-input
                        id="allocate-email"
                        placeholder=""
                        label="Email Address*"
                        name=""
                        value="">
                    </ins-input>
                </div>
                <div class="allocationArrowEmail">
                    <ins-button id="searchEmailModal" solid label="" icon="icon-arrow-forward">

                    </ins-button>
                </div>
            </div>
            <p class="body-x-small">
                <i>Please click the red arrow once you have entered your email.</i>
            </p>

            {% comment %} ? ERROR MESSAGE {% endcomment %}
            <div id="error-message-on-email" class="allocationModalErrorMessage is_not_visible">
                <div class="allocationErrorIcon">
                    <i class="icon-warning"></i>
                </div>
                <div class="allocationErrorMessage">
                    <p class="body-x-small">
                        Email address is not yet registered in our system. Please enter their details.
                    </p>
                </div>
            </div>

            <span id="emailRequired" class="txt-red body-x-small is_not_visible">Required</span>
            <div class="spacer"></div>

            {% comment %} ? NAME {% endcomment %}
            <div class="allocationModalName">
                <div class="allocationName">
                    {% comment %} ? FIRST NAME {% endcomment %}
                    <ins-input 
                        id="allocate-first-name"
                        disabled
                        label="First Name*"
                        name="" 
                        value="">
                    </ins-input>
                    <span id="firstNameRequired" class="txt-red body-x-small is_not_visible">Required</span>
                </div>
                <div class="allocationName">
                    {% comment %} ? Last NAME {% endcomment %}
                    <ins-input 
                        id="allocate-last-name"
                        disabled
                        label="Last Name*"
                        name="" 
                        value="">
                    </ins-input>
                    <ins-input hidden id="allocate-external-id" disabled></ins-input>
                    <span id="lastNameRequired" class="txt-red body-x-small is_not_visible">Required</span>
                </div>
            </div>

            <div class="spacer"></div>
            {% comment %} Has company {% endcomment %}
            <div class="list-field-wrap" 
                id="has_company"
                data-type="string"
                data-ui="radio" 
                data-name="has_company">

                <div class="list-radio-options">
                    <ins-radio label="With company" value="With company"
                        name="has_company" Checked>
                    </ins-radio>
                    <ins-radio label="No company" value="No company"
                        name="has_company">
                    </ins-radio>
                </div>
            </div>
            <div class="spacer small"></div>
            {% comment %} ? Company Name {% endcomment %}
             <div id="company_dropdown">
                <div class="searchable-select">
                    <label>Company name*</label>
                    <input field="email" disabled type="text" placeholder="Search or add company..." id="search-input" autocomplete="off">
                    <span id="companyRequired" class="txt-red body-x-small is_not_visible">Required</span>
                    <input type="hidden" id="selected-value">
                    <ul id="options-list"></ul>
                </div>


             </div>
            <div class="spacer"></div>
            {% comment %} ? DIETARY {% endcomment %}
            <ins-textarea 
                id="allocate-dietary" 
                name="" 
                label="Dietary Requirements" 
                placeholder=""
                value="">
            </ins-textarea>

        </div>
        <div class="allocationModalButton">
            <div class="cancelModalButton">
                <ins-button 
                    id="cancel"
                    type="button" 
                    class="card-form-cancel"
                    label="Cancel"
                    outlined>
                </ins-button>
            </div>
            <div class="allocateModalButton">
                <ins-button 
                    type="submit" 
                    id="submit-btn" 
                    label="Allocate" 
                    solid >
                </ins-button>
            </div>
        </div>
    </div>
</ins-modal>

{% comment %} ? SHOW EMPTY STATE {% endcomment %}
{% if ticket_count == false %}
    <div class="spacer xxxx-large"></div>
    <div class="empty-state text-center empty-box">
        <p>No Tickets available</p>
    </div> 
{% endif %}

{% comment %} ? JAVASCRIPT {% endcomment %}
 <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
    <script src="{{ 'modules/client/services/apiServices.js' | asset_url }}"></script>
    <script src="{{ 'modules/client/scripts/login-scripts.js' | asset_url }}"></script>
{%- else -%}
    <script src="{{ 'modules/client/services/apiServices.min.js' | asset_url }}"></script>
    <script src="{{ 'modules/client/scripts/login-scripts.min.js' | asset_url }}"></script>
{%- endif -%}

<script>

    // SET SESSION ON ALLOCATE
    var is_allocated_hidden_value = document.getElementById("is_allocated_hidden_value");    
     
    // ALLOCATION MODAL
    var searchEmailModal = document.getElementById("searchEmailModal");
    var cancelButton = document.getElementById("cancel");
    var allocateButton = document.getElementById("submit-btn");
    var errorMessageOnEmail = document.getElementById("error-message-on-email");
    var modal = ''

    // DETAILS
    var event_uuid = document.getElementById("event_uuid");
    var allocateTicket = document.getElementById("allocate-ticket");
    var allocateEmail = document.getElementById("allocate-email");
    var allocateFirstName = document.getElementById("allocate-first-name");
    var allocateLastName = document.getElementById("allocate-last-name");
    var allocateExternalId = document.getElementById("allocate-external-id");
    var allocateDietary = document.getElementById("allocate-dietary");

    // REQUIRED FIELDS
    var requiredEmail = document.getElementById("emailRequired");
    var is_email_has_value = false; 
    var requiredFirstName = document.getElementById("firstNameRequired");
    var is_firstname_has_value = false;
    var requiredLastName = document.getElementById("lastNameRequired");
    let companyRequired = document.getElementById("companyRequired")
    var is_lastname_has_value = false;
    let insSearchEl = document.getElementById('insSearchEl');
    // SEARCH EMAIL RESULT
    var is_email_found = false;

    // SEARCH Company
    const input = document.getElementById('search-input');
    const hiddenInput = document.getElementById('selected-value');
    const list = document.getElementById('options-list');
    let is_company_has_value = false;
    let is_company_required = true
    let companyNameVal = "";
    let companyNameTemp = ""
    let companyDeafaultNameTemp = ""
    let defaultCompany;



    let allocationButton = document.querySelectorAll('.allocation-button')
    allocationButton.forEach(e => {
        e.addEventListener('click', () => {
            let id = e.getAttribute('data-id');
            modal = document.getElementById('allocationModal');
            allocateTicket.value = id;
            modal.open()
        })
    });

    // CANCEL
    cancelButton.addEventListener('insClick', event => {
        modal.close();
    });

    // SEARCH EMAIL
    searchEmailModal.addEventListener('insClick', async (event) => {
        let url = '/check-user-email-allocation?'+ 'email='+ allocateEmail.value ;
        let response = await apiServices.processRequest('get', url);
        
        if(response.state && response.data) {
            input.removeAttribute('disabled')
            // IF EMAIL EXISTS 
            is_email_found = true;
            errorMessageOnEmail.classList.remove('is_not_visible');
            errorMessageOnEmail.classList.add('is_visible');
            if(response.data.email_status == "invalid"){
                errorMessageOnEmail.classList.remove('is_visible');
                errorMessageOnEmail.classList.add('is_not_visible');

                let firstNameInput = document.querySelectorAll('.allocationName #allocate-first-name');
                firstNameInput[0].setAttribute("disabled", "");

                let lastNameInput = document.querySelectorAll('.allocationName #allocate-last-name');
                lastNameInput[0].setAttribute("disabled", "");
    
                allocateFirstName.value = response.data.first_name;
                allocateLastName.value = response.data.last_name;   
                allocateExternalId.value = response.data.external_id;   

                // REQUIRED
                requiredFirstName.classList.remove('is_visible');
                requiredFirstName.classList.add('is_not_visible');
                requiredLastName.classList.remove('is_visible');
                requiredLastName.classList.add('is_not_visible');
                companyRequired.classList.remove('is_visible');
                companyRequired.classList.add('is_not_visible');

                prefillSelect(response.data.company_uuid)
                

            }else{
                is_email_found = false;
                errorMessageOnEmail.classList.remove('is_not_visible');
                errorMessageOnEmail.classList.add('is_visible');
                
                allocateFirstName.value = "";
                allocateLastName.value = "";
                allocateExternalId.value = "";

                let firstNameInput = document.querySelectorAll('.allocationName #allocate-first-name');
                firstNameInput[0].removeAttribute("disabled");
                let lastNameInput = document.querySelectorAll('.allocationName #allocate-last-name');
                lastNameInput[0].removeAttribute("disabled");

                // REQUIRED
                requiredFirstName.classList.remove('is_not_visible');
                requiredFirstName.classList.add('is_visible');
                requiredLastName.classList.remove('is_not_visible');
                requiredLastName.classList.add('is_visible');
                companyRequired.classList.remove('is_visible');
                companyRequired.classList.add('is_not_visible');

            }
        } 
    });

    // ALLOCATE
    allocateButton.addEventListener('insClick', async (event) => {

        // email
        if(allocateEmail.value == '') {
            requiredEmail.classList.remove('is_not_visible');
            requiredEmail.classList.add('is_visible');
            is_email_has_value = false;
        }else{
            requiredEmail.classList.remove('is_visible');
            requiredEmail.classList.add('is_not_visible');
            is_email_has_value = true;
        }

        // first name
        if(allocateFirstName.value == '') {
            requiredFirstName.classList.remove('is_not_visible');
            requiredFirstName.classList.add('is_visible');
            is_firstname_has_value = false;
        }else{
            requiredFirstName.classList.remove('is_visible');
            requiredFirstName.classList.add('is_not_visible');
            is_firstname_has_value = true;
        }

        // last name
        if(allocateLastName.value == '') {
            requiredLastName.classList.remove('is_not_visible');
            requiredLastName.classList.add('is_visible');
            is_lastname_has_value = false;
        }else{
            requiredLastName.classList.remove('is_visible');
            requiredLastName.classList.add('is_not_visible');
            is_lastname_has_value = true;
        }

            
        // Company
        if(is_company_required) {
            if(input.value == '') {
                companyRequired.classList.add('is_visible');
                companyRequired.classList.remove('is_not_visible');
                is_company_has_value = false;
            }else{
                companyRequired.classList.remove('is_visible');
                companyRequired.classList.add('is_not_visible');
                is_company_has_value = true;
            }
        }else {
            companyRequired.classList.remove('is_visible');
            companyRequired.classList.add('is_not_visible');
            is_company_has_value = true;
        }
 
    
        // Get the current URL
        const currentUrl = window.location.href;
        // Remove any existing `allocate` query parameters
        const newUrl = currentUrl.replace(/[?&]allocated=\d+/, '');

        let updatedUrl;

        if (newUrl.includes("allocated")) {
            updatedUrl = `${newUrl}`; 
        } else {
            updatedUrl = newUrl.includes('?') 
                ? `${newUrl}&allocated=true` 
                : `${newUrl}?allocated=true`;
        }

        if(is_email_has_value == true && is_firstname_has_value == true && is_lastname_has_value == true && is_company_has_value == true){
            allocateButton.loading = true;

            let url = "";
           
            if(is_email_found == true){
                url = '/allocate-ticket?' + 'event_uuid=' + event_uuid.value + '&ticket_id=' + allocateTicket.value + '&external_id=' + allocateExternalId.value + '&dietary_notes=' + allocateDietary.value + "&has_email=true"+ "&companyNameVal=" + companyNameVal;
            }else{
                url = '/allocate-ticket?' + 'event_uuid=' + event_uuid.value + '&ticket_id=' + allocateTicket.value + '&dietary_notes=' + allocateDietary.value + '&first_name=' + allocateFirstName.value + '&last_name=' + allocateLastName.value + '&email=' + allocateEmail.value + "&has_email=false" + "&companyNameVal=" + companyNameVal;
            }

            setTimeout(async() => {
                let response = await apiServices.processRequest('post', url);
                if(response.state == true) {
                    window.location.href = updatedUrl;
                }else{
                    App.events.notyf("error", "Allocation failed");
                }
            }, 500);

        }else{
            allocateButton.loading = false;
        }
    });


    ///Radio and company search 
    const hasCompanyEl = document.getElementById('has_company')
    const companyDropdown = document.getElementById('company_dropdown')
    let company_name = document.getElementById('company_name')
   
    let insSearchWrap = document.getElementById('insSearchWrap');
    let companyName
    let hasNextPage = false

    hasCompanyEl.addEventListener('insValueChange', (e) => {
        if(e.detail == 'With company') {
            companyDropdown.style.display = 'block'
            is_company_required = true
        }else {
            companyDropdown.style.display = 'none'
            is_company_required = false
            companyNameVal = ""
        }
    })

 //search 3 test

  let options = [];
  let currentPage = 1;
  let isLoading = false;
  let allLoaded = false;
  const limit = 5;

  let selectedIndex = -1;
  let filteredOptions = [];
  let debounceTimer = null;

  async function fetchOptions(page = 1, query = '') {
    if (isLoading || allLoaded) return;
    isLoading = true;
    showLoading();
    try {
      let url = '/get-companies?companyName=' + query + "&page=" + currentPage
      const res = await await apiServices.processRequest('get', url);
      let companies = res.data.items.results
      console.log
      const newOptions = companies.map(company => ({ label: company.properties.company_name, value: company.properties.uuid }));

      const newUniqueOptions = newOptions.filter(opt => !options.some(o => o.value === opt.value));
      if (newUniqueOptions.length === 0) {
        allLoaded = true;
      }

      options = [...options, ...newUniqueOptions];
      if (input === document.activeElement) {
        updateList(input.value);
      }
    } catch (error) {
      console.error('Error fetching users:', error);
    } finally {
      hideLoading();
      isLoading = false;
    }
  }

  async function prefillSelect(value) {
    const existing = options.find(opt => opt.value === value);
    if (existing) {
      input.value = existing.label;
      hiddenInput.value = existing.value;
      return;
    }
    try {
      const url = '/get-company?uuid=' + value;
      const response = await apiServices.processRequest('get', url);
      let company = response.data
      const option = { label: company.properties.company_name, value: company.properties.uuid };
      options.push(option);
      input.value = option.label;
      hiddenInput.value = option.value;
      defaultCompany = option.value;
      companyDeafaultNameTemp = company.properties.company_name
    } catch (err) {
      console.error('Prefill error:', err);
    }
  }

  function showLoading() {
    let loadingEl = document.getElementById('loading-item');
    if (!loadingEl) {
      loadingEl = document.createElement('li');
      loadingEl.className = 'loading';
      loadingEl.id = 'loading-item';
      loadingEl.textContent = 'Loading...';
      list.appendChild(loadingEl);
    }
  }

  function hideLoading() {
    const loadingEl = document.getElementById('loading-item');
    if (loadingEl) loadingEl.remove();
  }

  function updateList(filter = '') {
    list.innerHTML = '';
    filteredOptions = options.filter(opt => opt.label.toLowerCase().includes(filter.toLowerCase()));
    selectedIndex = -1;

    if (filteredOptions.length === 0) {
      const noResult = document.createElement('li');
      noResult.className = 'no-results';
      noResult.textContent = `Save "${filter}" as new`;
      noResult.addEventListener('click', () => {
        // hiddenInput.value = filter;
        input.value = filter;
        list.style.display = 'none';
        var tempCompany = filter
        companyNameTemp = filter
        confirmCompanyChange(tempCompany,filter)
      });
      list.appendChild(noResult);
    } else {
      filteredOptions.forEach((option, index) => {
        const li = document.createElement('li');
        li.textContent = option.label;
        li.dataset.value = option.value;
        li.addEventListener('click', () => {
          input.value = option.label;
        //   hiddenInput.value = option.value;
          list.style.display = 'none';
          var tempCompany = option.value
          companyNameTemp = option.label
          confirmCompanyChange(tempCompany,option.value)

            });
        list.appendChild(li);
      });
    }

    if (isLoading) showLoading();
    list.style.display = 'block';
  }

  input.addEventListener('input', (e) => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      const query = e.target.value.trim();
      options = [];
      currentPage = 1;
      allLoaded = false;
      fetchOptions(currentPage, query);
    }, 300);
  });

  input.addEventListener('focus', () => {
    if (options.length === 0) {
      fetchOptions(currentPage, input.value.trim());
    } else {
      updateList(input.value);
    }
  });

  input.addEventListener('click', () => {
    if (options.length > 0) {
      updateList(input.value);
    }
  });

  input.addEventListener('keydown', (e) => {
    const items = list.querySelectorAll('li:not(.loading):not(.no-results)');
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      selectedIndex = (selectedIndex + 1) % items.length;
      highlightItem(items);
      e.preventDefault();
    } else if (e.key === 'ArrowUp') {
      selectedIndex = (selectedIndex - 1 + items.length) % items.length;
      highlightItem(items);
      e.preventDefault();
    } else if (e.key === 'Enter' && selectedIndex >= 0) {
      const selected = filteredOptions[selectedIndex];
      input.value = selected.label;
      hiddenInput.value = selected.value;
      list.style.display = 'none';
      var tempCompany = selected.value
      companyNameTemp = selected.value
      e.preventDefault();
      confirmCompanyChange(tempCompany,selected.value)
    }
  });

  function highlightItem(items) {
    items.forEach((item, index) => {
      item.style.backgroundColor = index === selectedIndex ? '#e0e0e0' : '';
    });
  }

  list.addEventListener('scroll', () => {
    if (list.scrollTop + list.clientHeight >= list.scrollHeight - 5) {
      currentPage++;
      fetchOptions(currentPage, input.value.trim());
    }
  });

  document.addEventListener('click', (e) => {
    if (!e.target.closest('.searchable-select')) {
      list.style.display = 'none';
    }
  });
    
  async function confirmCompanyChange(tempCompany,tempComnpanyVal) {
    if(defaultCompany) {
        if(tempCompany != defaultCompany) {
            setTimeout(async()=> { 
                let confirm =  await Swal.fire({
                icon: 'warning',
                title: `This user is already assigned to ${companyDeafaultNameTemp}`,
                html: `Are you sure you want to assign them to <b>${companyNameTemp}</b> instead? This will update their current company association and may impact their login or Membership.`,
                showConfirmButton: true,
                showCancelButton: true,
                cancelButtonText: `<i class="icon-close-1"></i> No`,
                confirmButtonText: `<i class="icon-check-2"></i> Yes`,
                allowOutsideClick: false,
                customClass: "swal-member-offers"}).then((result) => {
                if (result.isConfirmed) {
                    hiddenInput.value = tempComnpanyVal
                    companyNameVal = tempComnpanyVal
                }else {
                    companyNameVal = ""
                    prefillSelect(defaultCompany)
                }
                })
            },200)
        }else {
           companyNameVal =  tempCompany
        }
    }else {
        companyNameVal =  tempCompany
    }
   
  }
    
</script>

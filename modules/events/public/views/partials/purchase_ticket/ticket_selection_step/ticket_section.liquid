---
metadata: {
    partial_name: 'Events | Purchase Ticket | Ticket Selection Step | Ticket Section'
}
---

{% graphql venues = 'modules/events/events/get_divisions', event_uuid: event.uuid | dig: 'items','results' %}
{% assign now = "now" | date: "%s" %}
<div class="accordion">


{% for venue in venues %}
  {% assign venue_individual_remaining = venue.area_individual_tickets_remaining | default: 0 %}
  {% assign venue_group_remaining = venue.area_group_tickets_remaining | default: 0 %}

  {% assign lowest_price = nil %}
  {% for tier in venue.tiers %}
    {% if lowest_price == nil or tier.price < lowest_price %}
      {% assign lowest_price = tier.price %}
    {% endif %}
  {% endfor %}

  {%- if lowest_price -%}
    {%- assign cents = lowest_price | times: 100 | round -%}
    {%- assign dollars = cents | divided_by: 100.0 -%}
    {%- assign formatted_price = dollars | append: "" -%}
    {%- if formatted_price contains "." -%}
      {%- assign parts = formatted_price | split: "." -%}
      {%- assign decimal = parts[1] -%}
      {%- if decimal.size == 1 -%}
        {%- assign formatted_price = formatted_price | append: "0" -%}
      {%- endif -%}
    {%- else -%}
      {%- assign formatted_price = formatted_price | append: ".00" -%}
    {%- endif -%}
  {%- endif -%}

  <div class="item open">
    <div class="title">
      <div class="event-ticket-venue-detail">
        <h3>{{ venue.name }}</h3>
        <div class="spacer x-small"></div>
        <p class="ticket-venue-sub-place">{{ venue.venue.venue_name }} - {{ venue.area_name }}</p>
        <div class="spacer x-small"></div>
        {% assign ticket_cat = "" %}
        {% for tier in venue.tiers %}
          {% unless ticket_cat contains tier.capacity_type %}
            {% if ticket_cat == "" %}
              {% assign ticket_cat = tier.capacity_type %}
            {% else %}
              {% assign ticket_cat = ticket_cat | append: "," | append: tier.capacity_type %}
            {% endif %}
          {% endunless %}
        {% endfor %}
        {% assign ticket_category = ticket_cat | split: "," %}
        <p class="ticket-venue-categories">
          {{ ticket_category.size }} Ticket Categories - Tickets starting from ${{ formatted_price }}
        </p>
      </div>
      <span class="icon"><i class="icon-angle-up"></i></span>
    </div>

    {% assign grouped_tiers = venue.tiers | group_by: "capacity_type" %}
    <div class="content">
      <div class="content-inner">
        {% for ticket_tier_category in grouped_tiers %}
          {% if ticket_tier_category[0] == "individual" %}
            {% assign ticket_icon = "icon-user" %}
            {% assign ticket_category_name = "Individual Tickets" %}
            {% assign ticket_type = "individual" %}
            {% assign venue_remaining = venue_individual_remaining %}
          {% else %}
            {% assign ticket_icon = "icon-users" %}
            {% assign ticket_category_name = "Group of " | append: venue.capacity_per_group |  append: ' Tickets' %}
            {% assign ticket_type = "group" %}
            {% assign venue_remaining = venue_group_remaining %}
          {% endif %}
          <div class="ticket-category-container"
            data-venue-uuid="{{ venue.uuid }}" 
            data-total-capacity="{{ venue.total_capacity }}"
            data-individual-remaining="{{ venue.area_individual_tickets_remaining }}"
            data-group-remaining="{{ venue.area_group_tickets_remaining }}"
            data-capacity-per-group="{{ venue.capacity_per_group }}"
            data-number-of-group="{{ venue.number_of_groups }}"
          >
            <div class="ticket-category">
              <i class="{{ ticket_icon }}"></i>
              <p>{{ ticket_category_name }}</p>
            </div>
            <div class="spacer small"></div>
            <hr>
            <div class="spacer small"></div>

            {% for ticket_tier_list in ticket_tier_category offset: 1 %}
              {% for ticket_tier in ticket_tier_list %}
                {% assign ticket_data = '{}' | parse_json %}
                {% assign ticket_data = ticket_data | add_hash_key: "capacity_type", ticket_tier.capacity_type %}
                {% assign ticket_data = ticket_data | add_hash_key: "price", ticket_tier.price %}
                {% assign ticket_data = ticket_data | add_hash_key: "event_pricing_division_uuid", ticket_tier.event_pricing_division_uuid %}
                {% assign ticket_data = ticket_data | add_hash_key: "name", ticket_tier.name %}
                {% assign ticket_data = ticket_data | add_hash_key: "tax", ticket_tier.tax %}
                {% assign ticket_data = ticket_data | add_hash_key: "tax_type", ticket_tier.tax_type %}
                {% assign ticket_data = ticket_data | add_hash_key: "ticket_venue_name", venue.name %}
                {% assign ticket_data = ticket_data | add_hash_key: "event_pricing_tier.uuid", ticket_tier.uuid %}
                {% assign ticket_data = ticket_data | add_hash_key: "capacity_max", venue_remaining %}
                {% assign ticket_data = ticket_data | add_hash_key: "tier_id", ticket_tier.uuid %}
                {% assign ticket_data = ticket_data | add_hash_key: "venue_uuid", venue.venue_uuid %}
                {% assign ticket_data = ticket_data | add_hash_key: "venue_name", venue.venue.venue_name %}
                {% if ticket_type == 'group' %}
                    {% assign ticket_data = ticket_data | add_hash_key: "capacity_per_group", venue.capacity_per_group %}
                {% endif %}

                {% assign start_date = ticket_tier.availability_start_date | date: "%s" %}
                {% assign end_date = ticket_tier.availability_end_date | date: "%s" %}

                {% assign max_tickets = venue_remaining %}
                {% if ticket_type == "individual" and ticket_tier.capacity and ticket_tier.capacity < max_tickets %}
                  {% assign max_tickets = ticket_tier.capacity %}
                {% elsif ticket_type == "group" and ticket_tier.number_of_groups and ticket_tier.number_of_groups < max_tickets %}
                  {% assign max_tickets = ticket_tier.number_of_groups %}
                {% endif %}

                <div class="ticket-purchaser">
                  <span class="ticket-tier-name">
                    {{ ticket_tier.name }}                    
                  {% if ticket_tier.availability_start_date != blank and start_date > now %}
                    <br>
                    <span class="not-available">Tickets available from {{ ticket_tier.availability_start_date | date: "%b %d, %Y" }}.</span>
                  {% elsif ticket_tier.availability_end_date != blank and end_date < now %}
                    <br>
                    <span class="not-available">Pre-sale ended.</span>
                  {% endif %}
                  </span>

                  {% if venue_remaining == 0 %}
                    <div class="ticket-purchaser-counter">
                      <span>${{ ticket_tier.price }}</span>
                      <div class="ticket-unavailable">Sold out</div>
                    </div>
                  {% elsif ticket_tier.availability_start_date != blank and start_date > now %}
                    <div class="ticket-purchaser-counter">
                      <span>${{ ticket_tier.price }}</span>
                      <div class="ticket-unavailable">Not available</div>
                    </div>
                  {% elsif ticket_tier.availability_end_date != blank and end_date < now %}
                    <div class="ticket-purchaser-counter">
                      <span>${{ ticket_tier.price }}</span>
                      <div class="ticket-unavailable">Not available</div>
                    </div>
                  {% else %}
                    <div class="ticket-purchaser-counter">
                      <span>${{ ticket_tier.price }}</span>
                       <div class="number-input" >
                        <button class="decrement">-</button>
                        <input data='{{ ticket_data | json }}' type="number" class="input-stepper" value="0" min="0" max="{{ max_tickets }}">
                        <button class="increment">+</button>
                      </div>
                    </div>
                  {% endif %}
                </div>
              {% endfor %}
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
{% endfor %}
</div>



---
metadata: {
    partial_name: 'Events | Ticket | Order Summary (Pre-payment, DB pricing)'
}
---

{%- comment -%}
  Pre-payment wrapper for the order summary. Used on /ticket-billing and
  /ticket-payment. Reads the user's tier+division selection from session,
  re-fetches current prices from event_pricing_tier (never from sessionStorage),
  builds the normalised breakdown, and delegates rendering to order_summary_final.
{%- endcomment -%}

{%- assign event_uuid = context.params.event -%}
{%- assign session_data = context.session.tickets_selected[event_uuid] -%}
{%- assign ticket_data = session_data.ticketData | parse_json -%}

{%- assign _uuid_str = "" -%}
{%- for td in ticket_data -%}
  {%- assign _tuuid = td['event_pricing_tier.uuid'] -%}
  {%- if _tuuid != blank -%}
    {%- assign _uuid_str = _uuid_str | append: _tuuid | append: "," -%}
  {%- endif -%}
{%- endfor -%}
{%- assign tier_uuids = _uuid_str | split: "," | array_compact | array_uniq -%}

{%- if tier_uuids.size > 0 -%}
  {%- graphql prices_result = 'modules/events/events/pricing/get_ticket_prices', uuid: tier_uuids -%}
  {%- assign tier_prices = prices_result | dig: 'items', 'results' -%}
{%- else -%}
  {%- assign tier_prices = blank -%}
{%- endif -%}

{%- graphql divisions_result = 'modules/events/events/get_divisions', event_uuid: event_uuid -%}
{%- assign all_divisions = divisions_result | dig: 'items', 'results' -%}

{%- assign breakdown = '' | split: ',' -%}
{%- assign subtotal = 0 -%}
{%- assign total_tax = 0 -%}
{%- assign seen_division_keys = "" -%}

{%- for td in ticket_data -%}
  {%- assign div_uuid = td.event_pricing_division_uuid -%}
  {%- assign dkey = "|" | append: div_uuid | append: "|" -%}
  {%- unless seen_division_keys contains dkey -%}
    {%- assign seen_division_keys = seen_division_keys | append: dkey -%}

    {%- assign db_division = all_divisions | where: "uuid", div_uuid | first -%}
    {%- assign display_div_name = db_division.name | default: "No Venue" -%}

    {%- assign div_tickets = ticket_data | where: "event_pricing_division_uuid", div_uuid -%}

    {%- assign items = '' | split: ',' -%}
    {%- assign seen_tier_keys = "" -%}

    {%- for vt in div_tickets -%}
      {%- assign _vt_uuid = vt['event_pricing_tier.uuid'] -%}
      {%- assign tkey = "|" | append: _vt_uuid | append: "|" | append: vt.capacity_type | append: "|" -%}
      {%- unless seen_tier_keys contains tkey -%}
        {%- assign seen_tier_keys = seen_tier_keys | append: tkey -%}

        {%- assign qty = 0 -%}
        {%- for vt2 in div_tickets -%}
          {%- assign _vt2_uuid = vt2['event_pricing_tier.uuid'] -%}
          {%- assign tkey2 = "|" | append: _vt2_uuid | append: "|" | append: vt2.capacity_type | append: "|" -%}
          {%- if tkey2 == tkey -%}{%- assign qty = qty | plus: 1 -%}{%- endif -%}
        {%- endfor -%}

        {%- assign db_tier = tier_prices | where: "uuid", _vt_uuid | first -%}
        {%- assign unit_price = db_tier.price | plus: 0 -%}
        {%- assign unit_tax = db_tier.tax | plus: 0 -%}
        {%- assign unit_tax_type = db_tier.tax_type -%}
        {%- assign tier_name = db_tier.name | default: vt.capacity_type -%}

        {%- assign item_subtotal = unit_price | times: qty -%}
        {%- assign subtotal = subtotal | plus: item_subtotal -%}
        {%- if unit_tax_type == "percentage" -%}
          {%- assign item_tax = item_subtotal | times: unit_tax | divided_by: 100.0 -%}
        {%- else -%}
          {%- assign item_tax = unit_tax | times: qty -%}
        {%- endif -%}
        {%- assign total_tax = total_tax | plus: item_tax -%}

        {%- assign cap_type = vt.capacity_type | capitalize -%}
        {%- assign item_name = cap_type | append: " - " | append: tier_name -%}

        {%- assign item = '{}' | parse_json -%}
        {%- assign item = item | add_hash_key: "name", item_name -%}
        {%- assign item = item | add_hash_key: "qty", qty -%}
        {%- assign item = item | add_hash_key: "unit_price", unit_price -%}
        {%- assign items = items | array_add: item -%}
      {%- endunless -%}
    {%- endfor -%}

    {%- assign venue_entry = '{}' | parse_json -%}
    {%- assign venue_entry = venue_entry | add_hash_key: "venue_name", display_div_name -%}
    {%- assign venue_entry = venue_entry | add_hash_key: "items", items -%}
    {%- assign breakdown = breakdown | array_add: venue_entry -%}
  {%- endunless -%}
{%- endfor -%}

{%- assign temp_total = subtotal | plus: total_tax -%}
{%- assign processing_fee = temp_total | times: 0.017 -%}
{%- assign grand_total = temp_total | plus: processing_fee -%}

{% include 'modules/events/ticket/order_summary',
    breakdown: breakdown,
    subtotal: subtotal,
    total_tax: total_tax,
    processing_fee: processing_fee,
    grand_total: grand_total %}

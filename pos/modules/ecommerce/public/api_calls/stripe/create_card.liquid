---
name: create_card
to: https://api.stripe.com/v1/customers/{{ data.gateway_id }}/sources
enabled: true
trigger_condition: true
request_type: POST
callback: >
  {%- assign response_data = response.body | to_hash -%}
  {% if response_data.error %}
    {%- log response_data.error, type: 'modules/ins_template_ecommerce/create_card' -%}
  {% endif %}
headers: >
  {% if data %}
    {%- include 'modules/insites_ecommerce/shared/api_credentials' -%}
    {
      {%- log context.exports.payments.gateway.secret_key, type: "SECRET KEY" -%}
      "Content-Type": "application/x-www-form-urlencoded",
      "Authorization": "Bearer {{ context.exports.payments.gateway.secret_key }}"
    }
  {% endif %}
---
source={{ data.source }}{% for data in data.metadata %}&metadata[{{ data[0] }}]={{ data[1] | url_encode }}{% endfor %}

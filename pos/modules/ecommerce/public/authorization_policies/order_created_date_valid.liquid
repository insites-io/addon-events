---
name: order_created_date_valid
redirect_to: sign-in
flash_alert: Order confirmation page has expired. Please login to view order details.
---
{% graphql order_details = "modules/ins_template_ecommerce/orders/get_order_details",
    id: context.params.order_id 
    | dig: 'items' | dig: 'results' | first %}
{% assign now = 'now' | to_time %}
{% assign diff = order_details.created_at | time_diff: now, 'minutes' %}
{% comment %} Allow user to see confirmation page for 5 minutes {% endcomment %}
{%- if diff < 5 -%}
    true
{%- endif -%}
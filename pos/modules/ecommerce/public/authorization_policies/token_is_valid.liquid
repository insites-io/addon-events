---
name: token_is_valid
redirect_to: 403
---
{%- graphql data =  'modules/ins_template_ecommerce/account/get_user_with_password_token', id: context.params.id -%}
{%- assign token_valid = context.params.token | is_token_valid: data.users.results[0].id -%}
{% if data.users.results[0].id != blank and token_valid == true and data.users.results[0].default[0].password_token == context.params.token %}true{% endif %}

---
name: sign_up
resource: User
resource_owner: anyone
flash_alert: Sorry-Signup
flash_notice: Congratulations-Signup
redirect_to: sign-up
fields:
  email:
    validation: 
      presence:
        message: Please use a valid email address
      email: 
        message: Please use a valid email address
  password:
    validation: 
      presence: 
        message: Invalid Password
  first_name:
    validation: 
      presence: 
        message: First name is required
  last_name:
    validation: 
      presence: 
        message: Last name is required
  profiles:
    modules/insites_core/insites_contact_number:
      properties:
        mobile_phone_number:
    modules/insites_core/insites_customer:
      properties:
        is_enabled:
          property_options:
            default: true
            readonly: true
    modules/ins_template_ecommerce/customer:
      properties:
        is_enabled:
          property_options:
            default: true
            readonly: true
        is_activated:
          property_options:
            default: false
            readonly: true
api_call_notifications:
  - modules/insites_core/insites_create_crm_activity
default_payload: |-
  {
    "fields": {
      "profiles":{
        "modules/ins_template_ecommerce/customer":{
          "properties_attributes": {
            "is_enabled" : true,
            "is_activated" : false
          }
        }
      }
    }
  }
callback_actions: |-
  {% graphql g = 'modules/ins_template_ecommerce/account/generate_user_temporary_token', email: form.email %}
  {% if g.items.results[0] %}
    {% graphql res = 'modules/ins_template_ecommerce/account/set_email_verification_token', id: g.items.results[0].id, token: g.items.results[0].temporary_token %}
  {% endif %}    
---


{%- form 
    html-id: "sign-up-form"
    html-novalidate: true
    html-enctype="multipart/form-data"
    html-onsubmit:"return LoginScript.methods.validateForm(event);" -%}
        
    <div class="grid-x grid-padding-x">
        <div class="small-12 cell">
            <ins-input validate
                id="email"
                label="Email*"
                field="email"
                name="{{ form.fields.email.name }}" 
                value="{{ form.fields.email.value }}" 
                {% if form.errors['email'] %} has-error {% endif %}
                error-message="{{ form.fields.email.validation.rules.presence.message }}"
                placeholder="Email Address">
            </ins-input>

            <ins-input validate
                id="password"
                label="Password*"
                field="password"
                name="{{ form.fields.password.name }}" 
                value="{{ form.fields.password.value }}" 
                {% if form.errors['password'] %} has-error {% endif %}
                error-message="{{ form.fields.password.validation.rules.presence.message }}"
                placeholder="Password">
            </ins-input>

            <ins-input validate
                id="first-name"
                label="First Name*"
                name="{{ form.fields.first_name.name }}" 
                value="{{ form.fields.first_name.value }}" 
                {% if form.errors['first_name'] %} has-error {% endif %}
                error-message="{{ form.fields.first_name.validation.rules.presence.message }}"
                placeholder="First Name">
            </ins-input>

            <ins-input validate
                id="last-name"
                label="Last Name*"
                name="{{ form.fields.last_name.name }}" 
                value="{{ form.fields.last_name.value }}" 
                {% if form.errors['last_name'] %} has-error {% endif %}
                error-message="{{ form.fields.last_name.validation.rules.presence.message }}"
                placeholder="Last Name">
            </ins-input>

            <ins-input 
                id="mobile-phone"
                label="Phone Number"
                field="tel"
                name="{{ form.fields.profiles['modules/insites_core/insites_contact_number'].properties.mobile_phone_number.name }}" 
                value="{{ form.fields.profiles['modules/insites_core/insites_contact_number'].properties.mobile_phone_number.value }}" 
                error-message="Please use a valid phone number"
                placeholder="Phone Number">
            </ins-input>

            <input type="hidden" name="{{ form.fields.profiles['modules/insites_core/insites_customer'].properties.is_enabled.name }}" value="{{ form.fields.profiles['modules/insites_core/insites_customer'].properties.is_enabled.value }}">
            <input type="hidden" name="{{ form.fields.profiles['modules/ins_template_ecommerce/customer'].properties.is_enabled.name }}" value="{{ form.fields.profiles['modules/ins_template_ecommerce/customer'].properties.is_enabled.value }}">
            <input type="hidden" name="{{ form.fields.profiles['modules/ins_template_ecommerce/customer'].properties.is_activated.name }}" value="{{ form.fields.profiles['modules/ins_template_ecommerce/customer'].properties.is_activated.value }}">

            <div>
                <p>By creating an account, you agree to our <a href="/privacy-policy">Privacy Policy</a> and <a href="terms-and-conditions">Terms of use</a>.</p>
            </div>
            <div class="spacer x-large"></div>
            <div class="text-center">
              <ins-button id="sign-up-btn" label="CREATE ACCOUNT" solid class="full" color="blue" type="submit" size="large"></ins-button>
            </div>
            <div class="spacer x-large"></div>
            <div class="text-center">
              <p>Already have an account? <a href="/sign-in">Sign In.</a></p>
            </div>

        </div>

    </div>

{%- endform -%}
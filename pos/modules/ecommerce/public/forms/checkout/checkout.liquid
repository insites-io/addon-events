---
name: checkout
resource: modules/insites_ecommerce/insites_order
resource_owner: anyone
redirect_to: > 
    {% log form.id, type: "==== Redirect To: confirmation?order_id= " %}
    confirmation?order_id={{ form.id }}
fields:
    properties:
    ## Shipping Details
        shipping_company_name:
        shipping_first_name:
            validation:
                presence:  
                    message: First name is required
        shipping_last_name:
            validation:
                presence:  
                    message: Last name is required 
        shipping_email:
            validation:
                email: 
                    message: Please use a valid email address
                presence:  
                    message: Please use a valid email address
        shipping_phone:
        shipping_address_id:
            property_options:
                virtual: true
        shipping_address_1:
            validation:
                presence:  
                    message: Address is required 
        shipping_address_2:
        shipping_address_3:
        shipping_city:
            validation:
                presence:  
                    message: City is required 
        shipping_state:
            validation:
                presence:  
                    message: State is required 
        shipping_country:
            validation:
                presence:  
                    message: Country is required 
        shipping_postcode:
            validation:
                presence:  
                    message: Postcode is required 
        additional_shipping_cost:
            property_options:
                virtual: true
        shipping_instructions:
    ## Payment Details
        billing_company_name:
        billing_first_name:
            validation:
                presence:  
                    message: First name is required 
        billing_last_name:
            validation:
                presence:  
                    message: Last name is required 
        billing_email:
            validation:
                email: 
                    message: Please use a valid email address
                presence:  
                    message: Please use a valid email address
        billing_phone:
        billing_address_id:
            property_options:
                virtual: true
        billing_address_1:
            validation:
                presence:  
                    message: Address is required 
        billing_address_2:
        billing_address_3:
        billing_city:
            validation:
                presence:  
                    message: City name is required 
        billing_state:  
            validation:
                presence:
                    message: State is required 
        billing_country:
            validation:
                presence:  
                    message: Country is required 
        billing_postcode:
            validation:
                presence:  
                    message: Postcode is required 
    ## Payment Gateway
        gateway_id: 
        gateway_customer_id: 
        user_id:  ## String! = current_user.id
        stripe_credit_card:
            property_options:
                virtual: true
        statement_descriptor:
            property_options:
                virtual: true
    ## Transaction Details
        order_status: ## String = "Paid" ??
        order_payment_status: ## String = "Paid" ??
        shipping_status: ## String = "Processing" 
        date_time: ## String! = date-time order success
        notes: ## stripe descrition
        is_enabled: ## Boolean = true
        currency: ## String! = AUD (System settings)
        order_value: ## Float!
        tax_amount: ## Float!
        shipping_amount: ## Float!
        total_amount: ## Float!
        amount_due: ## Float!
        total_discount_amount: ## Float
default_payload: >
    {%- comment -%}
    Get Gateway Settings from eCommerce settings 
    {%- endcomment -%}
    {%- graphql settings = "modules/ins_template_ecommerce/system/get_settings" 
        | dig: 'items' | dig: 'results' | first | dig: 'properties' -%}
    {%- comment -%}
    Get Cart Summary
    {%- endcomment -%}
    {% include 'modules/ins_template_ecommerce/checkout/compute_order_summary' %}
    {
        "properties_attributes": {
            "is_enabled": true,
            "gateway_id": "", 
            "gateway_customer_id": "", 
            "user_id": "{{ context.current_user.id }}", 
            "order_status": "Open", 
            "order_payment_status": "Open",
            "shipping_status": "", 
            "date_time": "", 
            "notes": "", 
            "currency": "{{ settings.currency | default: 'AUD' }}", 
            "order_value": "{{ context.exports.order.sub_total }}",
            "tax_amount": "{{ context.exports.order.tax_amount }}",
            "shipping_amount": "{{ context.exports.order.shipping_amount | plus: form.properties.additional_shipping_cost }}",
            "total_amount": "{{ context.exports.order.total_amount }}",
            "amount_due": "{{ context.exports.order.total_amount }}",
            "free_shipping": {{ context.exports.order.free_shipping | default: false }},
            "total_discount_amount": "{{ context.exports.order.total_discount_amount }}"
        }
    }
callback_actions: >
    {%- comment -%}
    These actions are made intentionally on `callback_actions` and not on `async_callback_action` bec.
    confirmation page needs to be able to see the 'payment details' & cart summary. 
    {%- endcomment -%}
    {%- include 'modules/insites_core/insites_admin/insites_create_crm_on_submit',
        email: form.properties.billing_email,
        first_name: form.properties.billing_first_name,
        last_name: form.properties.billing_last_name,
        mobile_phone_number: form.properties.phone_number,
        model_id: form.id -%}

    {% log company_name, type: "Callback CRM Company" %}
    {%- include 'modules/ins_template_ecommerce/checkout/create_crm_company_on_submit',
        user_id: context.exports.user_id,
        company_name: form.properties.billing_company_name -%}

    {%- comment -%}START: Checkout callback process
        - API call to Stripe (Payment)
        - Create / Update models
        - Trigger Email & API callback via GraphQL
    {%- endcomment -%}
    {%- include 'modules/ins_template_ecommerce/checkout/callback_init', 
        form: form
        context: context -%}
    {%- comment -%}END: Checkout callback process{%- endcomment -%}
---

{% form 
    html-id: "checkout-form"
    html-onsubmit:"return Checkout.events.checkoutFormSubmit(event);"
    html-novalidate: true %}

    <input type="hidden" id="hidden_billing_phone" 
        name="{{ form.fields.properties.billing_phone.name }}"
        value="{{ form.fields.properties.billing_phone.value }}" />

    <input type="hidden" id="hidden_shipping_phone" 
        name="{{ form.fields.properties.shipping_phone.name }}"
        value="{{ form.fields.properties.shipping_phone.value }}" /> 

    <!-- Account Details -->
    {% include 'modules/ins_template_ecommerce/checkout/account_details' %}
    <!-- END: Contact Person Fields -->

    <!-- Shipping Details -->
    {% include 'modules/ins_template_ecommerce/checkout/shipping_details' %}
    <!-- END: Shipping Details -->

    <!-- Payment Details -->
    {%- include 'modules/insites_ecommerce/shared/api_credentials' -%}
    {%- comment -%} 
    Stripe API keys 
    - pOS `context.exports.payments`
        context.exports.payments.gateway = stripe object
        context.exports.payments.live_mode = true/false (gateway mode: test / live)
        context.exports.payments.secret = ~ stripe secret key ~
    {%- endcomment -%}

    {% include 'modules/ins_template_ecommerce/checkout/payment_details' %}
    <!-- END Payment Details -->
    
{% endform %}

<!-- Stripe Element -->
{%- include 'modules/ins_template_ecommerce/forms/stripe_element',
    cc_field_id: "checkout-credit-card"
    email_field_id: "billing-email" -%}
<!-- END Stripe Element -->

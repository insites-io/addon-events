---
name: remove_from_cart
resource: modules/insites_ecommerce/insites_cart
resource_owner: anyone
redirect_to: /shopping-cart
fields: {}
callback_actions: >
  {%- graphql user_data = 'modules/ins_template_ecommerce/account/get_current_user' -%}
  {%- assign user = user_data.current_user -%}

  {% log user, type: "current user === " %}

  {%- if user -%}
    {%- assign user_id = user.id -%}
  {%- else -%}
    {%- assign user_id = context.session.session_id -%}
  {%- endif -%}

  {% comment %} Check & Update Cart Discount Codes {% endcomment %}
  {% graphql discount_codes = "modules/ins_template_ecommerce/discount_code/get_cart_discount_codes" 
        user_id: user_id,
        discount_debited: false
        | dig: 'items' | dig: 'results' %}

  {%- for item in discount_codes -%}
    {%- assign code = item.discount_code.properties -%}
    {% parse_json payload %}
    {
        "check_duplicates": false,
        "form_update": true,
        "form_delete": true,
        "form_id": "{{ item.id }}",
        "user_id": "{{ user_id }}",
        "discount_code": "{{ code.discount_code }}"
    }
    {% endparse_json %}
    {% function validate_code = "modules/ins_template_ecommerce/checkout/validate_discount_code"
        payload: payload %}
  {%- endfor -%}
---

{% form 
    html-novalidate: true
    html-enctype="multipart/form-data"
    html-onsubmit:"return shoppingCart.methods.validateRemoveForm(event);"
    method: "delete" %}
  <ins-button label="REMOVE" icon="icon-close" color="red" size="small" type="submit" class="removeBtn"></ins-button>
{% endform %}
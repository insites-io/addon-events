{%- comment -%}
By adding the global content to the top of the layout
It can be accessed in the includes without calling the GraphQL again
It IS NOT accessable in {{content_for_layout}} which includes the specific page
{%- endcomment -%}
{%- include "modules/website/data/global_content" -%}
{%- assign global = context.exports.global -%}

{%- comment -%} Used by the fragment cache in the layout {%- endcomment -%}
{%- include "modules/website/layout_fragment_cache_key" -%}

<!doctype html>
<html class="no-js" lang="en">
    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, height=device-height, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, viewport-fit=cover">
    <meta content="authenticity_token" name="csrf-param">
    <meta content="{{ context.authenticity_token }}" name="csrf-token">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    {%- comment -%}
    <!-- Unique to dynamic layouts to get the title and description to dynamic content-->
    {%- endcomment -%}

    <!-- [Schema] -->
    {%- if context.params.slug2 and context.params.slug == "products" -%}
        {%- include 'modules/insites_ecommerce/seo', 
            type: "product",
            slug: context.params.slug2 -%}
    {%- else -%}
        {% comment %} {%- include 'modules/insites_layouts/seo' -%} {% endcomment %}
    {%- endif -%}
    
    {% include 'modules/website/layout/pixel_tracking' %}

    {%- comment -%}
    <!-- Try to limit assets that are part of the head / technical head to minimize page size & improve page performance.
    Assets like 'Google Map API', should only be referenced as needed. -->
    {%- endcomment -%}


    {%- capture head_key -%} {{ context.exports.layout_cache_key.cache_key | append: "-head" }} {%- endcapture -%}
    {%- cache head_key -%}
    <!-- [Preload] -->
    {%- comment -%}<script src="{{ 'scripts/vendor/foundation.min.js' | asset_url }}" defer></script>{%- endcomment -%}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@9" defer></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.css">
    <script src="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.js"></script>

    <!-- [Insites Assets] -->
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cabin:ital,wght@0,400;0,500;0,700;1,400;1,700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600;1,700&display=swap" >
    <!-- Font Icons -->
    <link rel="stylesheet" href="https://components.insites.io/latest/css/insites-font-icons.css">
    <!-- [Project Assets] -->
    {% include 'modules/website/layout/technical_head' %}
    {%- endcache -%}
    
</head>
<body>
    <div class="main-wrap">
        {%- assign slug_type = 'error' -%}
        {%- comment -%}Check if has slug2{%- endcomment -%}
        {%- if context.params.slug2 -%}

            {%- comment -%}Check via graphql if there is a category with slug2{%- endcomment -%}
            {%- graphql slug2_cat = 'modules/ecommerce/shop/get_category_menu', slug: context.params.slug2 | dig: 'items' | dig: 'results' | first -%}
            {%- if slug2_cat -%}
                {%- assign slug_type = 'category' -%}
            {%- endif -%}
                
            {%- comment -%}Check via graphql if there is a product with slug2{%- endcomment -%}
            {%- graphql slug2_prod = 'modules/ecommerce/shop/get_product_detail_menu', slug: context.params.slug2 | dig: 'items' | dig: 'results' | first -%}            
            {%- if  slug2_prod -%}
                {%- assign slug_type = 'product' -%}
            {%- endif -%}
            
        {%- endif -%}
        
        {% include 'modules/website/layout/header' %}

        {%- if context.params.slug2 -%}
            <div class="breadbrumbs__wrapper wrapper">
                <div class="grid-container">
                    <div class="breadcrumbs">{%- comment -%}{% if slug_type != 'product' %}text-center{% endif %}{%- endcomment -%}
                        <span>
                            <a href="/products">Product</a>    
                        </span>
                        <i class="icon-chevron-right"></i>
                        <!-- <span>&gt;</span> -->
                        {%- if slug_type == 'product' -%}
                            <span class="active">{{ slug2_prod.name }}</span>
                        {%- else -%}
                            <span class="active">{{ slug2_cat.name }}</span>
                        {%- endif -%}
                    </div>
                </div>
            </div>
        {%- endif -%}
        <div class="wrapper">
            <div class="grid-container">
                {{ content_for_layout }}
            </div>
        </div>
        <div class="spacer section"></div>
    </div>
    {%- capture foot_key -%} {{ context.exports.layout_cache_key.cache_key | append: "-footer_section"}} {%- endcapture -%}
    {%- cache foot_key -%}
    {% include 'modules/website/layout/footer' %}
    {% include 'modules/website/layout/foot' %}
    {%- endcache -%}

</body>

</html>


{%- comment -%}
By adding the global content to the top of the layout
It can be accessed in the includes without calling the GraphQL again
It IS NOT accessable in {{content_for_layout}} which includes the specific page
{%- endcomment -%}
{%- include "modules/ins_template_website/data/global_content" -%}
{%- assign global = context.exports.global -%}

{%- comment -%}
General layout for pages
{%- endcomment -%}
<!doctype html>
<html class="no-js" lang="en">
    {%- if context.environment == "staging" -%}
    <!-- start layout: user profile layout  -->
    {%- endif -%}
  <head>
    
    {% include 'modules/ins_template_website/layout/head' %}
    <!-- [google Maps] -->
    {% include 'modules/ins_template_website/layout/googlemaps' %}

    {%- comment -%}
    <!-- Try to limit assets that are part of the head / technical head to minimize page size & improve page performance.
    Assets like 'Google Map API', should only be referenced as needed. -->
    {%- endcomment -%}
  </head>
  <body>
    <div class="main-wrap">
      {% include 'modules/ins_template_website/layout/header' %}
      {% include 'modules/ins_template_website/content/layout/page-header' %}

      <div class="wrapper">
        <div class="grid-container">
          <div class="spacer xxxx-large"></div>
          {{ content_for_layout }}
          <div class="spacer section"></div>

        </div>
      </div>

    </div>

    {% include 'modules/ins_template_website/layout/footer' %}
    {% include 'modules/ins_template_website/layout/foot' %}
    </body>

    {%- if context.environment == "staging" -%}
    <!-- end layout: user profile layout   -->
    {%- endif -%}
</html>


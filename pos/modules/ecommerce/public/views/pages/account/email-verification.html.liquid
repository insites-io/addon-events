---

{%- graphql g = 'modules/ins_template_ecommerce/account/get_user_with_password_token', email: params.email -%}
{% assign token = context.location.search.token %}
{% assign user_id = g.users.results[0].id %}
{% assign token_valid = token | is_token_valid: user_id %}

{% if user_id == blank or token_valid == false 
        or g.users.results[0].default[0].password_token != params.token %}

    <div class="sign-up">
        <div class="grid-x align-center">
            <div class="large-5 medium-9 samll-12 cell text-center">
                <div class="spacer xxx-large"></div>
                <div class="spacer x-large"></div>
                <p><strong>Unfortunately, provided token is not valid anymore.<br/> Please request another verification instruction by trying to <a href="/sign-up">sign up</a> again.</strong></p>
                <div class="spacer section"></div>
            </div>
        </div>
    </div>

{% else %}
    {% graphql verifyResult = 'modules/ins_template_ecommerce/account/verify_email', 
        id: user_id, token: g.users.results[0].default[0].password_token %}

    {% if verifyResult.items  %}

        {%- parse_json messageInfo -%}
        {
            "title" : "Success",
            "type": "success",
            "message": "<p><strong>Your email has been verified. You may now continue to <a href='/sign-in'>sign in</a>.</strong></p>"
        }
        {%- endparse_json -%}
        {%- include 'modules/ins_template_ecommerce/system/form-result', messageInfo: messageInfo -%}

    {% endif %}
    
{% endif %}


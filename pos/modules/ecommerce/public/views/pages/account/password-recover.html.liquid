{%- if context.flash.notice != blank -%}

{%- parse_json messageInfo -%}
{
    "title" : "Success",
    "type": "success",
    "message": "<p>If you provided the right email, we will send you the reset password instructions.</p><p>Go to <a href='/sign-in'>sign in</a>"
}
{%- endparse_json -%}
{%- include 'modules/ins_template_ecommerce/system/form-result', messageInfo: messageInfo -%}

{%- else -%}

<div class="sign-up grid-x">
    <div class="large-offset-4 large-4 medium-offset-3 medium-6 small-12 cell">
        <h1 class="heading-1 text-center">Forget your password?</h1>
        <div class="spacer x-small"></div>
        <p class="text-center">Enter your email address below and we'll get you back on track</p>
        <div class="spacer x-large"></div>

        {%- include_form 'modules/ins_template_ecommerce/password_recover' -%}
    </div>
</div>

{%- endif -%}



<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>

{%- if context.environment == "staging" -%}
    <script src="{{ 'modules/ins_template_ecommerce/services/apiServices.js' | asset_url }}"></script>

---


{%- graphql g = 'modules/ins_template_ecommerce/account/get_user_with_password_token', email: params.email -%}
{% assign token_valid = params.token | is_token_valid: g.users.results[0].id %}


{%- if context.flash.notice or context.flash.alert -%}
{%- comment -%} If any flash notice or alert is pressent {%- endcomment -%}

{%- if context.flash.notice != blank -%}
{%- parse_json messageInfo -%}
{
    "title" : "Success",
    "type": "success",
    "message": "<p>Your password has been reset. You can now proceed to <a href='/sign-in'>sign in.</a></p>"
}
{%- endparse_json -%}
{%- include 'modules/ins_template_ecommerce/system/form-result', messageInfo: messageInfo -%}
{%- else -%}
<div class="sign-up">
    <div class="grid-x align-center">
        <div class="small-12 cell spacer xxx-large"></div>
        <div class="large-4 medium-9 small-12 cell">
            <h1 class="text-center">Password Reset</h1>
            {%- comment -%}
            <div class="spacer x-small"></div>
            <p>For a more secure password, please try to make your password at least between 8 - 36 characters, and should at least have 1 upper-case letter and at least 1 number.</p>
            {%- endcomment -%}
        </div>
        <div class="small-12 cell spacer x-large"></div>
        <div class="large-4 medium-9 small-12 cell">
            {%- include_form 'modules/ins_template_ecommerce/password_reset', id:g.users.results[0].id  -%}
        </div>
        <div class="small-12 cell spacer section"></div>
    </div>
</div>
{%- endif -%}

{%- else -%}
{%- comment -%} If there is no flash notice or alert {%- endcomment -%}


{% if g.users.results[0].id == blank or token_valid == false or g.users.results[0].default[0].password_token != params.token %}
<div class="sign-up">
    <div class="grid-x align-center">
        <div class="large-5 medium-9 samll-12 cell">
            <div class="spacer xxx-large"></div>
            <h1 class="text-center">Info</h1>
            <div class="spacer x-large"></div>
            Unfortunately, provided token is not valid anymore. Please request password instructions again.
            
            <div class="spacer section"></div>
        </div>
    </div>
</div>
{%- else -%}
<div class="sign-up">
    <div class="grid-x align-center">
        <div class="small-12 cell spacer xxx-large"></div>
        <div class="large-4 medium-9 small-12 cell">
            <h1 class="text-center">Password Reset</h1>
            {%- comment -%}
            <div class="spacer x-small"></div>
            <p>For a more secure password, please try to make your password at least between 8 - 36 characters, and should at least have 1 upper-case letter and at least 1 number.</p>
            {%- endcomment -%}
        </div>
        <div class="small-12 cell spacer x-large"></div>
        <div class="large-4 medium-9 small-12 cell">
            {%- include_form 'modules/ins_template_ecommerce/password_reset', id:g.users.results[0].id  -%}
        </div>
        <div class="small-12 cell spacer section"></div>
    </div>
</div>
{%- endif -%}


{%- endif -%}


<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
    <script src="{{ 'modules/ins_template_ecommerce/services/apiServices.js' | asset_url }}"></script>
    <script src="{{ 'modules/ins_template_ecommerce/scripts/login-scripts.js' | asset_url }}"></script>
{%- else -%}
    <script src="{{ 'modules/ins_template_ecommerce/services/apiServices.min.js' | asset_url }}"></script>
    <script src="{{ 'modules/ins_template_ecommerce/scripts/login-scripts.min.js' | asset_url }}"></script>
{%- endif -%}
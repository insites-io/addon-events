---
slug: sign-in
layout: modules/ins_template_website/system_pages
# enable_profiler: true
searchable: true
max_deep_level: 1
metadata: {
    "status": "published",
    "page_type": "system", ## content, system or endpoint
    "og:url": "{{ context.exports.global.company_url | strip }}",
    "og:type": "",
    "og:image": "",
    "og:title": "Sign In | {{ context.exports.global.company_name | strip }}",
    "og:description": "Sign In | {{ context.exports.global.company_name | strip }}",
    "og:site_name": "{{ context.exports.global.company_name | strip }}",
    "meta_title": "Sign In | {{ context.exports.global.company_name | strip }}",
    "page_title": "Sign In | {{ context.exports.global.company_name | strip }}",
    "meta_description": "Sign In | {{ context.exports.global.company_name | strip }}",
    "canonical_url": "",
    "search_engine_visibility": false,
    "sitemap_enabled": false,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "0", ## secondary order (ASC)
    "sitemap_changefreq": "never"
}
## dynamic_cache:
##   layout: true
##   key: |-
##     {%- parse_json models -%}
##       [
##         "modules/ins_template_website/main_menu",
##         "modules/insites_layouts/insites_global_content"
##       ]
##     {%- endparse_json -%}

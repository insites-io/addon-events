{%- if context.flash.notice != blank -%}
 
    {%- parse_json messageInfo -%}
    {
    "title" : "Account Created",
    "type": "success",
    "message": "<p><strong>An email has been sent to the address you provided for verification.</strong></p><p>You can also proceed to <a href='/sign-in'>sign in.</a></p>"
    }
    {%- endparse_json -%}
    {%- include 'modules/ins_template_ecommerce/system/form-result', messageInfo: messageInfo -%}
  

{%- else -%}


<div class="sign-up">
    <div class="grid-x align-center">
        <div class="small-12 cell spacer xxx-large"></div>
        <div class="small-12 cell">
            <h1 class="text-center">Create an account</h1>
        </div>
        <div class="small-12 cell spacer x-large"></div>
        <div class="large-4 medium-8 small-12 cell">
            {%- include_form 'modules/ins_template_ecommerce/sign_up' -%}
        </div>
        <div class="small-12 cell spacer section"></div>
    </div>
</div>

{%- endif -%}


<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
    <script src="{{ 'modules/ins_template_ecommerce/services/apiServices.js' | asset_url }}"></script>
    <script src="{{ 'modules/ins_template_ecommerce/scripts/login-scripts.js' | asset_url }}"></script>
{%- else -%}
    <script src="{{ 'modules/ins_template_ecommerce/services/apiServices.min.js' | asset_url }}"></script>
    <script src="{{ 'modules/ins_template_ecommerce/scripts/login-scripts.min.js' | asset_url }}"></script>
{%- endif -%}
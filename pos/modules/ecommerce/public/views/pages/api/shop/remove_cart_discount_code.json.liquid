---
{%- assign id = context.params.id | parse_json -%}
{%- assign status = 200 -%}


{% comment %} Step 1: Check if code is being removed belongs to the customer {% endcomment %}
{%- if context.current_user.id -%}
    {%- assign user_id = context.current_user.id -%}
{%- else -%}
    {%- assign user_id = context.session.session_id -%}
{%- endif -%}

{% graphql discount = "modules/ins_template_ecommerce/discount_code/get_cart_discount_codes"
    page: 1, size: 1
    id: id,
    user_id: user_id,
    discount_debited: false
    | dig: 'items' | dig: 'results' | first %}

{% comment %} Step 2: If it is valid, cart discount code can be deleted {% endcomment %}
{%- if discount -%}
    {% graphql remove = "modules/ins_template_ecommerce/discount_code/delete_cart_discount_code",
        id: id %}
{%- endif -%}

{% parse_json data %}
    {{ remove | fetch: "items" }}
{% endparse_json %}

{%- comment -%}Status code 400: API or GraphQL error{%- endcomment -%}
{%- if data == blank %}
  {%- assign status = 400 -%}
{%- endif -%}

{%- response_status status -%}
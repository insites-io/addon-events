---
slug: products
layout: modules/ins_template_ecommerce/shop-layout
# enable_profiler: true
searchable: "true"
max_deep_level: 2
redirect_to: |-
  {%- if context.params.slug2 -%}
    {%- graphql slug2_cat = 'modules/ins_template_ecommerce/shop/get_category', slug: context.params.slug2 -%}
    {%- graphql slug2_prod = 'modules/ins_template_ecommerce/shop/get_product_detail', slug: context.params.slug2 -%}
    {%- if slug2_cat and slug2_cat.items.total_entries > 0 -%}
    {%- elsif slug2_prod and slug2_prod.items.total_entries > 0 -%}
    {%- else -%}
        /404
    {%- endif -%}
  {%- endif -%}
metadata: {
    "status": "published",
    "page_type": "content", ## content, system or endpoint
    "og:url": "{{ context.exports.global.company_url | strip }}",
    "og:type": "",
    "og:image": "",
    "og:title": "Products | {{ context.exports.global.company_name | strip }}",
    "og:description": "Products | {{ context.exports.global.company_name | strip }}",
    "og:site_name": "{{ context.exports.global.company_name | strip }}",
    "meta_title": "Products | {{ context.exports.global.company_name | strip }}",
    "page_title": "Products | {{ context.exports.global.company_name | strip }}",
    "meta_description": "Products | {{ context.exports.global.company_name | strip }}",
    "canonical_url": "",
    "search_engine_visibility": true,
    "sitemap_enabled": true,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "2", ## secondary order (ASC)
    "sitemap_changefreq": "daily"
}

---

{% comment -%}
URL Structures: 
/products/mens-shoes
/products/mens-shoes/product_id
{% endcomment -%}

{%- assign slug_type = 'error' -%}
{%- comment -%}Check if has slug2{%- endcomment -%}
{%- if context.params.slug2 -%}
    {%- comment -%}Check via graphql if there is a category with slug2{%- endcomment -%}
    {%- graphql slug2_cat = 'modules/ins_template_ecommerce/shop/get_category', slug: context.params.slug2 -%}
    {%- if slug2_cat.items and slug2_cat.items.total_entries > 0 -%}
    {%- assign category_slug2 = slug2_cat.items.results[0] -%}
    {%- assign slug_type = 'category' -%}
    {%- endif -%}

    {%- comment -%}Check via graphql if there is a product with slug2{%- endcomment -%}
    {%- graphql slug2_prod = 'modules/ins_template_ecommerce/shop/get_product_detail', slug: context.params.slug2 -%}
    {%- if slug2_prod.items and slug2_prod.items.total_entries > 0 -%}
    {%- assign product_slug2 = slug2_prod.items.results[0] -%}
    {%- assign slug_type = 'product' -%}
    {%- endif -%}
    
{%- endif -%}

<div class="ecommerce-wrapper grid-container">
    <div>
        <div class="spacer x-large"></div>
    </div>

    {%- if context.params.slug2 -%}
        {%- if slug_type == 'product' -%}
        {%- include 'modules/ins_template_ecommerce/products/detail' -%}
        {%- else -%}
        {%- include 'modules/ins_template_ecommerce/products/list' -%}
        {%- endif -%}
    {%- else -%}
        {%- include 'modules/ins_template_ecommerce/products/list' -%}
    {%- endif -%}

</div>



{%- if context.params.slug2 -%}

    {%- if slug_type == 'product' -%}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
        {%- if context.environment == "staging" -%}
            <script src="{{ 'modules/ins_template_ecommerce/services/apiServices.js' | asset_url }}"></script>
            <script src="{{ 'modules/ins_template_ecommerce/scripts/product-detail.js' | asset_url }}"></script>
        {%- else -%}
            <script src="{{ 'modules/ins_template_ecommerce/services/apiServices.min.js' | asset_url }}"></script>
            <script src="{{ 'modules/ins_template_ecommerce/scripts/product-detail.min.js' | asset_url }}"></script>
        {%- endif -%}
    {%- else -%}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
        {%- if context.environment == "staging" -%}
            <script src="{{ 'modules/ins_template_ecommerce/services/apiServices.js' | asset_url }}"></script>
            <script src="{{ 'modules/ins_template_ecommerce/scripts/product-list.js' | asset_url }}"></script>
        {%- else -%}
            <script src="{{ 'modules/ins_template_ecommerce/services/apiServices.min.js' | asset_url }}"></script>
            <script src="{{ 'modules/ins_template_ecommerce/scripts/product-list.min.js' | asset_url }}"></script>
        {%- endif -%}
    {%- endif -%}

{%- else -%}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
    {%- if context.environment == "staging" -%}
        <script src="{{ 'modules/ins_template_ecommerce/services/apiServices.js' | asset_url }}"></script>
        <script src="{{ 'modules/ins_template_ecommerce/scripts/product-list.js' | asset_url }}"></script>
    {%- else -%}
        <script src="{{ 'modules/ins_template_ecommerce/services/apiServices.min.js' | asset_url }}"></script>
        <script src="{{ 'modules/ins_template_ecommerce/scripts/product-list.min.js' | asset_url }}"></script>
    {%- endif -%}
{%- endif -%}



{%- if context.flash and context.flash.notice == "Success-AddCart" -%}
<script>
setTimeout(() => {
    App.events.notyf('success', "Product has been added to cart!");
}, 200);
</script>
{% endif -%}


{%- if context.flash and context.flash.notice == "Success-OutStockNotify" -%}
<script>
setTimeout(() => {
    App.events.notyf('success', "Your inquiry has been sent!");
}, 200);
</script>
{% endif -%}
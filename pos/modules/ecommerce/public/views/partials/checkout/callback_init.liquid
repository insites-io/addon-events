{% log "================ START CALLBACK INIT: Processing checkout and payment ================" %}

{%- comment -%}GET Cart data{%- endcomment -%}
{% include 'modules/ins_template_ecommerce/checkout/compute_order_summary',
    cart_id: cart_id,
    cart_ids: cart_ids %}

{%- comment -%}
Step 1: Get gateway settings from INS Ecommerce settings and process payment
{%- endcomment -%}
{%- graphql settings = "modules/ins_template_ecommerce/system/get_settings" 
    | dig: 'items' | dig: 'results' | first | dig: 'properties' -%}
{%- assign gateway = settings.gateway_name | downcase -%}
{%- assign payment_status = "Failed" -%}
{%- case gateway -%}
    {%- when 'stripe' -%}
        {%- comment -%}Step 1-A: Stripe payment process{%- endcomment -%}
        {%- include 'modules/ins_template_ecommerce/stripe/payment/checkout_payment', 
            form: form,
            user_id: context.exports.user_id,
            company_id: context.exports.company_id,
            company_name: context.exports.company_name,
            context: context,
            account_verified: user.current_user.customer[0].is_activated -%}
        {%- comment -%}
        If new / other payment gateways are supported, insert process here:
        {%- endcomment -%}

    {%- else -%}
        {% log "ERROR: Payment gateway invalid / not set. Please check INS Ecommerce settings." %}
{%- endcase -%}

    {%- comment -%}
    Capture gateway reposnse and set status
    {%- endcomment -%}
    {%- assign status = context.exports.payment_response.status | downcase -%}
    {%- assign user_id = context.exports.user_id | downcase -%}
    {%- assign order_id = form.id | downcase -%}
    {%- if status == 'succeeded' -%}
        {%- assign status = 'success' -%}
        {%- assign cart_status = "Paid" -%}
        {%- assign order_payment_status = "Paid" -%}
        {%- assign order_status = "Complete" -%}
    {%- else -%}
        {%- assign status = 'failed' -%}
        {%- assign cart_status = "Failed" -%}
        {%- assign order_payment_status = "Failed" -%}
        {%- assign order_status = "Open" -%}
    {%- endif -%}


{%- comment -%}
Step 2: Update inventory, cart and order models.
{%- endcomment -%}
{% include 'modules/ins_template_ecommerce/checkout/callback_update_models'
    status: status,
    cart_status: cart_status,
    order_status: order_status,
    order_payment_status: order_payment_status,
    user_id: user_id,
    order_id: order_id,
    form: form,
    settings: settings %}


{%- comment -%}
Step 3: (optional) Create address models
{%- endcomment -%}
{%- if context.current_user.id -%}
    {% include 'modules/ins_template_ecommerce/checkout/callback_create_address', 
        user_id: user_id,
        form: form %}
{%- endif -%}



{%- comment -%}
Step 4: Trigger autoresponder, workflow email & API 
{%- endcomment -%}
{% parse_json customer_info %}
{
    "email": "{{ form.properties.billing_email }}",
    "first_name": "{{ form.properties.billing_first_name }}",
    "last_name": "{{ form.properties.billing_last_name }}"
}
{% endparse_json %}
{% parse_json data %}
{
    "payment_response": {{ context.exports.payment_response }},
    "customer_info": {{ context.current_user | default: customer_info }},
    "cart_ids": {{ context.exports.order.cart_ids }},
    "order_info": {{ context.exports.updated_order.items }},
    "total_discounted_amount": {{ context.exports.order.total_discount_amount }}, 
    "form": {{ form }}
}
{% endparse_json %}
{% log data, type: "==== Email & API: Payload data ====" %}
{% log status, type: "==== Email & API: status ====" %}

    {%- comment -%}Step 4.1 Workflow & Email Notification{%- endcomment -%}
    {% include 'modules/ins_template_ecommerce/checkout/callback_email_notifications', 
        status: status,
        data: data %}

    {%- comment -%}Step 4.2: Trigger API Call{%- endcomment -%}
    {% include 'modules/ins_template_ecommerce/checkout/callback_api_call', 
        status: status,
        data: data %}

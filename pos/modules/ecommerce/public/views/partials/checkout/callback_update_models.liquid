
{%- assign date_time = "now" | date: "%Y-%m-%dT%H:%M:%SZ" -%}
{%- assign amount_due = context.exports.order.total_amount -%}
{%- capture payment_gateway_details -%}{{ context.exports.payment_response }}{%- endcapture -%}
{%- parse_json card -%}
{
    "last4": "{{ context.exports.payment_response.source.last4 }}",
    "brand": "{{ context.exports.payment_response.source.brand }}",
    "exp_month": "{{ context.exports.payment_response.source.exp_month }}",
    "exp_year": "{{ context.exports.payment_response.source.exp_year }}"
}
{%- endparse_json -%}
{%- if status == 'success' -%}
    {%- assign amount_due = 0.0 -%}
{%- endif -%}


{%- comment -%}Step 2.0: Create payment data{%- endcomment -%}
{% graphql payment = "modules/ins_template_ecommerce/payment/create_payment", 
    order_id: order_id,
    payment_source: "Payment Gateway",
    payment_status: order_payment_status,
    payment_gateway_name: settings.gateway_name,
    payment_gateway_details: payment_gateway_details,
    notes: "",
    date_time: date_time,
    last_updated_by_id: user_id,
    is_enabled: true,
    card_last4: card.last4,
    card_brand: card.brand,
    card_exp_month: card.exp_month,
    card_exp_year: card.exp_year,
    currency: settings.currency,
    order_value: context.exports.order.total_amount,
    amount: context.exports.order.total_amount,
    amount_due: amount_due %}
{% log "==== Payment Created ====" %}

{%- comment -%}Step 2.1: Update cart status: Paid / Failed{%- endcomment -%}
{% comment %} 
# Updated for pOS release for `sync` <data>_update_all [Ticket: NMS-4453]
{% endcomment %}
{% log user_id, type: "---- User ID ----" %}
{% log order_id, type: "---- order ID ----" %}
{% log form.id, type: "---- form ID ----" %}
    {% log context.exports.payment_response, type: "payment_response" %}
{% log context.exports.order.cart_ids, type: "---- Cart IDs ----" %}

{% graphql cart = "modules/ins_template_ecommerce/cart/update_status_cart_ids", 
    ids: context.exports.order.cart_ids,
    status: cart_status,
    user_id: user_id,
    order_id: order_id %} 
    
{% log cart, type: "==== Cart Updated ====" %} 


{% comment %}Step 2.2: Update Cart Discount IDs {% endcomment %}
{% log context.exports.order.cart_discount_code_idsan, type: "---- Update Cart Discount IDs ----" %}
{% graphql cart_discount_codes = "modules/ins_template_ecommerce/discount_code/callback_update_cart_discount_codes",
    ids: context.exports.order.cart_discount_code_ids,
    discount_debited: true,
    user_id: user_id,
    order_id: order_id %}

{% log cart_discount_codes, type: "==== Cart Discount Codes Updated ====" %} 


{%- comment -%}Step 2.3: Update order status fields{%- endcomment -%}
{% graphql updated_order = "modules/ins_template_ecommerce/orders/update_order", 
    id: form.id,
    amount_due: amount_due,
    date_time: date_time,
    user_id: user_id,
    order_payment_status: order_payment_status,
    order_status: order_status,
    order_number: order_id,
    shipping_company_name: form.properties.shipping_company_name,
    billing_company_name: form.properties.billing_company_name,
    gateway_id: context.exports.payment_response.id,
    gateway_customer_id: context.exports.payment_response.source.customer %}

{% log updated_order, type: "==== Order Updated ====" %}



{%- comment -%}Step 2.4: Update inventory{%- endcomment -%}
{%- if status == 'success' -%}
{%- assign model_name = "modules/insites_ecommerce/insites_product" -%}
    
    {% comment %} Discount Code inventory {% endcomment %}
    {% log context.exports.order.discount_code_ids, type: "---- Update Discount IDs inventory ----" %}
    {% graphql discount_codes = "modules/ins_template_ecommerce/discount_code/callback_update_discount_codes",
        ids: context.exports.order.discount_code_ids %}
    {% log discount_codes, type: "==== Discount Codes Max # of Use Updated ====" %} 

    {% comment %} Product Inventory {% endcomment %}
    {%- if settings.inventory_tracking -%}
        {% log "==== Inventory tracking is enabled: updating inventory ==== " %}
        {% log context.exports.order.cart_ids, type: "Update card ids" %}
        {%- for cart_id in context.exports.order.cart_ids -%}
            {%- comment -%}2.3.1 Check if cart item was variant or main product{%- endcomment -%}
            {%- graphql cart = 'modules/ins_template_ecommerce/cart/get_cart', 
                id: cart_id
                | dig: 'items' | dig: 'results' | first -%}
            {% log cart, type: "==== Cart ==== " %}

            {%- assign qty_purchased = cart.properties.quantity | times: 1.0 -%}
            {%- comment -%}Check if cart item was variant or main product{%- endcomment -%}
            {%- if cart.properties.product_variant_id and cart.product.variant_schema -%}
                {%- comment -%}IF variant id and variant schema, deduct purchase from variant inventory{%- endcomment -%}
                {%- assign model_name = cart.product.variant_schema -%}
                {%- assign cart_item_id = cart.properties.product_variant_id -%}

            {%- else -%}
                {%- comment -%}ELSE inventory will be deducted on product model{%- endcomment -%}
                {%- assign cart_item_id = cart.properties.product_id -%}
            {%- endif -%}
            
            {%- comment -%}2.3.2 Deduct purchase from model variant / product{%- endcomment -%}
            {%- if cart_item_id -%}
                {%- graphql stock = "modules/ins_template_ecommerce/orders/update_stock_purchased"
                    id: cart_item_id
                    model_name: model_name
                    qty: qty_purchased -%}
                    
                {% log stock, type: "==== Stock updated ==== " %}
            {%- endif -%}
        {%- endfor -%}
    {%- else -%}
        {% log "==== Inventory tracking is disabled: inventory was not updated ==== " %}
    {%- endif -%}
{%- endif -%}


{% export updated_order %}
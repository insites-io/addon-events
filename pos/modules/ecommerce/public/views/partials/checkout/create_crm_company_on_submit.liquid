{% comment %} Check if company exist {% endcomment %}
{% comment %}  - IF does not exist, create CRM company {% endcomment %}
{% comment %}  - IF exist, get company id {% endcomment %}
{% comment %}  - Assign Contact to company {% endcomment %}

{%- liquid 

    if company_name and user_id
        graphql company = "modules/ins_template_ecommerce/crm/get_crm_company", page: 1, size: 1, company_name: company_name | dig: "items" | dig: "results" | first
        
        log company, type: "=== CRM company found"
        unless company.id 
            graphql company = "modules/ins_template_ecommerce/crm/create_crm_company", company_name: company_name | dig: "items" 
            log company, type: "-- CRM company created"
        endunless
        
        graphql assign_contact = "modules/ins_template_ecommerce/crm/assign_company_contact", id: user_id, company_id: company.id | dig: "items" 
        log assign_contact, type: "-- CRM contact assigned to company"

        assign company_id = company.id
        assign company_name = company.company_name
        
    endif

    export company_id
    export company_name -%}

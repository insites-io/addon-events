<div id="payment-details" class="hide">
    <h2 class="heading-1">Payment Info</h2>
    <div class="spacer xxx-large"></div>
    
    <div class="grid-x grid-padding-x">
        <div class="large-6 medium-6 small-12 cell">
            <h2 class="heading-2">Credit Card</h2>
        </div>
        <div class="large-6 medium-6 small-12 cell text-right">
            <div class="spacer x-small"></div>
            <ins-button type="button"
                id="add-card-btn"
                size="small"
                icon="icon-plus"
                label="Add Card">
            </ins-button>
        </div>
    </div>

    <div class="validate-credit-card">
        {% comment %} Credit Cards {% endcomment %}
        <div id="credit-card-fields" required class="card-fields">
            <div class="spacer x-large"></div>
            <p class="error-message hide">Credit Card is required.</p>
            <ins-input required validate
                field="hidden" 
                id="stripe-card"
                name="{{ form.fields.properties.stripe_credit_card.name }}" 
                value="{{ form.fields.properties.stripe_credit_card.value }}">
            </ins-input>
            <div id="card-options-list" card-grid="large-6 medium-6 small-12" class="grid-x grid-padding-x">
                {%- if context.current_user.id -%}
                    {%- graphql cards = "modules/ins_template_ecommerce/credit_card/get_credit_card", 
                        user_id: context.current_user.id
                        size: 50 | dig: 'items' -%}
                    {%- if cards.total_entries > 0 -%}
                        {%- assign hide = "hide" -%}
                    {%- endif -%}
                    {%- for card in cards.results -%}
                        <div class="large-6 medium-6 small-12 cell card-options">
                            <ins-credit-card 
                                data-id="{{ card.id }}" 
                                brand="{{ card.properties.brand }}"
                                last-four="{{ card.properties.last4 }}"
                                expiry-month="{{ card.properties.exp_month }}"
                                expiry-year="{{ card.properties.exp_year }}"
                                full-year
                                value="{{ card.properties.gateway_id }}">
                            </ins-credit-card>
                            <div class="spacer small"></div>
                        </div>
                    {%- endfor -%}
                {%- endif -%}
            </div>
        </div>
        
        <ins-card steady id="no-card" class="empty-state text-center {{ hide }}">
            No Cards Added
        </ins-card>
    </div>

    
    {% comment %}END: Credit Cards {% endcomment %}

    <div class="spacer xxx-large"></div>
    <div class="validate-address">
        <div class="grid-x grid-padding-x">
            <div class="large-6 medium-6 small-12 cell">
                <h2 class="heading-2">Billing Address</h2>
            </div>
            <div class="large-6 medium-6 small-12 cell text-right">
                {% comment %} {%- if context.current_user.id -%}
                    <div class="spacer x-small"></div>
                    <ins-button type="button"
                        class="add-address-btn"
                        name="billing-address-fields"
                        size="small"
                        icon="icon-plus"
                        label="New Address">
                    </ins-button>
                {%- endif -%} {% endcomment %}
            </div>
        </div>

        <div class="spacer x-large"></div>
        <ins-checkbox class="inline"
            id="same-billing"
            label="My billing address is the same as my shipping address">
        </ins-checkbox>
        <div class="spacer"></div>
        <p class="error-message hide">Billing address is required.</p>
        {%- if context.current_user.id -%}
            {%- graphql addresses = "modules/ins_template_ecommerce/user/get_user_address_list", 
                user_id: context.current_user.id 
                | dig: "items" | dig: "results" -%}

            {%- comment -%}Address cards{%- endcomment -%}
            {%- include 'modules/ins_template_ecommerce/layout/address_cards', 
                addresses: addresses,
                type: 'billing' -%}
        {%- endif -%}

        {% comment %} Billing Address Fields {% endcomment %}
        <div id="billing-address-fields" required class="address-fields">
            <div class="spacer"></div>
            <div class="grid-x grid-padding-x">
                <div class="large-12 medium-12 small-12 cell">
                    <ins-input address-lookup 
                        label="Search Addresss" 
                        id="billing-address-search"
                        name="billing"
                        placeholder="Search Addresss"
                        icon="icon-map-pin">
                    </ins-input>
                    <input type="hidden" billing-address-field
                        id="billing_address_id"
                        name="{{ form.fields.properties.billing_address_id.name }}" />
                </div>
                <div class="large-6 medium-6 small-12 cell">
                    <ins-input billing-address-field
                        required validate
                        label="Address 1*" 
                        id="billing_address_1"
                        placeholder="Address 1"
                        name="{{ form.fields.properties.billing_address_1.name }}" 
                        value="{{ form.fields.properties.billing_address_1.value }}" 
                        {% if form.errors['properties.billing_address_1'] %} has-error {% endif %}
                        error-message="{{ form.fields.properties.billing_address_1.validation.rules.presence.message }}">
                    </ins-input>
                </div>
                <div class="large-6 medium-6 small-12 cell">
                    <ins-input billing-address-field
                        label="Address 2" 
                        id="billing_address_2"
                        placeholder="Address 2"
                        name="{{ form.fields.properties.billing_address_2.name }}" 
                        value="{{ form.fields.properties.billing_address_2.value }}" 
                        {% if form.errors['properties.billing_address_2'] %} has-error {% endif %}
                        error-message="{{ form.fields.properties.billing_address_2.validation.rules.presence.message }}">
                    </ins-input>
                </div>
                <div class="large-6 medium-6 small-12 cell">
                    <ins-input billing-address-field
                        required validate
                        label="City*" 
                        id="billing_city"
                        placeholder="City"
                        name="{{ form.fields.properties.billing_city.name }}" 
                        value="{{ form.fields.properties.billing_city.value }}" 
                        {% if form.errors['properties.billing_city'] %} has-error {% endif %}
                        error-message="{{ form.fields.properties.billing_city.validation.rules.presence.message }}">
                    </ins-input>
                </div>
                <div class="large-6 medium-6 small-12 cell">
                    <ins-input billing-address-field
                        required validate
                        label="State*" 
                        id="billing_state"
                        placeholder="State"
                        name="{{ form.fields.properties.billing_state.name }}" 
                        value="{{ form.fields.properties.billing_state.value }}" 
                        {% if form.errors['properties.billing_state'] %} has-error {% endif %}
                        error-message="{{ form.fields.properties.billing_state.validation.rules.presence.message }}">
                    </ins-input>
                </div>
                <div class="large-6 medium-6 small-12 cell">
                    <ins-input billing-address-field
                        required validate
                        label="Zip / Postal Code*" 
                        id="billing_postcode"
                        placeholder="Zip / Postal Code"
                        name="{{ form.fields.properties.billing_postcode.name }}" 
                        value="{{ form.fields.properties.billing_postcode.value }}" 
                        {% if form.errors['properties.billing_postcode'] %} has-error {% endif %}
                        error-message="{{ form.fields.properties.billing_postcode.validation.rules.presence.message }}">
                    </ins-input>
                </div>
                <div class="large-6 medium-6 small-12 cell">
                    <ins-input billing-address-field
                        required validate
                        label="Country*" 
                        id="billing_country"
                        placeholder="Country"
                        name="{{ form.fields.properties.billing_country.name }}" 
                        value="{{ form.fields.properties.billing_country.value }}" 
                        {% if form.errors['properties.billing_country'] %} has-error {% endif %}
                        error-message="{{ form.fields.properties.billing_country.validation.rules.presence.message }}">
                    </ins-input>
                </div>
            </div>
        </div>
        {% comment %}END:Billing Address Fields {% endcomment %}
    </div>

    {%- comment -%}Check if there's items to pay for{%- endcomment -%}
    {%- include 'modules/ins_template_ecommerce/checkout/compute_order_summary' -%}
    <div class="grid-x grid-padding-x">
        <div class="large-12 medium-12 small-12 cell text-right">
            <div class="spacer small"></div>
            {%- graphql settings = "modules/ins_template_ecommerce/system/get_settings" 
                | dig: 'items' | dig: 'results' | first | dig: 'properties' -%}
            
            {%- assign gateway = settings.gateway_name | downcase | strip -%}
            {%- if gateway == '' -%}
                <ins-button disabled 
                    color="negative" 
                    label="Payment settings not configured, please contact website administrator.">
                </ins-button>
            {%- else -%}
                {%- if context.exports.order.total_amount > 0 -%}
                    <ins-button solid type="submit"
                        id="checkout-submit-btn"
                        label="Purchase Order">
                    </ins-button>
                {%- else -%}
                    <ins-button disabled 
                        color="negative" 
                        label="No items to pay">
                    </ins-button>
                {%- endif -%}
            {%- endif -%}
        </div>
    </div>
</div>
<div class="order-summary-wrapper">
    <h2 class="color-font-sub heading-2">
        {%- if context.location.pathname == '/confirmation' -%}
        Payment {% else %} Order {% endif %} Summary
    </h2>
    <div class="spacer x-large"></div>
    
    <div class="order-summary">
        {%- assign cart_status = status | capitalize | default: blank -%}
        {%- unless order_id -%}
        {%- if context.current_user.id -%}
                {%- assign user_id = context.current_user.id -%}
            {%- else -%}
                {%- assign user_id = context.session.session_id -%}
            {%- endif -%}
        {%- endunless -%}
    
        {% graphql cart = 'modules/ins_template_ecommerce/cart/get_cart', 
            user_id: user_id, 
            status: cart_status, 
            order_id: order_id
            | dig: 'items' | dig: 'results' %}

        {%- for item in cart -%}
        {%- assign item_amount = item.properties.product_price | times: item.properties.quantity -%}

        {%- if show_product -%}
        <div class="grid-x grid-padding-x body-large">
            <div class="product-name large-6 medium-8 small-6 cell">
                <div>{{ item.properties.product_name }}</div>
                <div>
                    <span class="attributes">{{ item.properties.product_variant }}</span>
                </div>
            </div>
            <div class="text-right large-3 medium-4 small-6 cell">
                {%- assign label = "pc" -%}
                {%- if item.properties.quantity > 1 -%}
                    {%- assign label = "pcs" -%}
                {%- endif -%}
                {{ item.properties.quantity }} {{ item.product.unit_label | default: label }}
            </div>
            <div class="text-right large-3 medium-12 small-12 cell">
                {%- assign item_amount = item_amount | divided_by: 100.0 | advanced_format: '%.2f' | default: "0.00" -%}
                {%- assign item_amount = item_amount | pricify -%}
                {%- unless item_amount contains '.' -%}
                    {%- assign item_amount = item_amount | append: '.00' -%}
                {%- endunless -%}
                {{ item_amount }}
            </div>
        </div>
            {%- unless forloop.last -%}
            <div class="spacer small"></div>
            {%- endunless -%}
        {%- endif -%}
        {%- endfor -%}
    </div>

    {%- if show_product and cart.size > 0 -%}
    <div class="spacer"></div>
    <hr>
    <div class="spacer"></div>
    {%- endif -%}
    
    {% comment %}--- GET ORDER COMPUTATION SUMMARY ---{% endcomment %}
    {%- include 'modules/ins_template_ecommerce/checkout/compute_order_summary' 
        order_id: order_id,
        user_id: user_id -%}

    <div class="order-subtotal">
        <div class="grid-x grid-padding-x body-large">
            <div class="large-6 medium-6 small-6 cell">
                Subtotal
            </div>
            <div class="large-6 medium-6 small-6 cell text-right">
                {%- assign sub_total = context.exports.order.sub_total | divided_by: 100 | advanced_format: '%.2f' | default: "0.00" -%}
                {%- assign sub_total = sub_total | pricify -%}
                {%- unless sub_total contains '.' -%}
                    {%- assign sub_total = sub_total | append: '.00' -%}
                {%- endunless -%}
                {{ sub_total }}
            </div>
        </div>
        <div class="spacer x-small"></div>
        <div class="grid-x grid-padding-x">
            <div class="large-6 medium-6 small-6 cell">
                Delivery & Handling
            </div>
            <div class="large-6 medium-6 small-6 cell text-right">
                {%- assign shipping_cost = context.exports.order.shipping_amount | divided_by: 100 | advanced_format: '%.2f' | default: "0.00" -%}
                {%- assign shipping_cost = shipping_cost | pricify -%}
                {%- unless shipping_cost contains '.' -%}
                    {%- assign shipping_cost = shipping_cost | append: '.00' -%}
                {%- endunless -%}
                {{ shipping_cost }}
            </div>
        </div>
        <div class="spacer x-small"></div>
        <div class="grid-x grid-padding-x">
            <div class="large-6 medium-6 small-6 cell">
                Tax
            </div>
            <div class="large-6 medium-6 small-6 cell text-right">
                {%- assign tax_amount = context.exports.order.tax_amount | divided_by: 100 | advanced_format: '%.2f' | default: "0.00" -%}
                {%- assign tax_amount = tax_amount | pricify -%}
                {%- unless tax_amount contains '.' -%}
                    {%- assign tax_amount = tax_amount | append: '.00' -%}
                {%- endunless -%}
                {{ tax_amount }}
            </div>
        </div>
    </div>

    <div class="spacer medium"></div>
    <hr>
    <div class="spacer medium"></div>

    {% comment %} Discount Codes {% endcomment %}
    {%- if order_id -%}
        {%- assign discount_debited = true -%}
    {%- else -%}
        {%- assign discount_debited = false -%}
    {%- endif -%}
    
    {% graphql discount_codes = "modules/ins_template_ecommerce/discount_code/get_cart_discount_codes" 
        user_id: user_id,
        order_id: order_id,
        discount_debited: discount_debited,
        | dig: 'items' | dig: 'results' %}

    {% if discount_codes.size > 0 %}
        <div class="list-discount-codes">
            <div class="grid-x">
                <div class="small-6 medium-6 large-8 cell">
                    <p class="body-large color-font-head"><b>Discounts</b></p>
                </div>
                <div class="small-6 medium-6 large-4 cell text-right">
                    {%- if context.exports.order.total_discount_amount > 0 -%}
                        {%- assign total_discount_amount = context.exports.order.total_discount_amount | divided_by: 100 | advanced_format: '%.2f' | default: "0.00" -%}
                        {%- assign total_discount_amount = total_discount_amount | pricify -%}
                        {%- unless total_discount_amount contains '.' -%}
                            {%- assign total_discount_amount = total_discount_amount | append: '.00' -%}
                        {%- endunless -%}
                        <p class="body-large color-font-head"><b>{{ total_discount_amount | prepend: '- '}}</b></p>
                    {%- endif -%}
                </div>
            </div>
            <div class="spacer medium"></div>
            {%- for item in discount_codes -%}
                {%- if order_id -%}
                    {%- assign code = item.properties -%}
                {%- else -%}
                    {%- assign code = item.discount_code.properties -%}
                {%- endif -%}
                
                {%- assign type = code.discount_type | downcase -%}
                {%- if context.params.slug == "confirmation" -%}
                    {%- parse_json validate_code -%}{ "is_valid": true }{%- endparse_json -%}
                {%- else -%}

                    {% comment %} Run function to validate & auto delete invalid codes {% endcomment %}
                    {% parse_json payload %}
                    {
                        "check_duplicates": false,
                        "form_delete": {{ form_delete | default: false }},
                        "form_update": {{ form_update | default: false }},
                        "form_id": "{{ item.id }}",
                        "user_id": "{{ user_id }}",
                        "discount_code": "{{ code.discount_code }}"
                    }
                    {% endparse_json %}
                    
                    {% function validate_code = "modules/ins_template_ecommerce/checkout/validate_discount_code"
                        payload: payload %}
                    {% comment %} End Function {% endcomment %}
                {%- endif -%}


                {%- if validate_code.is_valid == true or validate_code.is_valid == 'true' -%}
                    {%- if type contains "fix" -%}
                        {%- assign value = code.discount_value | advanced_format: "%.2f" -%}
                        {%- assign value = value | pricify -%}
                        {%- unless value contains '.' -%}
                            {%- assign value = value | append: '.00' -%}
                        {%- endunless -%}
                        {%- assign value = value | append: " Off" -%}
                    {%- elsif type contains "percent" -%}
                        {%- assign value = code.discount_value | replace: '.00', '.0' -%}
                        {%- assign value = value | replace: '.0', '' -%}
                        {%- assign value = value | append: "% Off" -%}
                    {%- else -%}
                        {%- assign value = code.discount_type -%}
                    {%- endif -%}
                    {%- unless value contains "hipping" -%}{% comment %} <-- not a typo {% endcomment %}
                        {%- liquid 
                            if type contains "shipping"
                                assign value = value | append: " Shipping"
                            endif
                        -%}
                    {%- endunless -%}
                    {%- if code.apply_to_total == true -%}
                        {%- assign value = value | append: " Total" -%}
                    {%- endif -%}

                    <div class="list-discount-codes--item" data-id="{{ item.id }}">
                        <div class="code-details">
                            <p class="font-head color-font-head">{{ code.discount_name }}</p>
                            <p class="body-small">{{ code.discount_code }} - {{ value }}</p>
                            {%- if code.minimum_cart_value > 0 -%}
                            <div class="spacer xx-small"></div>
                            <p class="body-small">Minimum ${{ code.minimum_cart_value | advanced_format: "%.2f" }} Purchase</p>
                            {%- endif -%}
                        </div>
                        {%- if show_discount_list -%}
                        <div class="icon-close"></div>
                        {%- endif -%}
                    </div>

                {%- endif -%}
            {%- endfor -%}
        </div>
        <div class="spacer medium"></div>
        <hr>
        <div class="spacer medium"></div>
    {%- endif -%}

    {% comment %} END Discount Codes {% endcomment %}

    <div class="grid-x grid-padding-x">
        <div class="large-6 medium-6 small-6 cell">
            <h3 class="order-total">Total</h3>
        </div>
        <div class="large-6 medium-6 small-6 cell text-right">
            <span class="order-total">
            {%- assign total_amount = context.exports.order.total_amount | divided_by: 100 | advanced_format: '%.2f' | default: "0.00" -%}
            {%- assign total_amount = total_amount | pricify -%}
            {%- unless total_amount contains '.' -%}
                {%- assign total_amount = total_amount | append: '.00' -%}
            {%- endunless -%}
            {{ total_amount }}
            </span>
        </div>
    </div>
</div>
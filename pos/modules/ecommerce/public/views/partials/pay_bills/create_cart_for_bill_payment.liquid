{% comment %}
Add to cart 'payable'
     - For IIA orders breakdown only
     - Amount in cart does not affect the order/payment value
{% endcomment %}

{%- if user_id -%}
    {%- comment -%}Optional parameter to get specific user's cart{%- endcomment -%}
    {%- assign user_id = user_id -%}
{%- else -%}
    {%- comment -%}Automatically get & set user_id parameter {%- endcomment -%}
    {%- if context.current_user.id -%}
        {%- assign user_id = context.current_user.id -%}
    {%- else -%}
        {%- assign user_id = context.session.session_id -%}
    {%- endif -%}
{%- endif -%}

{% parse_json cart_payload %}
{
    "properties_attributes": {
        "user_id": "{{ user_id }}",
        "quantity": 1,
        "order_id": "",
        "status": "Cart",
        "product_name": "{{ form.properties.invoice_number | default: "Bills Payment" }}",
        "product_price": {{ form.properties.total_amount | times: 100 | advanced_format: '%.0f' }},
        "tax_amount": 0,
        "shipping_amount": 0
    }
}
{% endparse_json %}

{% export cart_payload %}

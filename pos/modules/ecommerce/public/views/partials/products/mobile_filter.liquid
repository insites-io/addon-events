{%- comment -%} 
    Parameter from parent
    - parent_id (id of current category in slug2)
{%- endcomment -%} 
<ins-drawer 
    show-header="false" 
    position="left"
    id="mobile-filter-drawer">


{%- comment -%} Step: Check if category or main product page {%- endcomment -%}
{%- if context.params.slug2 -%}
    {%- comment -%} Sub-Step: Create a filter to get the subcategory of the parent category {%- endcomment -%}
    {%- parse_json params -%}
    {
        "parent_ids": ["{{ parent_id }}"]
    }
    {%- endparse_json -%}
    {%- graphql sub_category_data = 'modules/ecommerce/shop/get_category_ids', args: params | dig: 'items' -%}

    <div class="grid-x">
        <div class="small-12 cell">
            <div class="text-right align-right">
                <ins-button label="" icon="icon-close-1" id="mobile-filter-cls"></ins-button>
            </div>
        </div> 
        <div class="small-12 cell">
            <div id="sub-categories" class="sub-category no-icons">
                {%- for subcat in sub_category_data.results -%}
                    {%- parse_json sub_params -%}
                    { 
                        "parent_ids": ["{{ subcat.id }}"]        
                    }
                    {%- endparse_json -%}
                    {%- graphql lvl_two_cat_data = 'modules/ecommerce/shop/get_category_ids', args: sub_params | dig: 'items' -%}

                    {%- if lvl_two_cat_data.total_entries > 0 -%}
                    <ins-accordion menu>
                        <ins-accordion-item id="sub-{{subcat.id}}"
                            class="sub-cat-accor ui-sidebar" 
                            heading="{{subcat.name}}" 
                            link="{{subcat.slug}}"
                            link-target="_self" 
                            open-icon="icon-plus"
                            close-icon="icon-minus"
                            {% if context.params.slug2 == 'subcat.slug'%}active{% endif %} 
                            arrow-activated>
                            {%- for lvltwosub in lvl_two_cat_data.results -%}
                            <a href="{{lvltwosub.slug}}">
                                <div class="ui-sidebar" id="sub-{{lvltwosub.id}}">{{lvltwosub.name}}</div>
                            </a>
                            {%- endfor -%}
                        </ins-accordion-item>
                    </ins-accordion>
                    {%- else -%}                    
                    <a href="{{subcat.slug}}">
                        <div class="sub-cat" id="sub-{{subcat.id}}">{{subcat.name}}</div>
                    </a>
                    {%- endif -%}    
                {%- endfor -%}
            </div>
            <div class="spacer x-large"></div>
        </div>
    </div>

{%- else -%}

    {%- comment -%} Sub-Step: Get all the list of the parent category  {%- endcomment -%}
    {%- graphql parent_category = 'modules/ecommerce/shop/get_category_parent', page: 1, size: 100 | dig: 'items' -%}
    {%- if parent_category.total_entries > 0 -%}
        <div class="grid-x">
            <div class="small-12 cell">
                <div class="text-right align-right">
                    <ins-button label="" icon="icon-close-1" id="mobile-filter-cls"></ins-button>
                </div>
            </div> 
            <div class="small-12 cell">
                <div id="main-categories" class="main-category no-icons">
                {%- for catMenu in parent_category.results -%}
                    <a href="/products/{{catMenu.slug}}" class="cat">
                        {{ catMenu.name }}
                    </a>
                {%- endfor -%}
                </div>
                <div class="spacer x-large"></div>
            </div>
        </div>
    {%- endif -%}

{%- endif -%}

</ins-drawer>
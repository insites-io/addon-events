{%- comment -%}START: Form callback action{%- endcomment -%}

{% comment %} GET user_id used  {% endcomment %}
{%- if context.current_user.id -%}
    {%- assign user_id = context.current_user.id -%}
{%- else -%}
    {%- assign user_id = context.session.session_id -%}
{%- endif -%}

{%- comment -%}Step 1: Get product or variant added to cart{%- endcomment -%}
{%- if form.properties.product_variant_id -%}
    {%- comment -%}Step 1-A: check if added is 'variant' {%- endcomment -%}
    {% graphql product = 'modules/ecommerce/shop/get_product_variants_minified', 
        id: form.properties.product_variant_id 
        | fetch: "items" | fetch: "results" | first -%}
{%- else -%}
    {%- comment -%}Step 1-B: check if added is 'main product' {%- endcomment -%}    
    {% graphql product = 'modules/ecommerce/shop/get_product_detail_minified', 
        id: form.properties.product_id 
        | fetch: "items" | fetch: "results" | first -%}
{%- endif -%}

{%- comment -%}Step 2: Check if product / variant exist (have match in cart){%- endcomment -%}
{%- assign not_id = form.id | split: "," -%} 
{%- assign update_cart_id = form.id -%} 
{%- graphql cart = 'modules/ecommerce/cart/get_cart_quantity', 
    not_id: not_id,
    user_id: user_id, 
    product_id: form.properties.product_id, 
    product_variant_id: form.properties.product_variant_id,
    status: "Cart" | fetch: "items" | fetch: "results" | first %}

{%- if cart -%}
    {%- assign cart_id = cart.id -%}
    {%- assign update_cart_id = cart.id -%} 
    {%- assign cart_qty = cart.quantity -%}
{%- endif -%}

{%- comment -%}Step 3: compute for price & taxes and update quantity {%- endcomment -%}
{%- assign product_price = product.regular_price | times: 100 -%}
{%- if product.on_sale -%}
    {%- assign product_price = product.sale_price | times: 100 -%}
{%- endif -%}

{%- assign tax = product.tax | divided_by: 100.0 -%}
{%- assign tax_amount = product_price | times: tax | default: 0.0 -%}    

{%- assign shipping_amount = 0.0 -%}
{%- if product.free_shipping == false -%}
    {%- assign shipping_amount = product.shipping_cost | times: 100 -%}
{%- endif -%}

{%- assign cart_qty = cart_qty | plus: form.properties.quantity -%}
{%- if cart_qty > product.stock -%}
    {%- assign cart_qty = product.stock -%}
{%- endif -%}


{%- comment -%}Step 4: Update the older instance of the item in cart {%- endcomment -%}
{%- graphql update_cart = "modules/ecommerce/cart/update_cart", 
    id: update_cart_id,
    quantity: cart_qty,
    product_price: product_price,
    tax_amount: tax_amount,
    shipping_amount: shipping_amount -%}


{%- comment -%}Step 5: Update & delete duplicate cart items{%- endcomment -%}
{%- if cart -%}
    {%- comment -%}Delete duplicate product on cart - pOS hard delete{%- endcomment -%}
    {%- graphql delete_cart = "modules/ecommerce/cart/delete_cart", id: form.id -%}
{%- endif -%}
{%- comment -%}Export data (if needed){%- endcomment -%}


{%- comment -%}END: Form callback action{%- endcomment -%}
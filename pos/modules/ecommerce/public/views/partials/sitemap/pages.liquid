{%- assign parent_slug = "/products" -%}
{%- graphql product_list = 'modules/ins_template_ecommerce/shop/get_product_list', 
    page: 1, size: 500, is_enabled: true, is_archived: false -%} 
{%- if product_list.items.total_entries > 0 -%}
    {%- comment -%}Loop pagination{%- endcomment -%}
    {%- for page in (1..product_list.items.total_pages) -%}
        {%- for item in product_list.items.results -%}
            {%- if item.properties.slug != blank and item.properties.slug != '' and item.properties.slug != null -%}
                <url>
                    <loc>https://{{ context.location.host }}{{ parent_slug }}/{{ item.properties.slug }}</loc>
                    {%- comment -%}Last data modified: 'YYYY-MM-DD' {%- endcomment -%}
                    <lastmod>{{ item.updated_at | date: '%Y-%m-%d' }}</lastmod>
                    <changefreq>{{ item.sitemap_changefreq | downcase | default: 'monthly' }}</changefreq>
                    <priority>{{ item.sitemap_priority | advanced_format: '%.1f' | default: 1.0 }}</priority>
                </url> 
            {%- endif -%}
        {%- endfor -%}
    {%- endfor -%}
{%- endif -%}

{% graphql stripe_create_card = 'modules/ins_template_ecommerce/system/trigger_api_call', 
    name: "modules/insites_ecommerce/create_card",
    data: stripe_card
    | dig: 'items' | dig: 'response' %}
    
    {%- assign stripe_create_card = stripe_create_card.body | parse_json -%}
    {% log "---- API Response - Stripe 'create_card' ----" %}
    {% parse_json credit_card %}
    {
        "gateway_id": "{{ stripe_create_card.id }}",
        "gateway_customer_id": "{{ stripe_card.customer_id }}",
        "user_id": "{{ user_id }}",
        "brand": "{{ stripe_create_card.brand }}",
        "exp_month": "{{ stripe_create_card.exp_month }}",
        "exp_year": "{{ stripe_create_card.exp_year }}",
        "last4": "{{ stripe_create_card.last4 }}"
    }
    {% endparse_json %}
    {% comment %} Create pOS credit card model {% endcomment %}
    {% graphql card_model = "modules/ins_template_ecommerce/credit_card/create_credit_card"
        args: credit_card | dig: "items" %}
    {% log "---- POS Card model ----" %}

{%- comment -%}Return Stripe Card ID{%- endcomment -%}
{%- if return == true -%}
    {{ stripe_create_card.id }}
{%- endif -%}
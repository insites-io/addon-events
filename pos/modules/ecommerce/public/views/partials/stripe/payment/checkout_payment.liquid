{% log "Checkout Form Data " %}

{%- assign stripe_customer_id = blank -%}
{%- assign customer_email = form.properties.billing_email | strip -%}
{%- assign customer_name = form.properties.billing_first_name | append: ' ' | append: form.properties.billing_last_name -%}
{%- assign user_id = user_id | default: blank -%}
{%- assign company_id = company_id | default: blank -%}
{%- assign company_name = company_name | default: blank -%}
{%- assign charge_to_this_card = false -%}
{%- assign account_verified = account_verified | default: false -%} 

{%- comment -%} STEP 1: Stripe Customer  {%- endcomment -%}
{%- graphql stripe_customer = "modules/ins_template_ecommerce/customer/get_customer_model" 
    email: customer_email,
    gateway_name: "Stripe" 
    | dig: "items" | dig: "results" | first -%}
{% log stripe_customer, type: "Check existing stripe / customer model ?? ==== " %}

{%- if stripe_customer.id -%}
{%- comment -%}Step 1-A: Customer Stripe data exist. Proceed payment process {%- endcomment -%}

{%- comment -%}Step 1-A.1: Get updated 'user' data{%- endcomment -%}
    {%- graphql user = "modules/ins_template_ecommerce/user/get_user_by_email" 
        email: customer_email
        | dig: "items" | dig: "results" | first -%}
    
    {%- assign customer_model_id = stripe_customer.id | downcase -%}
    {%- assign user_id = user.id -%}
    {%- assign customer_name = user.first_name | append: ' ' | append: user.last_name -%}

{%- comment -%}Step 1-A.2: Update customer model data{%- endcomment -%}
    {%- graphql customer_model = "modules/ins_template_ecommerce/customer/update_customer_model", 
        id: customer_model_id
        user_id: user_id,
        name: customer_name | dig: "items" -%}
    
    {% log customer_model, type: "===== Customer model updated =====" %}
    
{%- comment -%}Step 1-A.3: Customer Stripe data exist. Proceed create stripe credit card {%- endcomment -%}
    {%- assign stripe_customer_id = customer_model.properties.gateway_id -%}
    {% log stripe_customer_id, type: "Exist True ---- stripe_customer_id ----" %}

    {%- assign check_new = form.properties.stripe_credit_card | split: '_' | first | downcase -%}
    {%- if check_new == 'tok' -%}
        {%- comment -%}Create new card object payload {%- endcomment -%}
        {% parse_json stripe_card %}
        {
            "customer_id": "{{ stripe_customer_id }}",
            "source": "{{ form.properties.stripe_credit_card }}"
        }
        {% endparse_json %}
        {%- comment -%}Create new card on Stripe API {%- endcomment -%}
        
        {%- capture charge_to_this_card -%}
            {%- if account_verified and user_id -%}
                {%- assign bind_card_user_id = user_id | default: blank -%}
            {%- endif -%}
            {%- include 'modules/ins_template_ecommerce/stripe/credit_card/create_credit_card', 
                stripe_card: stripe_card,
                user_id: bind_card_user_id
                return: true -%}
        {%- endcapture -%}
        {%- assign charge_to_this_card = charge_to_this_card | strip_newlines | strip -%}
    {%- elsif check_new == 'card' -%}
        {%- assign charge_to_this_card = form.properties.stripe_credit_card -%}
        {%- if context.current_user.id and account_verified -%}
        {% comment %} Optional: Update Credit Card, if user is logged in & verified, set user_id {% endcomment %}
        {% comment %} 
            {%- graphql current_card = "modules/ins_template_ecommerce/credit_card/get_credit_card", 
                gateway_id: charge_to_this_card,
                size: 1 | dig: 'items' | dig: 'results' | first -%}
            {%- graphql update_credit_card = 'modules/ins_template_ecommerce/credit_card/update_credit_card',
                id: current_card.id,
                user_id: user_id | dig: 'items' -%}
            {% log update_credit_card, type: "---- Updated CREDIT CARD ----" %}
        {% endcomment %}
        {%- endif -%}
    {%- endif -%}
    {% log charge_to_this_card, type: "---- CHARGE TO THIS CARD ----" %}
    {%- comment -%}Proceed to Step 2: Payment {%- endcomment -%}
{%- else -%}
{%- comment -%}Step 1-B: New customer: Create Stripe customer data{%- endcomment -%}
    {%- unless user_id -%}
        {%- graphql user = "modules/ins_template_ecommerce/user/get_user_by_email" 
            email: customer_email
            | dig: "items" | dig: "results" | first -%}
        {%- assign user_id = user.id -%}
    {%- endunless -%}

    {% parse_json "stripe_customer" %}
    {
        "email": "{{ customer_email }}",
        "name": "{{ customer_name }}",
        "source": "{{ form.properties.stripe_credit_card }}",
        "description": ""
    }
    {% endparse_json %}
    {%- comment -%}
        - optional 'source' payload
    {%- endcomment -%}
    {% graphql stripe_create_customer = 'modules/ins_template_ecommerce/system/trigger_api_call', 
        name: "modules/ins_template_ecommerce/create_customer",
        data: stripe_customer
        | dig: 'items' | dig: 'response' %}
    {% comment %} End TODO {% endcomment %}

    {%- assign stripe_create_customer = stripe_create_customer.body | parse_json  -%}
    {%- assign stripe_customer_id = stripe_create_customer.id -%}
    

    {%- comment -%}Save Stripe credit card to pOS model{%- endcomment -%}
    {%- assign stripe_card = stripe_create_customer.sources.data[0] -%}
    {% parse_json credit_card %}
    {
        "gateway_id": "{{ stripe_card.id }}",
        "gateway_customer_id": "{{ stripe_customer_id }}",
        "user_id": "{{ user_id }}",
        "brand": "{{ stripe_card.brand }}",
        "exp_month": "{{ stripe_card.exp_month }}",
        "exp_year": "{{ stripe_card.exp_year }}",
        "last4": "{{ stripe_card.last4 }}"
    }
    {% endparse_json %}

    {% log credit_card, type: "---- Stripe PAYLOAD: create_credit_card ----" %}
    {% graphql card_model = "modules/ins_template_ecommerce/credit_card/create_credit_card"
        args: credit_card %}
    {%- comment -%}END Save Stripe card to pOS {%- endcomment -%}
    {% log card_model, type: "---- Stripe RESPONSE : create_credit_card ----" %}

    {% parse_json customer_data %}
    {
        "gateway_id": "{{ stripe_create_customer.id }}",
        "gateway_name": "Stripe",
        {%- if charge_to_this_card -%}
            "default_source": "{{ charge_to_this_card }}",
        {%- endif -%}
        "external_id": "",
        "user_id": "{{ user_id }}",
        "email": "{{ customer_email }}",
        "name": "{{ customer_name }}"
        
    }
    {% endparse_json %}
    {% log customer_data, type: "===== Create Customer PAYLOAD =====" %}
    {%- graphql customer_model = "modules/ins_template_ecommerce/customer/create_customer_model", 
        args: customer_data -%}
    {% log customer_model, type: "===== Created Customer model =====" %}
{%- endif -%}


{%- comment -%} STEP 2: Stripe Charge / Payment  {%- endcomment -%}
{% parse_json "create_charge" %}
{
    "idempotency_key": "{{ '' | uuid }}",
    "currency": "AUD",
    "amount": "{{ form.properties.total_amount | advanced_format: '%.0f' }}",
    "customer": "{{ stripe_customer_id }}",
    {%- if charge_to_this_card -%}
        "source": "{{ charge_to_this_card }}",
    {%- endif -%}
    "description": "Insites Order ID: {{ form.id }} (Insites Customer ID: {{ user_id }})",
    "metadata": {
        "Insites Order ID": "{{ form.id }}",
        "Insites Customer ID": "{{ user_id }}",
        "Insites Company ID": "{{ company_id }}",
        "Insites Company Name": "{{ company_name }}",
        "Insites Order": "https://{{ context.location.host }}/admin/insites#/ecommerce/order/{{ form.id }}"
    },
    "statement_descriptor": "{{ form.properties.statement_descriptor }}"
}
{% endparse_json %}

{% log create_charge, type: "=== START PROCESS: STRIPE PAYMENT ==="%}

{% graphql stripe_create_charge = 'modules/ins_template_ecommerce/system/trigger_api_call', 
    name: "modules/insites_ecommerce/create_payment",
    data: create_charge 
    | dig: "items" | dig: "response" %}

{%- assign stripe_create_charge = stripe_create_charge.body | parse_json -%}
{%- assign payment_response = stripe_create_charge -%}

{% export payment_response %}

{% log "=== END PROCESS: STRIPE PAYMENT ===" %}